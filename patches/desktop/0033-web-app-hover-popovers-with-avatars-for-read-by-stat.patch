+/**
+ * Wraps the delivery-status icon so that hovering it reveals a popover with the
+ * people who have read the message (avatar + name + relative timestamp), or a
+ * short status label when there's no read-receipt info to show.
+ */
+function ReadByHoverInfo(props: {
+  messageId: number
+  status: msgStatus
+  error: string | null
+  children: React.ReactNode
+}) {
+  return (
+    <HoverInfoTrigger
+      align='end'
+      card={
+        <ReadByHoverCard
+          messageId={props.messageId}
+          status={props.status}
+          error={props.error}
+        />
+      }
+    >
+      {props.children}
+    </HoverInfoTrigger>
+  )
+}
+
+function ReadByHoverCard(props: {
+  messageId: number
+  status: msgStatus
+  error: string | null
+}) {
+  const tx = useTranslationFunction()
+  const accountId = selectedAccountId()
+
+  const receiptsFetch = useRpcFetch(BackendRemote.rpc.getMessageReadReceipts, [
+    accountId,
+    props.messageId,
+  ])
+  const refresh = receiptsFetch.refresh
+  useEffect(
+    () =>
+      onDCEvent(accountId, 'MsgRead', ({ msgId }) => {
+        if (msgId === props.messageId) {
+          refresh()
+        }
+      }),
+    [accountId, props.messageId, refresh]
+  )
+
+  const receipts = (
+    receiptsFetch.lingeringResult?.ok ? receiptsFetch.lingeringResult.value : []
+  )
+    .filter(receipt => receipt.timestamp != null)
+    // Most recently read first.
+    .sort((a, b) => b.timestamp - a.timestamp)
+
+  const contacts = useContactsById(receipts.map(r => r.contactId))
+
+  const rows: PersonRow[] = receipts
+    .map((receipt): PersonRow | null => {
+      const contact = contacts[receipt.contactId]
+      if (!contact) {
+        return null
+      }
+      return {
+        key: receipt.contactId,
+        contact,
+        detail: <RelativeTime timestamp={receipt.timestamp} />,
+        detailTitle: moment(receipt.timestamp * 1000).format('LLLL'),
+      }
+    })
+    .filter((row): row is PersonRow => row !== null)
+
+  // When there are no read receipts we still show a short status label instead
+  // of an empty popover.
+  const statusLabel =
+    props.error !== null
+      ? tx('msg_status_hover_error')
+      : props.status === 'sending'
+        ? tx('msg_status_hover_sending')
+        : props.status === 'read'
+          ? tx('read_by')
+          : tx('msg_status_hover_delivered')
+
+  const loading = receiptsFetch.loading && receiptsFetch.lingeringResult == null
+
+  return (
+    <PeopleHoverCard
+      title={rows.length > 0 ? tx('read_by') : statusLabel}
+      rows={rows}
+      loading={loading}
+    />
+  )
+}
+
 function ViewCount(props: { messageId: number }) {
   const viewCountFetch = useRpcFetch(
     useMemo(
