+}
+
+.peopleHoverDetail {
+  flex-shrink: 0;
+  opacity: 0.65;
+  font-size: 12px;
+  white-space: nowrap;
+}
+
+.peopleHoverEmpty {
+  padding: 2px 4px;
+  opacity: 0.7;
+  font-size: 12px;
+}
