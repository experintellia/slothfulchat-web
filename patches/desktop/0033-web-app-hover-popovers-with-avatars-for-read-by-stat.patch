+  font-size: 13px;
+  line-height: 1.3;
+}
+
+.peopleHoverTitle {
+  font-weight: 600;
+  font-size: 12px;
+  opacity: 0.75;
+  padding: 2px 4px 6px;
+}
+
+.peopleHoverList {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+}
+
+.peopleHoverRow {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 3px 4px;
+  border-radius: 6px;
+
+  // The shared Avatar component ships as `.avatar.small` at 32px; shrink it a
+  // touch so the row stays compact.
+  :global(.avatar.small) {
+    width: 24px;
+    height: 24px;
+    min-width: 24px;
+    line-height: 24px;
+    flex-shrink: 0;
+  }
+
+  :global(.avatar.small .content) {
+    font-size: 12px;
+  }
+}
+
+.peopleHoverName {
+  flex: 1 1 auto;
+  min-width: 0;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
