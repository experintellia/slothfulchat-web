+/**
+ * Popover contents for the reactions cluster: everyone who reacted, each with
+ * their avatar, name and the emoji they picked. Reactors are grouped by emoji
+ * following the core's most-used-first ordering.
+ */
+function ReactionsHoverCard(props: { reactionsData: T.Reactions }) {
+  const tx = useTranslationFunction()
+  const { reactions, reactionsByContact } = props.reactionsData
+
+  const reactors = useMemo(() => {
+    const entries: { contactId: number; emoji: string }[] = []
+    for (const { emoji } of reactions) {
+      for (const [contactId, emojis] of Object.entries(reactionsByContact)) {
+        // The dialog and the bubble only ever show a contact's first reaction,
+        // so we mirror that here.
+        if (emojis[0] === emoji) {
+          entries.push({ contactId: Number(contactId), emoji })
+        }
+      }
+    }
+    return entries
+  }, [reactions, reactionsByContact])
+
+  const contacts = useContactsById(reactors.map(r => r.contactId))
+
+  const rows: PersonRow[] = reactors
+    .map(({ contactId, emoji }): PersonRow | null => {
+      const contact = contacts[contactId]
+      if (!contact) {
+        return null
+      }
+      return {
+        key: contactId,
+        contact,
+        detail: <span className={styles.hoverEmoji}>{emoji}</span>,
+        detailTitle: tx('reacted_with', emoji),
+      }
+    })
+    .filter((row): row is PersonRow => row !== null)
+
+  const loading = rows.length === 0 && reactors.length > 0
+
+  return (
+    <PeopleHoverCard title={tx('reactions')} rows={rows} loading={loading} />
   )
 }
