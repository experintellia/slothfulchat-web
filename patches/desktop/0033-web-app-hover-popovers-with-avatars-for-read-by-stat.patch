+.hoverInfoTrigger {
+  position: relative;
+  display: inline-flex;
+  align-items: center;
+}
+
+// Anchors the popover to the trigger without taking up layout space. The card
+// itself opens upward (bottom: 100%) so it doesn't get clipped by content
+// below the message footer.
+.hoverInfoAnchor {
+  position: absolute;
+  bottom: calc(100% + 6px);
+  z-index: 200;
+  // Let the pointer travel from the trigger onto the card without the small
+  // gap counting as a mouse-leave.
+  padding-bottom: 6px;
+  margin-bottom: -6px;
+  pointer-events: auto;
+}
+
+.anchorEnd {
+  inset-inline-end: 0;
+}
+
+.anchorStart {
+  inset-inline-start: 0;
+}
+
+.peopleHoverCard {
+  background-color: var(--contextMenuBg, rgb(30, 30, 30));
+  color: var(--contextMenuText, white);
+  border: 1px solid var(--contextMenuBorder, rgba(120, 120, 120, 0.3));
+  border-radius: 8px;
+  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
+  padding: 8px;
+  min-width: 160px;
+  max-width: 280px;
+  width: max-content;
+  text-align: start;
+  cursor: default;
+  // Restore a sensible font size — the trigger lives inside the tiny metadata
