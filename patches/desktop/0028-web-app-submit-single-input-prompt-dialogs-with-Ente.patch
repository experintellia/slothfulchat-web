+++ b/packages/frontend/src/components/AccountListSidebar/EditPrivateTagDialog.tsx
@@ -31,24 +31,26 @@ export function EditPrivateTagDialog({
   return (
     <Dialog onClose={onClose} canOutsideClickClose={true}>
       <DialogHeader title={tx('profile_tag')} />
-      <DialogBody>
-        <DialogContent>
-          <p>{tx('profile_tag_explain')}</p>
-          <DeltaInput
-            id='profile_tag'
-            // label={tx('profile_tag')}
-            placeholder={tx('profile_tag_hint')}
-            value={tag}
-            onChange={(
-              event: React.FormEvent<HTMLElement> &
-                React.ChangeEvent<HTMLInputElement>
