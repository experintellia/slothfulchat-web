@@ -0,0 +1,66 @@
+// Remembered voice-message playback positions, persisted in localStorage under
+// one key. Injectable storage + clock so it's testable in node (mocha).
+//
+// ponytail: keyed by the `src` string (the transformed blob URL, stable per
+// message file) instead of threading messageId through AudioPlayer. Capped at
+// ~300 entries, oldest-by-`at` dropped; all storage access is try/caught so
+// quota / private-mode just no-ops.
+
+const KEY = 'voiceMessagePlaybackPositions'
+const CAP = 300
+
+type Entry = { t: number; at: number }
+type StoreShape = Record<string, Entry>
+type StorageLike = Pick<Storage, 'getItem' | 'setItem'>
+
+export function makePositionStore(
+  storage: StorageLike,
+  now: () => number = () => Date.now()
+) {
+  const read = (): StoreShape => {
+    try {
+      return JSON.parse(storage.getItem(KEY) || '{}') as StoreShape
+    } catch {
+      return {}
+    }
+  }
+  const write = (s: StoreShape): void => {
+    try {
+      storage.setItem(KEY, JSON.stringify(s))
+    } catch {
+      // storage may be blocked (private mode / quota); positions are optional
+    }
+  }
+  return {
+    getPosition(src: string): number | null {
+      const e = read()[src]
+      return e ? e.t : null
+    },
+    setPosition(src: string, t: number): void {
+      const s = read()
+      s[src] = { t, at: now() }
+      const keys = Object.keys(s)
+      if (keys.length > CAP) {
+        keys.sort((a, b) => (s[a]?.at ?? 0) - (s[b]?.at ?? 0))
+        for (const k of keys.slice(0, keys.length - CAP)) {
+          delete s[k]
+        }
+      }
+      write(s)
+    },
+    clearPosition(src: string): void {
+      const s = read()
+      if (src in s) {
+        delete s[src]
+        write(s)
+      }
+    },
+  }
+}
+
+// Browser default; a no-op storage keeps import-time safe where localStorage is
