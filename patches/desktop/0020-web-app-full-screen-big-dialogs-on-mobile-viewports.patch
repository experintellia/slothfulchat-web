diff --git a/packages/frontend/src/components/Dialog/styles.module.scss b/packages/frontend/src/components/Dialog/styles.module.scss
index 3eeed1a83..dbbf3a6c2 100644
--- a/packages/frontend/src/components/Dialog/styles.module.scss
+++ b/packages/frontend/src/components/Dialog/styles.module.scss
@@ -45,6 +45,31 @@ $paddingVertical: 20px;
   }
 }
 
+/* Big dialogs (settings, about, gallery, profiles, new chat, QR scanner…)
+   go edge-to-edge on small/mobile viewports: full screen, no rounded
+   corners, no margin or drop shadow. Opt in with the `fullscreenOnMobile`
+   prop on <Dialog> / <DialogWithHeader>. */
+@media (max-width: variables.$dialog-breakpoint) {
+  .dialog:not(.unstyled).fullscreenOnMobile {
+    border-radius: 0;
+    box-shadow: none;
+    margin: 0;
+    width: 100vw;
+    min-width: 100vw;
+    max-width: 100vw;
+    height: 100dvh;
+    max-height: 100dvh;
+
+    &:not(.noTopPadding) {
+      padding-top: 0;
+    }
+
+    .dialogBody {
+      max-height: none;
+    }
+  }
+}
+
 .dialogHeader {
   width: 100%;
   align-items: center;
