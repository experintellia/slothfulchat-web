+++ b/packages/frontend/src/components/composer/linkPreview/LinkPreviewGhost.tsx
@@ -0,0 +1,122 @@
+import React from 'react'
+
+import { CloseButton } from '../../Dialog'
+import Spinner from '../../Spinner'
+import type { UseLinkPreview } from './useLinkPreview'
+
+import styles from './styles.module.scss'
+
+type Props = {
+  preview: UseLinkPreview
+}
+
+/**
+ * The composer's link-preview affordance. Auto-appears as a quiet dashed "ghost"
+ * when the draft contains a URL and no image is attached; becomes a chip once a
+ * preview has been generated and attached.
+ */
+export default function LinkPreviewGhost({ preview }: Props) {
+  const { phase } = preview
+  if (!phase) {
+    return null
+  }
+
+  if (phase.kind === 'loading') {
+    return (
+      <div className={styles.bar} aria-live='polite' data-testid='link-preview-loading'>
+        <Spinner size={18} />
+        <span className={styles.barLabel}>Generating preview…</span>
+      </div>
+    )
+  }
+
+  if (phase.kind === 'unavailable') {
+    return (
+      <div
+        className={styles.bar}
+        aria-live='polite'
+        data-testid='link-preview-unavailable'
+      >
+        <span className={styles.linkIcon} aria-hidden='true' />
+        <span className={styles.barLabel}>
+          Link previews need a bridge with unfurl enabled.
+        </span>
+        <CloseButton
+          onClick={preview.onDismiss}
+          aria-label='Dismiss'
+          data-testid='link-preview-dismiss'
+        />
+      </div>
+    )
+  }
+
+  if (phase.kind === 'idle') {
+    // Skeleton of the compact card "Add" will bake — light surface, placeholder
+    // title lines + the real host, and a thumbnail box on the right. We don't
+    // know yet whether the page has a (large) image, so preview the smaller
+    // variant to hint at the shape of the result.
+    return (
+      <div className={styles.ghost} data-testid='link-preview-ghost'>
+        <div className={styles.ghostLeft}>
+          <div className={styles.ghostCard} aria-hidden='true'>
+            <div className={styles.ghostBody}>
+              <span className={styles.skelLine} />
+              <span className={`${styles.skelLine} ${styles.skelLineShort}`} />
+              <span className={styles.ghostHost}>{phase.host}</span>
+            </div>
+            <span className={styles.ghostThumb} />
+          </div>
+          <span className={styles.ghostHint}>
+            Click “Add” to fetch and attach a preview
+          </span>
+        </div>
+        <div className={styles.ghostActions}>
+          <button
+            type='button'
+            className={styles.addButton}
+            onClick={preview.onAdd}
+            data-testid='link-preview-add'
+            aria-label='Add link preview'
+          >
+            Add
+          </button>
+          <CloseButton
+            onClick={preview.onDismiss}
+            aria-label='Dismiss preview'
+            data-testid='link-preview-dismiss'
+          />
+        </div>
+      </div>
+    )
+  }
+
+  // phase.kind === 'ready' — the baked card IS the preview (title/host/image are
+  // baked into it), so show it big and skip the redundant text; keep only the
+  // size toggle (with a word, not just a glyph) and remove.
+  const isHero = phase.layout === 'hero'
+  return (
+    <div className={styles.ready} data-testid='link-preview-ready'>
+      <img
+        className={styles.preview}
+        src={phase.image}
+        alt='Link preview to be sent'
+      />
+      <div className={styles.readyControls}>
+        <button
+          type='button'
+          className={styles.labelButton}
+          onClick={preview.onToggleLayout}
+          data-testid='link-preview-toggle'
+          aria-label={isHero ? 'Collapse to compact' : 'Expand to hero'}
+        >
+          {isHero ? '⤡ Smaller' : '⤢ Bigger'}
+        </button>
+        <CloseButton
+          onClick={preview.onRemove}
+          aria-label='Remove preview'
+          data-testid='link-preview-remove'
+        />
+      </div>
+    </div>
+  )
+}
diff --git a/packages/frontend/src/components/composer/linkPreview/detectUrl.ts b/packages/frontend/src/components/composer/linkPreview/detectUrl.ts
new file mode 100644
index 000000000..1a29ff2b0
--- /dev/null
+++ b/packages/frontend/src/components/composer/linkPreview/detectUrl.ts
@@ -0,0 +1,80 @@
+// Extracts the first "previewable" http(s) URL from composer draft text.
+//
+// A previewable URL is a plain http/https web link. We deliberately ignore
+// Delta Chat's own scheme links (invite codes, OpenPGP fingerprints, mailto,
+// etc.) because generating a web preview for them makes no sense and could be
+// privacy-surprising.
+
+const URL_RE = /\bhttps?:\/\/[^\s<>"'`]+/gi
+
+// Schemes/hosts we never preview even if they appear as an http(s) URL.
+const IGNORED_HOST_SUFFIXES = ['localhost', '127.0.0.1', '[::1]']
+
+/**
+ * Trailing characters that are almost never part of a URL when a link is typed
+ * inline in prose (closing brackets, sentence punctuation).
+ */
+function trimTrailingPunctuation(url: string): string {
+  let out = url
+  // Strip trailing punctuation, but keep a closing paren if there's a matching
+  // opening one inside the URL (e.g. Wikipedia "..._(disambiguation)").
+  // eslint-disable-next-line no-constant-condition
+  while (out.length > 0) {
+    const last = out[out.length - 1]
+    if (last === undefined) {
+      break
+    }
+    if (last === ')') {
+      const opens = (out.match(/\(/g) || []).length
+      const closes = (out.match(/\)/g) || []).length
+      if (closes > opens) {
+        out = out.slice(0, -1)
+        continue
+      }
+      break
+    }
+    if ('.,;:!?"\'`>]}'.includes(last)) {
+      out = out.slice(0, -1)
+      continue
+    }
+    break
+  }
+  return out
+}
+
+export type DetectedUrl = {
+  /** The normalized URL string, safe to pass to the fetcher. */
+  url: string
+  /** Lower-cased hostname without a leading `www.`. */
+  host: string
+}
+
+/**
+ * Returns the first previewable URL in `text`, or `null` if there is none.
+ * Only the first match is considered — we preview at most one link per message.
+ */
+export function detectPreviewableUrl(text: string): DetectedUrl | null {
+  if (!text) {
+    return null
+  }
+  URL_RE.lastIndex = 0
+  let match: RegExpExecArray | null
+  while ((match = URL_RE.exec(text)) !== null) {
+    const candidate = trimTrailingPunctuation(match[0])
+    let parsed: URL
+    try {
+      parsed = new URL(candidate)
+    } catch {
+      continue
+    }
+    if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') {
+      continue
+    }
+    const host = parsed.hostname.toLowerCase().replace(/^www\./, '')
+    if (!host || IGNORED_HOST_SUFFIXES.some(h => parsed.hostname === h)) {
+      continue
+    }
+    return { url: parsed.toString(), host }
+  }
+  return null
+}
diff --git a/packages/frontend/src/components/composer/linkPreview/generate.ts b/packages/frontend/src/components/composer/linkPreview/generate.ts
new file mode 100644
index 000000000..a582bf1b3
--- /dev/null
+++ b/packages/frontend/src/components/composer/linkPreview/generate.ts
@@ -0,0 +1,254 @@
+// Orchestrates link-preview generation: fetch the page's metadata + image,
+// render the card to a PNG, and stage it as a temp file ready for
+// `addFileToDraft(path, name, 'File')` (attached as File so core sends the PNG
+// uncompressed — see useLinkPreview; 'Image' would recode to alpha-less JPEG).
+//
+// NOTE ON SCOPE — this is a UI prototype, not the final design. Attaching the
+// preview as an *image* is a deliberate compromise so we can build and validate
+// the composer UX now while staying compatible with every existing client (an
+// image needs no receive-side change). The intended end state is to move preview
+// generation into *core* and carry the preview as real structured message
+// metadata (title/description/image/host as first-class message fields), not a
+// baked PNG. When that happens, this desktop card becomes a renderer over that
+// metadata.
+//
+// Fetching is WEBAPP-ONLY and goes through the bridge's unfurl endpoint. We do
+// NOT try a direct browser `fetch()` of the page first: browser fetches are
+// CORS-bound and virtually every real site blocks cross-origin reads of its
+// HTML, so a direct attempt almost always fails — and a blocked cross-origin
+// GET still hits the site, so it just double-fetches (sender's IP + bridge).
+// Instead we go straight to `GET /unfurl?url=…` on the configured ws-tcp
+// bridge's own HTTP port (`packages/ws-tcp-proxy/unfurl.mjs`) — a hardened
+// metadata fetcher (NOT a tunnel; that would be an open proxy) that fetches the
+// page server-side and returns OpenGraph metadata + the image as JSON with
+// permissive CORS. Nothing to configure app-side: we reuse the bridge URL. The
+// endpoint is on by default for a local/allow-all bridge; if it's unreachable
+// the composer shows a quiet "needs a bridge with unfurl" hint. (Native clients
+// will fetch directly, no CORS, and need none of this.)
+
+import { getLogger } from '@deltachat-desktop/shared/logger'
+import { runtime } from '@deltachat-desktop/runtime-interface'
+
+import { chooseLayout, type LinkMetadata, type PreviewLayout } from './openGraph'
+import { renderCardPng, type Drawable } from './renderCard'
+
+const log = getLogger('renderer/composer/linkPreview')
+
+/**
+ * Thrown when the unfurl endpoint can't be reached at all (no bridge, wrong
+ * URL, connection refused, or the browser blocking a localhost fetch) — as
+ * opposed to the endpoint responding that a given page has no preview. The
+ * composer turns this into a "needs a bridge with unfurl enabled" hint rather
+ * than silently doing nothing.
+ */
+export class UnfurlUnavailableError extends Error {}
+
+/**
+ * HTTP base of the unfurl endpoint, derived from the configured ws-tcp bridge:
+ * the unfurl route lives on the bridge's own port, so there is nothing extra to
+ * configure — we just reuse the bridge URL (`?proxy=` / `slothfulchat.proxyUrl`
+ * / per-instance default, matching runtime.ts) and swap the scheme (ws→http,
+ * wss→https). Webapp-only: native builds have no bridge URL.
+ */
+function unfurlBaseUrl(): string | null {
+  try {
+    const proxy =
+      new URLSearchParams(window.location.search).get('proxy') ||
+      window.localStorage.getItem('slothfulchat.proxyUrl') ||
+      (window as any).__slothfulConfig?.defaultProxyUrl ||
+      'ws://localhost:8641'
+    if (!proxy || !/^wss?:\/\//.test(proxy)) {
+      return null
+    }
+    return proxy.replace(/^ws(s?):\/\//, 'http$1://').replace(/\/+$/, '')
+  } catch {
+    return null
+  }
+}
+
+/** Shape of the unfurl service's JSON reply (see packages/ws-tcp-proxy/unfurl.mjs). */
+type UnfurlReply = {
+  url: string
+  title: string
+  description: string | null
+  isVideo: boolean
+  twitterCard: string | null
+  imageWidth: number | null
+  imageHeight: number | null
+  /** base64 (no data: prefix) og:image bytes, fetched by the service. */
+  image: string | null
+  imageMime: string | null
+}
+
+/**
+ * Fetch `url` via the bridge's unfurl endpoint. Returns already-parsed metadata
+ * plus the decoded thumbnail. Throws `UnfurlUnavailableError` when the endpoint
+ * itself can't be reached (→ "needs a bridge with unfurl" hint), or a plain
+ * Error when it responds but has no preview for this page (→ silent).
+ */
+async function fetchViaUnfurlService(
+  url: string
+): Promise<{ meta: LinkMetadata; thumbnail: Drawable }> {
+  const base = unfurlBaseUrl()
+  if (!base) {
+    throw new UnfurlUnavailableError('no bridge configured')
+  }
+  let res: Response
+  try {
+    res = await fetch(`${base}/unfurl?url=${encodeURIComponent(url)}`)
+  } catch (err) {
+    // network-level failure: no bridge, refused, or the browser blocked the
+    // localhost fetch (Local Network Access) — the endpoint is unreachable.
+    throw new UnfurlUnavailableError(`unfurl endpoint unreachable: ${err}`)
+  }
+  if (!res.ok) {
+    throw new Error(`unfurl replied ${res.status}`)
+  }
+  const data: UnfurlReply = await res.json()
+  if (!data || typeof data.title !== 'string' || !data.title) {
+    throw new Error('unfurl service returned no usable metadata')
+  }
+
+  let thumbnail: Drawable = null
+  if (data.image) {
+    try {
+      const mime =
+        data.imageMime && data.imageMime.startsWith('image')
+          ? data.imageMime
+          : 'image/jpeg'
+      const img = await loadImage(`data:${mime};base64,${data.image}`)
+      thumbnail = {
+        image: img,
+        naturalWidth: img.naturalWidth || 1,
+        naturalHeight: img.naturalHeight || 1,
+      }
+    } catch (err) {
+      log.info('unfurl thumbnail decode failed', url, err)
+    }
+  }
+
+  const host = (() => {
+    try {
+      return new URL(url).hostname.toLowerCase().replace(/^www\./, '')
+    } catch {
+      return url
+    }
+  })()
+  const isVideo = !!data.isVideo
+  const imageWidth = data.imageWidth ?? null
+  const imageHeight = data.imageHeight ?? null
+  const meta: LinkMetadata = {
+    url,
+    host,
+    title: data.title,
+    description: data.description ?? null,
+    imageUrl: null, // the image came inline; nothing left to fetch
+    imageWidth,
+    imageHeight,
+    isVideo,
+    suggestedLayout: chooseLayout({
+      isVideo,
+      twitterCard: data.twitterCard ?? null,
+      imageUrl: data.image ? url : null,
+      imageWidth,
+      imageHeight,
+    }),
+  }
+  return { meta, thumbnail }
+}
+
+function loadImage(dataUrl: string): Promise<HTMLImageElement> {
+  return new Promise((resolve, reject) => {
+    const img = new Image()
+    img.onload = () => resolve(img)
+    img.onerror = () => reject(new Error('image decode failed'))
+    img.src = dataUrl
+  })
+}
+
+/**
+ * A prepared preview: the fetched metadata plus the decoded thumbnail, kept in
+ * memory so the layout can be re-rendered (expand/collapse) without re-fetching.
+ */
+export type PreparedPreview = {
+  meta: LinkMetadata
+  thumbnail: Drawable
+  /** Layout picked from metadata; may differ from the initial `suggestedLayout`
+   *  once the real image aspect ratio is known. */
+  initialLayout: PreviewLayout
+}
+
+/**
+ * Fetch a URL into a ready-to-render preview, or `null` when the endpoint
+ * responds but there's nothing to show. Throws `UnfurlUnavailableError` when
+ * the unfurl endpoint can't be reached at all (the caller shows a hint).
+ * `accountId` is unused now (kept for signature stability with the eventual
+ * core-native path).
+ */
+export async function preparePreview(
+  _accountId: number,
+  url: string
+): Promise<PreparedPreview | null> {
+  let meta: LinkMetadata
+  let thumbnail: Drawable
+  try {
+    ;({ meta, thumbnail } = await fetchViaUnfurlService(url))
+  } catch (err) {
+    if (err instanceof UnfurlUnavailableError) {
+      throw err
+    }
+    log.info('no preview available for', url, err)
+    return null
+  }
+
+  let initialLayout = meta.suggestedLayout
+  // Refine when the site didn't declare dimensions but the decoded image is wide.
+  if (
+    initialLayout === 'compact' &&
+    thumbnail &&
+    !meta.isVideo &&
+    thumbnail.naturalWidth / thumbnail.naturalHeight >= 1.6 &&
+    thumbnail.naturalWidth >= 480
+  ) {
+    initialLayout = 'hero'
+  }
+  // A hero with no usable image looks empty — fall back to compact/text.
+  if (initialLayout === 'hero' && !thumbnail) {
+    initialLayout = 'compact'
+  }
+  return { meta, thumbnail, initialLayout }
+}
+
+export type StagedCard = {
+  path: string
+  fileName: string
+  width: number
+  height: number
+  bytes: number
+  /** The rendered PNG as a `data:` URL, so the composer can show the card
+   *  (what will actually be sent) before the message goes out. */
+  dataUrl: string
+}
+
+/** Render `prepared` at `layout` and stage a temp PNG (attached as File so it
+ * ships uncompressed with its transparency intact). */
+export async function stageCard(
+  prepared: PreparedPreview,
+  layout: PreviewLayout
+): Promise<StagedCard> {
+  const rendered = await renderCardPng({
+    meta: prepared.meta,
+    thumbnail: prepared.thumbnail,
+    layout,
+  })
+  const fileName = 'link-preview.png'
+  const path = await runtime.writeTempFileFromBase64(fileName, rendered.base64)
+  return {
+    path,
+    fileName,
+    width: rendered.width,
+    height: rendered.height,
+    bytes: rendered.bytes,
+    dataUrl: `data:image/png;base64,${rendered.base64}`,
+  }
+}
