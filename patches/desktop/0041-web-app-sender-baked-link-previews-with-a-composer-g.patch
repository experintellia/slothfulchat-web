--- /dev/null
+++ b/packages/frontend/src/components/composer/linkPreview/openGraph.ts
@@ -0,0 +1,56 @@
+// Preview metadata shape + the compact-vs-hero layout heuristic. The metadata
+// itself is fetched and parsed server-side by the bridge's unfurl endpoint
+// (see generate.ts / packages/ws-tcp-proxy/unfurl.mjs); this module only holds
+// the types the frontend consumes and the layout rule.
+
+export type PreviewLayout = 'compact' | 'hero'
+
+export type LinkMetadata = {
+  url: string
+  host: string
+  title: string
+  description: string | null
+  /** Absolute URL of the preview image, or null if the page declares none. */
+  imageUrl: string | null
+  imageWidth: number | null
+  imageHeight: number | null
+  isVideo: boolean
+  /** Layout the metadata asks for; the user can still override it. */
+  suggestedLayout: PreviewLayout
+}
+
+/**
+ * Decide compact vs hero from the metadata alone (no hardcoded site list).
+ * The site's own declarations win: a large-image twitter card or a video wants
+ * a hero; a plain summary card or a small/square image wants compact.
+ */
+export function chooseLayout(opts: {
+  isVideo: boolean
+  twitterCard: string | null
+  imageUrl: string | null
+  imageWidth: number | null
+  imageHeight: number | null
+}): PreviewLayout {
+  if (opts.isVideo) {
+    return 'hero'
+  }
+  const card = opts.twitterCard?.toLowerCase()
+  if (card === 'summary_large_image' || card === 'player') {
+    return 'hero'
+  }
+  if (card === 'summary') {
+    return 'compact'
+  }
+  if (opts.imageUrl && opts.imageWidth && opts.imageHeight) {
+    const wide = opts.imageWidth / opts.imageHeight >= 1.5
+    const bigEnough = opts.imageWidth >= 480
+    if (wide && bigEnough) {
+      return 'hero'
+    }
+    // Small or square images (favicons, avatars) read better as a side thumb.
+    return 'compact'
+  }
+  // Image with unknown dimensions: default to compact; the renderer measures the
+  // decoded image and can be nudged to hero there if it turns out wide.
+  return 'compact'
+}
diff --git a/packages/frontend/src/components/composer/linkPreview/renderCard.ts b/packages/frontend/src/components/composer/linkPreview/renderCard.ts
new file mode 100644
index 000000000..b6326c4ee
--- /dev/null
+++ b/packages/frontend/src/components/composer/linkPreview/renderCard.ts
@@ -0,0 +1,331 @@
+// Draws a self-contained link-preview card onto a canvas and exports it as PNG.
+//
+// The card carries its own opaque light surface so text stays legible on any
+// recipient theme; transparency is used only for the rounded-corner cut-outs and
+// the soft drop shadow, which composite cleanly onto any chat background.
+//
+// PNG is used for universal decodeability. Since PNG has no quality knob, size is
+// controlled by pixel dimensions: we render at 2x for crisp text and step the
+// scale down until the encoded image fits the byte budget.
+
+import type { LinkMetadata, PreviewLayout } from './openGraph'
+
+const BUDGET_BYTES = 600 * 1024 // keep previews well under ~0.6 MB
+const SCALES = [2, 1.5, 1.25, 1]
+
+// Locked light-surface palette (see docs/link-preview.md).
+const COLORS = {
+  surface: '#f4f6f9',
+  title: '#121821',
+  desc: '#525d68',
+  host: '#0e7f5b',
+  border: 'rgba(16,26,38,.14)',
+  shadow: 'rgba(8,14,22,.30)',
+}
+
+const CARD_W = 452 // logical card width (css px), excluding the shadow margin
+const RADIUS = 14
+const INNER_PAD = 16
+const HERO_H = 194
+const THUMB = 78 // compact side-thumbnail size
+
+export type Drawable = {
+  image: CanvasImageSource
+  naturalWidth: number
+  naturalHeight: number
+} | null
+
+export type RenderInput = {
+  meta: LinkMetadata
+  thumbnail: Drawable
+  layout: PreviewLayout
+}
+
+export type RenderedCard = {
+  /** base64 PNG (no data: prefix), ready for writeTempFileFromBase64. */
+  base64: string
+  width: number
+  height: number
+  bytes: number
+}
+
+function roundRect(
+  ctx: CanvasRenderingContext2D,
+  x: number,
+  y: number,
+  w: number,
+  h: number,
+  r: number
+) {
+  const rr = Math.min(r, w / 2, h / 2)
+  ctx.beginPath()
+  ctx.moveTo(x + rr, y)
+  ctx.arcTo(x + w, y, x + w, y + h, rr)
+  ctx.arcTo(x + w, y + h, x, y + h, rr)
+  ctx.arcTo(x, y + h, x, y, rr)
+  ctx.arcTo(x, y, x + w, y, rr)
+  ctx.closePath()
+}
+
+/** Wrap `text` to `maxW`, clamp to `maxLines`, ellipsis the last line. */
+function wrapLines(
+  ctx: CanvasRenderingContext2D,
+  text: string,
+  maxW: number,
+  maxLines: number,
+  font: string
+): string[] {
+  ctx.font = font
+  const words = text.split(/\s+/).filter(Boolean)
+  const lines: string[] = []
+  let line = ''
+  for (const w of words) {
+    const test = line ? line + ' ' + w : w
+    if (ctx.measureText(test).width > maxW && line) {
+      lines.push(line)
+      line = w
+      if (lines.length === maxLines) {
+        break
+      }
+    } else {
+      line = test
+    }
+  }
+  if (lines.length < maxLines && line) {
+    lines.push(line)
+  }
+  const consumedWords = lines.join(' ').split(/\s+/).filter(Boolean).length
+  if (consumedWords < words.length) {
+    let last = lines[lines.length - 1] || ''
+    while (last.length && ctx.measureText(last + '…').width > maxW) {
+      last = last.slice(0, -1)
+    }
+    lines[lines.length - 1] = last.replace(/\s+$/, '') + '…'
+  }
+  return lines
+}
+
+/** Draw pre-wrapped lines; returns the y of the last baseline. */
+function drawLines(
+  ctx: CanvasRenderingContext2D,
+  lines: string[],
+  x: number,
+  y: number,
+  lineH: number,
+  font: string,
+  color: string
+): number {
+  ctx.font = font
+  ctx.fillStyle = color
+  ctx.textBaseline = 'alphabetic'
+  for (let i = 0; i < lines.length; i++) {
+    ctx.fillText(lines[i] ?? '', x, y + lineH * (i + 1))
+  }
+  return y + lineH * lines.length
+}
+
+function drawHost(
+  ctx: CanvasRenderingContext2D,
+  host: string,
+  x: number,
+  y: number
+) {
+  const s = 12
+  roundRect(ctx, x, y - s + 1, s, s, 3)
+  ctx.fillStyle = COLORS.host
+  ctx.fill()
+  ctx.font = '650 12.5px system-ui, sans-serif'
+  ctx.fillStyle = COLORS.host
+  ctx.fillText(host.toUpperCase(), x + s + 7, y)
+}
+
+/** Draw a "cover"-fitted image into a clipped rounded rect. */
+function drawCover(
+  ctx: CanvasRenderingContext2D,
+  d: Drawable,
+  x: number,
+  y: number,
+  w: number,
+  h: number,
+  r: number
+) {
+  if (!d) {
+    // Neutral placeholder block so layout is stable even without an image.
+    roundRect(ctx, x, y, w, h, r)
+    ctx.fillStyle = '#dfe4ea'
+    ctx.fill()
+    return
+  }
+  ctx.save()
+  roundRect(ctx, x, y, w, h, r)
+  ctx.clip()
+  const scale = Math.max(w / d.naturalWidth, h / d.naturalHeight)
+  const dw = d.naturalWidth * scale
+  const dh = d.naturalHeight * scale
+  ctx.drawImage(d.image, x + (w - dw) / 2, y + (h - dh) / 2, dw, dh)
+  ctx.restore()
+}
+
+function drawPlayGlyph(
+  ctx: CanvasRenderingContext2D,
+  cx: number,
+  cy: number
+) {
+  const r = 26
+  ctx.save()
+  ctx.beginPath()
+  ctx.arc(cx, cy, r, 0, Math.PI * 2)
+  ctx.fillStyle = 'rgba(8,12,18,.55)'
+  ctx.fill()
+  ctx.beginPath()
+  ctx.moveTo(cx - 8, cy - 12)
+  ctx.lineTo(cx - 8, cy + 12)
+  ctx.lineTo(cx + 13, cy)
+  ctx.closePath()
+  ctx.fillStyle = '#ffffff'
+  ctx.fill()
+  ctx.restore()
+}
+
+/** Render one canvas at `scale` (device pixels per css px). */
+function buildCanvas(input: RenderInput, scale: number): HTMLCanvasElement {
+  const { meta, thumbnail, layout } = input
+  const PAD = 28
+  const hasThumb = thumbnail != null || layout === 'hero'
+  const titleFont = '600 17px system-ui, sans-serif'
+  const descFont = '400 14px system-ui, sans-serif'
+
+  // Measure the wrapped text first so the card is sized to its actual content
+  // (a fixed worst-case height leaves a blank band under short titles).
+  const c = document.createElement('canvas')
+  const ctx = c.getContext('2d')!
+  const sideThumb = hasThumb && layout !== 'hero'
+  const textW = CARD_W - INNER_PAD * 2 - (sideThumb ? THUMB + 14 : 0)
+  const titleLines = wrapLines(ctx, meta.title, textW, 2, titleFont)
+  const descLines = meta.description
+    ? wrapLines(ctx, meta.description, textW, sideThumb ? 1 : 2, descFont)
+    : []
+  // title block + optional description block + host row (baseline offset 20,
+  // ~6px descender allowance)
+  const textH =
+    22 * titleLines.length +
+    (descLines.length ? 4 + 20 * descLines.length : 0) +
+    20 + 6
+
+  let cardH: number
+  if (layout === 'hero') {
+    cardH = HERO_H + 4 + textH + INNER_PAD
+  } else {
+    const textCardH = INNER_PAD - 2 + textH + INNER_PAD
+    cardH = sideThumb ? Math.max(THUMB + INNER_PAD * 2, textCardH) : textCardH
+  }
+  cardH = Math.round(cardH)
+
+  const wCss = CARD_W + PAD * 2
+  const hCss = cardH + PAD * 2
+
+  c.width = Math.round(wCss * scale)
+  c.height = Math.round(hCss * scale)
+  ctx.scale(scale, scale)
+
+  // surface + shadow
+  ctx.save()
+  ctx.shadowColor = COLORS.shadow
+  ctx.shadowBlur = 22
+  ctx.shadowOffsetY = 8
+  ctx.fillStyle = COLORS.surface
+  roundRect(ctx, PAD, PAD, CARD_W, cardH, RADIUS)
+  ctx.fill()
+  ctx.restore()
+
+  // hairline border
+  ctx.lineWidth = 1
+  ctx.strokeStyle = COLORS.border
+  roundRect(ctx, PAD + 0.5, PAD + 0.5, CARD_W - 1, cardH - 1, RADIUS)
+  ctx.stroke()
+
+  // clip content to the card
+  ctx.save()
+  roundRect(ctx, PAD, PAD, CARD_W, cardH, RADIUS)
+  ctx.clip()
+
+  const ox = PAD
+  const oy = PAD
+  const tx = ox + INNER_PAD
+
+  if (layout === 'hero') {
+    drawCover(ctx, thumbnail, ox, oy, CARD_W, HERO_H, 0)
+    if (meta.isVideo) {
+      drawPlayGlyph(ctx, ox + CARD_W / 2, oy + HERO_H / 2)
+    }
+    const afterT = drawLines(
+      ctx, titleLines, tx, oy + HERO_H + 4, 22, titleFont, COLORS.title
+    )
+    const afterD = descLines.length
+      ? drawLines(ctx, descLines, tx, afterT + 4, 20, descFont, COLORS.desc)
+      : afterT
+    drawHost(ctx, meta.host, tx, afterD + 20)
+  } else {
+    if (sideThumb) {
+      const thx = ox + CARD_W - INNER_PAD - THUMB
+      const thy = oy + (cardH - THUMB) / 2
+      drawCover(ctx, thumbnail, thx, thy, THUMB, THUMB, Math.max(8, RADIUS - 6))
+    }
+    const afterT = drawLines(
+      ctx, titleLines, tx, oy + INNER_PAD - 2, 22, titleFont, COLORS.title
+    )
+    const afterD = descLines.length
+      ? drawLines(ctx, descLines, tx, afterT + 4, 20, descFont, COLORS.desc)
+      : afterT
+    drawHost(ctx, meta.host, tx, afterD + 20)
+  }
+  ctx.restore()
+  return c
+}
+
+function toPngBase64(
+  canvas: HTMLCanvasElement
+): Promise<{ base64: string; bytes: number }> {
+  return new Promise((resolve, reject) => {
+    canvas.toBlob(blob => {
+      if (!blob) {
+        reject(new Error('canvas.toBlob returned null'))
+        return
+      }
+      const reader = new FileReader()
+      reader.onerror = () => reject(reader.error)
+      reader.onloadend = () => {
+        const dataUrl = String(reader.result)
+        const base64 = dataUrl.slice(dataUrl.indexOf(',') + 1)
+        resolve({ base64, bytes: blob.size })
+      }
+      reader.readAsDataURL(blob)
+    }, 'image/png')
+  })
+}
+
+/**
+ * Render the card and return a PNG that fits the byte budget, stepping the
+ * pixel scale down until it does (last resort: return the smallest attempt).
+ */
+export async function renderCardPng(input: RenderInput): Promise<RenderedCard> {
+  let smallest: RenderedCard | null = null
+  for (const scale of SCALES) {
+    const canvas = buildCanvas(input, scale)
+    const { base64, bytes } = await toPngBase64(canvas)
+    const result = {
+      base64,
+      bytes,
+      width: canvas.width,
+      height: canvas.height,
+    }
+    if (bytes <= BUDGET_BYTES) {
+      return result
+    }
+    if (!smallest || bytes < smallest.bytes) {
+      smallest = result
+    }
+  }
+  // Everything was over budget (huge/complex thumbnail); return the smallest.
+  return smallest as RenderedCard
+}
diff --git a/packages/frontend/src/components/composer/linkPreview/styles.module.scss b/packages/frontend/src/components/composer/linkPreview/styles.module.scss
new file mode 100644
index 000000000..0d752a182
--- /dev/null
+++ b/packages/frontend/src/components/composer/linkPreview/styles.module.scss
@@ -0,0 +1,206 @@
+// Link-preview ghost / chip, shown in the composer's upper bar alongside the
+// quote and attachment sections. Uses theme variables so it blends in both
+// light and dark themes.
+
+.base {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  padding: 9px;
+  border-bottom: 1px solid
+    color-mix(in srgb, var(--messageQuotedText) 15%, transparent);
+}
+
+.ghost {
+  composes: base;
+  align-items: center;
+  gap: 8px;
+  margin: 5px;
+  padding: 5px;
+}
+
+// A skeleton of the compact card "Add" will bake: a light surface (fixed
+// colors, like the sent card, so it previews the real result on any theme) with
+// placeholder title lines, the real host, and a thumbnail box on the right. The
+// dashed border keeps the "this is a suggestion, not content yet" ghost read.
+// Card + its "click to fetch" hint, stacked; the action buttons sit beside it.
+.ghostLeft {
+  flex: 1 1 auto;
+  min-width: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 6px;
+}
+
+.ghostHint {
+  padding: 0 2px;
+  font-size: 12px;
+  color: color-mix(in srgb, var(--messageText) 60%, transparent);
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+}
+
+.ghostCard {
+  flex: 0 0 auto;
+  min-width: 0;
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  // Match the baked compact card: same surface, corner radius (renderCard
+  // RADIUS=14), inner padding and soft shadow — a dashed border is the only
+  // "this isn't real content yet" cue.
+  padding: 12px 14px;
+  border-radius: 14px;
+  background: #f4f6f9;
+  border: 1px dashed rgba(16, 26, 38, 0.2);
+  box-shadow: 0 2px 10px rgba(8, 14, 22, 0.1);
+}
+
+.ghostBody {
+  flex: 1 1 auto;
+  min-width: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 7px;
+}
+
+// Placeholder bars standing in for the card's title (taller/darker) and
+// description (thinner/lighter) rows.
+.skelLine {
+  width: 62%;
+  height: 11px;
+  border-radius: 4px;
+  background: rgba(16, 26, 38, 0.17);
+}
+
+.skelLineShort {
+  width: 90%;
+  height: 8px;
+  background: rgba(16, 26, 38, 0.1);
+}
+
+.ghostHost {
+  margin-top: 2px;
+  font-size: 12.5px;
+  font-weight: 650;
+  letter-spacing: 0.02em;
+  text-transform: uppercase;
+  color: #0e7f5b; // matches the sent card's host color
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+}
+
+.ghostThumb {
+  flex: 0 0 auto;
+  width: 60px;
+  height: 60px;
+  border-radius: 10px;
+  background: #dfe4ea; // matches the card's empty-image placeholder block
+}
+
+.ghostActions {
+  flex: 0 0 auto;
+  display: flex;
+  align-items: center;
+  gap: 4px;
+}
+
+.ready {
+  composes: base;
+  align-items: center;
+}
+
+// The baked card shown at a readable size — it already carries the title, host
+// and image, so it's the whole preview (no separate text). Bounded so the
+// composer bar stays reasonable; object-fit keeps the card's aspect on both
+// compact and hero.
+.preview {
+  flex: 0 1 auto;
+  min-width: 0;
+  max-width: 100%;
+  max-height: 220px;
+  object-fit: contain;
+  object-position: left center;
+  border-radius: 6px;
+}
+
+.readyControls {
+  flex: 0 0 auto;
+  margin-left: auto;
+  display: flex;
+  align-items: center;
+  gap: 4px;
+}
+
+// Like .iconButton but with a word next to the glyph so the size toggle reads.
+.labelButton {
+  flex: 0 0 auto;
+  border: none;
+  background: none;
+  cursor: pointer;
+  font-size: 13px;
+  line-height: 1;
+  padding: 6px 10px;
+  border-radius: 6px;
+  white-space: nowrap;
+  color: color-mix(in srgb, var(--messageText) 75%, transparent);
+
+  &:hover {
+    background: color-mix(in srgb, var(--messageText) 10%, transparent);
+  }
+  &:focus-visible {
+    outline: 2px solid var(--colorPrimary, #415e6b);
+    outline-offset: 1px;
+  }
+}
+
+.bar {
+  composes: base;
+  gap: 8px;
+}
+
+.barLabel {
+  font-size: 13px;
+  color: color-mix(in srgb, var(--messageText) 70%, transparent);
+}
+
+.linkIcon {
+  flex: 0 0 auto;
+  width: 18px;
+  height: 18px;
+  border-radius: 4px;
+  background: color-mix(in srgb, var(--colorPrimary, #415e6b) 22%, transparent);
+  position: relative;
+
+  &::after {
+    content: '';
+    position: absolute;
+    inset: 4px;
+    border: 2px solid var(--colorPrimary, #415e6b);
+    border-radius: 3px;
+    opacity: 0.85;
+  }
+}
+
+.addButton {
+  flex: 0 0 auto;
+  border: none;
+  border-radius: 6px;
+  padding: 6px 14px;
+  font-size: 13px;
+  font-weight: 600;
+  cursor: pointer;
+  color: #fff;
+  background: var(--colorPrimary, #415e6b);
+
+  &:hover {
+    filter: brightness(1.06);
+  }
+  &:focus-visible {
+    outline: 2px solid var(--colorPrimary, #415e6b);
+    outline-offset: 2px;
+  }
+}
+
diff --git a/packages/frontend/src/components/composer/linkPreview/useLinkPreview.ts b/packages/frontend/src/components/composer/linkPreview/useLinkPreview.ts
new file mode 100644
index 000000000..eb6d6c287
--- /dev/null
+++ b/packages/frontend/src/components/composer/linkPreview/useLinkPreview.ts
@@ -0,0 +1,330 @@
+// State machine behind the composer's link-preview ghost.
+//
+// Watches the draft text for a URL and, when there is one and no other file is
+// attached, offers to generate a sender-baked preview card. Generation is
+// explicit (the user taps "Add"); once attached, the card can be removed or
+// toggled between compact and hero without re-fetching.
+
+import { useCallback, useEffect, useMemo, useRef, useState } from 'react'
+import { T } from '@deltachat/jsonrpc-client'
+
+import { getLogger } from '@deltachat-desktop/shared/logger'
+import { runtime } from '@deltachat-desktop/runtime-interface'
+
+import { detectPreviewableUrl } from './detectUrl'
+import {
+  preparePreview,
+  stageCard,
+  UnfurlUnavailableError,
+  type PreparedPreview,
+  type StagedCard,
+} from './generate'
+import type { PreviewLayout } from './openGraph'
+
+const log = getLogger('renderer/composer/linkPreview')
+
+// Give up (and hide the spinner) if generation hasn't finished in this long —
+// the core's own fetch caps at 60s and the unfurl fetch has no timeout, so a
+// hung request would otherwise leave the loading state forever.
+const GENERATION_TIMEOUT_MS = 25_000
+
+export type LinkPreviewPhase =
+  | { kind: 'idle'; host: string } // ghost offering to add a preview
+  | { kind: 'loading' }
+  | {
+      kind: 'ready'
+      host: string
+      title: string
+      layout: PreviewLayout
+      /** `data:` URL of the baked card, shown as the preview in the chip. */
+      image: string
+    }
+  // The unfurl endpoint couldn't be reached: show a quiet "needs a bridge with
+  // unfurl enabled" hint instead of silently doing nothing.
+  | { kind: 'unavailable' }
+
+export type UseLinkPreview = {
+  /** Non-null when the ghost/card should be shown in the composer. */
+  phase: LinkPreviewPhase | null
+  /** True while a generated preview is the current draft attachment. */
+  isPreviewActive: boolean
+  onAdd: () => void
+  onRemove: () => void
+  onToggleLayout: () => void
+  onDismiss: () => void
+}
+
+type Params = {
+  accountId: number
+  chatId: number
+  text: string
+  /** The current draft's attached file path, if any. */
+  draftFile: string | null
+  addFileToDraft: (
+    file: string,
+    fileName: string | null,
+    viewType: T.Viewtype
+  ) => Promise<void>
+  removeFile: () => void
+  /** Disable the feature entirely (e.g. while editing an existing message). */
+  disabled?: boolean
+}
+
+const DETECT_DEBOUNCE_MS = 400
+
+export function useLinkPreview(params: Params): UseLinkPreview {
+  const { accountId, chatId, text, draftFile, addFileToDraft, removeFile } =
+    params
+
+  // Debounced URL detection so the ghost doesn't flicker while typing.
+  const [detected, setDetected] = useState(() => detectPreviewableUrl(text))
+  useEffect(() => {
+    const id = setTimeout(
+      () => setDetected(detectPreviewableUrl(text)),
+      DETECT_DEBOUNCE_MS
+    )
+    return () => clearTimeout(id)
+  }, [text])
+
+  const url = detected?.url ?? null
+  const host = detected?.host ?? ''
+
+  const [phase, setPhase] = useState<LinkPreviewPhase | null>(null)
+  const [isPreviewActive, setIsPreviewActive] = useState(false)
+  // Mirror of `isPreviewActive` that updates synchronously: our own
+  // `addFileToDraft` changes `draftFile` in the same tick we mark the preview
+  // active, and `userFilePresent` (read during render) must already see the
+  // flag flipped — otherwise the URL effect briefly treats our fresh preview
+  // as a user file and drops it.
+  const previewActiveRef = useRef(false)
+  const setPreviewActive = useCallback((active: boolean) => {
+    previewActiveRef.current = active
+    setIsPreviewActive(active)
+  }, [])
+
+  // The last URL the user dismissed (or that a preview was removed/failed for);
+  // the ghost stays hidden while that exact URL is in the composer. Reset once
+  // the composer has no URL (message sent, link deleted) so the same link in a
+  // new message offers the ghost again — the dismissal is per-message, not a
+  // permanent per-chat mute.
+  const dismissedRef = useRef<string | null>(null)
+  // Increments on every URL change / action to invalidate in-flight async work.
+  const tokenRef = useRef(0)
+  // Kept in memory so layout toggles re-render without re-fetching.
+  const preparedRef = useRef<PreparedPreview | null>(null)
+  const stagedPathRef = useRef<string | null>(null)
+
+  const clearStagedTemp = useCallback(() => {
+    if (stagedPathRef.current) {
+      runtime.removeTempFile(stagedPathRef.current).catch(() => {})
+      stagedPathRef.current = null
+    }
+  }, [])
+
+  // A file the user attached themselves — i.e. a draft file that is NOT our
+  // generated preview. Our own preview keeps `isPreviewActive` in lockstep with
+  // `draftFile`, so attaching/removing it never flips this; it changes only when
+  // the user attaches or removes their own file.
+  // `draftFile` is '' (not null) when empty, so test truthiness. Uses the ref,
+  // not the state, so our own attach (which flips the ref synchronously before
+  // changing `draftFile`) never reads as a user file.
+  const userFilePresent = !!draftFile && !previewActiveRef.current
+
+  // React to the detected URL changing (or disappearing), or to the user
+  // attaching/removing their own file. Keying on `userFilePresent` (not raw
+  // `draftFile`) is what lets this react to the user's files without our own
+  // attach re-triggering it and dropping the fresh preview.
+  useEffect(() => {
+    // Any change here invalidates in-flight generation and the memoized preview.
+    tokenRef.current++
+    clearStagedTemp()
+    preparedRef.current = null
+
+    // If our preview is attached when this runs, the reason is always a stale
+    // one (the URL changed or was removed — `userFilePresent` can't be true
+    // while a preview is active), so drop it.
+    if (previewActiveRef.current) {
+      removeFile()
+      setPreviewActive(false)
+    }
+
+    // No URL in the composer (sent, cleared, or link removed): forget any
+    // dismissal so the same link, typed again later, offers the ghost afresh.
+    if (!url) {
+      dismissedRef.current = null
+    }
+
+    if (
+      params.disabled ||
+      !url ||
+      userFilePresent ||
+      dismissedRef.current === url
+    ) {
+      setPhase(null)
+      return
+    }
+    setPhase({ kind: 'idle', host })
+    // `host` tracks `url`; `isPreviewActive` is read but deliberately not a dep
+    // (our own attach must not retrigger this effect and remove the preview).
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [url, params.disabled, userFilePresent])
+
+  const attach = useCallback(
+    async (
+      prepared: PreparedPreview,
+      layout: PreviewLayout,
+      token: number
+    ): Promise<StagedCard | null> => {
+      const staged = await stageCard(prepared, layout)
+      if (token !== tokenRef.current) {
+        runtime.removeTempFile(staged.path).catch(() => {})
+        return null
+      }
+      stagedPathRef.current = staged.path
+      // Mark ours BEFORE addFileToDraft changes draftFile, so the URL effect
+      // doesn't mistake the fresh attachment for a user file (see the ref).
+      setPreviewActive(true)
+      // Attach as 'File', not 'Image': core promotes an image File to Image on
+      // send *without* recompressing it (chat.rs check_or_recode_image early-
+      // returns for File). Sending as 'Image' recodes to JPEG once the PNG tops
+      // ~500 KB (or 130 KB on "worse" media quality), and JPEG has no alpha, so
+      // into_rgb8() turns the card's transparent rounded-corner/shadow margin
+      // black. 'File' keeps the PNG (with transparency) byte-for-byte.
+      await addFileToDraft(staged.path, staged.fileName, 'File')
+      // The core copied the file into its blob dir; the temp copy is disposable.
+      clearStagedTemp()
+      return staged
+    },
+    [addFileToDraft, clearStagedTemp, setPreviewActive]
+  )
+
+  const onAdd = useCallback(() => {
+    // Nothing to preview, or the user has their own file attached — never
+    // clobber that. (The ghost is already hidden in that case; guard anyway.)
+    if (!url || (!!draftFile && !isPreviewActive)) {
+      return
+    }
+    const token = ++tokenRef.current
+    setPhase({ kind: 'loading' })
+    // Bail out of a hung fetch so the spinner doesn't linger forever.
+    const timeout = setTimeout(() => {
+      if (token === tokenRef.current) {
+        tokenRef.current++ // cancel the in-flight continuation
+        setPhase(null)
+        dismissedRef.current = url
+        log.info('link preview generation timed out', url)
+      }
+    }, GENERATION_TIMEOUT_MS)
+    ;(async () => {
+      const prepared = await preparePreview(accountId, url)
+      if (token !== tokenRef.current) {
+        return
+      }
+      if (!prepared) {
+        // Nothing worth showing — quietly give up (no manual editor by design).
+        setPhase(null)
+        dismissedRef.current = url
+        return
+      }
+      preparedRef.current = prepared
+      const staged = await attach(prepared, prepared.initialLayout, token)
+      if (token !== tokenRef.current) {
+        return
+      }
+      if (!staged) {
+        setPhase(null)
+        return
+      }
+      // `attach` already flipped isPreviewActive on success.
+      setPhase({
+        kind: 'ready',
+        host: prepared.meta.host,
+        title: prepared.meta.title,
+        layout: prepared.initialLayout,
+        image: staged.dataUrl,
+      })
+    })()
+      .catch(err => {
+        log.warn('link preview generation failed', err)
+        if (token === tokenRef.current) {
+          // Endpoint unreachable → hint the user; any other failure (no preview
+          // for this page) just quietly clears.
+          setPhase(err instanceof UnfurlUnavailableError ? { kind: 'unavailable' } : null)
+          dismissedRef.current = url
+        }
+      })
+      .finally(() => clearTimeout(timeout))
+  }, [accountId, url, draftFile, isPreviewActive, attach])
+
+  const onRemove = useCallback(() => {
+    tokenRef.current++
+    clearStagedTemp()
+    if (previewActiveRef.current) {
+      removeFile()
+      setPreviewActive(false)
+    }
+    if (url) {
+      dismissedRef.current = url
+    }
+    setPhase(null)
+  }, [clearStagedTemp, removeFile, setPreviewActive, url])
+
+  const onDismiss = useCallback(() => {
+    if (url) {
+      dismissedRef.current = url
+    }
+    setPhase(null)
+  }, [url])
+
+  const onToggleLayout = useCallback(() => {
+    const prepared = preparedRef.current
+    if (!prepared || phase?.kind !== 'ready') {
+      return
+    }
+    const next: PreviewLayout = phase.layout === 'hero' ? 'compact' : 'hero'
+    const prevImage = phase.image
+    const token = ++tokenRef.current
+    setPhase({ kind: 'loading' })
+    ;(async () => {
+      const staged = await attach(prepared, next, token)
+      if (token !== tokenRef.current) {
+        return
+      }
+      setPhase(
+        staged
+          ? {
+              kind: 'ready',
+              host: prepared.meta.host,
+              title: prepared.meta.title,
+              layout: next,
+              image: staged.dataUrl,
+            }
+          : null
+      )
+      // `attach` already flipped isPreviewActive on success.
+    })().catch(err => {
+      log.warn('link preview re-render failed', err)
+      if (token === tokenRef.current) {
+        setPhase({
+          kind: 'ready',
+          host: prepared.meta.host,
+          title: prepared.meta.title,
+          layout: phase.layout,
+          image: prevImage,
+        })
+      }
+    })
+  }, [attach, phase])
+
+  // Clean up any staged temp file on unmount / chat switch.
+  useEffect(() => {
+    return () => {
+      clearStagedTemp()
+    }
+  }, [chatId, clearStagedTemp])
+
+  return useMemo(
+    () => ({ phase, isPreviewActive, onAdd, onRemove, onToggleLayout, onDismiss }),
+    [phase, isPreviewActive, onAdd, onRemove, onToggleLayout, onDismiss]
+  )
+}
