diff --git a/packages/frontend/src/utils/groupAdmin.ts b/packages/frontend/src/utils/groupAdmin.ts
new file mode 100644
index 000000000..345052320
--- /dev/null
+++ b/packages/frontend/src/utils/groupAdmin.ts
@@ -0,0 +1,40 @@
+import { C } from '@deltachat/jsonrpc-client'
+import type { T } from '@deltachat/jsonrpc-client'
+
+// slothfulchat admin groups (ported from ArcaneChat, core/0019):
+// `groupAdminId` and `createGroupWithAdmin` exist in the regenerated local
+// jsonrpc bindings; the published 2.53.0 package does not have them yet, so
+// widen locally to keep tsc green. At runtime `BackendRemote.rpc` is the
+// regenerated client (it comes from our web-app runtime).
+
+/** Contact ID of the group admin, or null for regular groups. */
+export function groupAdminId(chat: T.FullChat): number | null {
+  return (chat as { groupAdminId?: number | null }).groupAdminId ?? null
+}
+
+/**
+ * Whether we may manage this chat's members/name/avatar/timer:
+ * true for regular chats, and for admin groups only if we are the admin.
+ */
+export function selfMayManageGroup(chat: T.FullChat): boolean {
+  const admin = groupAdminId(chat)
+  return admin == null || admin === C.DC_CONTACT_ID_SELF
+}
+
+/** Whether this is an admin group and we are its admin. */
+export function selfIsAdminOfAdminGroup(chat: T.FullChat): boolean {
+  return groupAdminId(chat) === C.DC_CONTACT_ID_SELF
+}
+
+/** See `createGroupWithAdmin` in the regenerated bindings. */
+export function createGroupWithAdmin(
+  rpc: unknown,
+  accountId: number,
+  name: string
+): Promise<number> {
+  return (
+    rpc as {
+      createGroupWithAdmin(accountId: number, name: string): Promise<number>
+    }
+  ).createGroupWithAdmin(accountId, name)
+}
