+/**
+ * Visible custom controls that drive the LOCAL muted `<audio>` element.
+ * The existing mirroring (see `MediaPlayerMutexContext`) turns those local
+ * actions into actual sound on the global singleton.
+ */
+function CustomAudioControls({
+  audioRef,
+  tabIndex,
+}: {
+  audioRef: React.RefObject<HTMLAudioElement | null>
+  tabIndex?: number
+}) {
+  const tx = useTranslationFunction()
+  const ctx = useContext(MediaPlayerMutexContext)
+  const [paused, setPaused] = useState(true)
+  const [currentTime, setCurrentTime] = useState(0)
+  const [duration, setDuration] = useState(0)
+  // While the user drags the seek thumb, don't let `timeupdate` reassert the
+  // controlled value out from under the pointer.
+  const seekingRef = useRef(false)
+
+  // One dumb subscription mirroring the local element's state into React.
+  useEffect(() => {
+    const el = audioRef.current
+    if (el == null) {
+      return
+    }
+    const sync = () => {
+      setPaused(el.paused)
+      if (!seekingRef.current) {
+        setCurrentTime(el.currentTime)
+      }
+      setDuration(el.duration)
+    }
+    sync()
+    const events = ['timeupdate', 'durationchange', 'play', 'pause'] as const
+    events.forEach(ev => el.addEventListener(ev, sync))
+    return () => events.forEach(ev => el.removeEventListener(ev, sync))
+  }, [audioRef])
+
+  // Keep the local rate in sync with the global one so all bubbles agree
+  // (on mount and whenever the global rate changes). Setting it fires
+  // `ratechange`, which the mirror applies to the singleton only when this
+  // is the active src.
+  useEffect(() => {
+    const el = audioRef.current
+    if (el != null) {
+      el.playbackRate = ctx.playbackRate
+      // Loading a new `src` resets `playbackRate` to `defaultPlaybackRate`,
+      // so set both — same as setPlaybackRate does for the singleton.
+      el.defaultPlaybackRate = ctx.playbackRate
+    }
+  }, [audioRef, ctx.playbackRate])
+
+  const safeDuration = Number.isFinite(duration) ? duration : 0
+
+  return (
+    <div className={styles.customControls}>
+      <IconButton
+        icon={paused ? 'play' : 'pause'}
+        coloring='currentColor'
+        aria-label={paused ? tx('menu_play') : tx('menu_pause')}
+        tabIndex={tabIndex}
+        onClick={() => {
+          const el = audioRef.current
+          if (el == null) {
+            return
+          }
+          // A user click is the non-programmatic path: the mirror's
+          // ignore-refs are only set when the global element drives us.
+          if (el.paused) {
+            el.play()
+          } else {
+            el.pause()
+          }
+        }}
+      />
+      <input
+        type='range'
+        className={styles.seek}
+        min={0}
+        max={safeDuration}
+        step='any'
+        value={Math.min(currentTime, safeDuration)}
+        tabIndex={tabIndex}
+        aria-label={tx('a11y_audio_seek')}
+        aria-valuetext={`${formatAudioTime(
+          Math.min(currentTime, safeDuration)
+        )} / ${formatAudioTime(safeDuration)}`}
+        onPointerDown={() => {
+          seekingRef.current = true
+        }}
+        onPointerUp={() => {
+          seekingRef.current = false
+        }}
+        onChange={e => {
+          const v = Number(e.currentTarget.value)
+          // Update state too: with `sync()` suppressed during the drag, a
+          // skip-only fix would leave the controlled value stale and snap the
+          // thumb back on every pointermove.
+          setCurrentTime(v)
+          const el = audioRef.current
+          if (el != null) {
+            // ponytail: scrubbing a paused message before playing is not
+            // mirrored to the global element (same as the native controls
+            // today). A2's remembered-position work is the upgrade path.
+            el.currentTime = v
+          }
+        }}
+      />
+      <span className={styles.time}>
+        {formatAudioTime(currentTime)} / {formatAudioTime(safeDuration)}
+      </span>
+      <button
+        type='button'
+        className={styles.speedPill}
+        tabIndex={tabIndex}
+        aria-label={tx('a11y_playback_speed', `${ctx.playbackRate}×`)}
+        onClick={() => ctx.setPlaybackRate(nextPlaybackRate(ctx.playbackRate))}
+      >
+        {ctx.playbackRate}×
+      </button>
+    </div>
   )
 }
 
