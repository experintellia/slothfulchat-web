@@ -0,0 +1,35 @@
+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import {
+  formatAudioTime,
+  nextPlaybackRate,
+} from '../components/AudioPlayer/utils.js'
+
+describe('AudioPlayer / formatAudioTime', () => {
+  it('formats seconds as m:ss', () => {
+    expect(formatAudioTime(0)).to.equal('0:00')
+    expect(formatAudioTime(5)).to.equal('0:05')
+    expect(formatAudioTime(65)).to.equal('1:05')
+    expect(formatAudioTime(600)).to.equal('10:00')
+  })
+
+  it('guards NaN, Infinity and negatives as 0:00', () => {
+    expect(formatAudioTime(NaN)).to.equal('0:00')
+    expect(formatAudioTime(Infinity)).to.equal('0:00')
+    expect(formatAudioTime(-5)).to.equal('0:00')
+  })
+})
+
+describe('AudioPlayer / nextPlaybackRate', () => {
+  it('cycles 1 -> 1.5 -> 2 -> 1', () => {
+    expect(nextPlaybackRate(1)).to.equal(1.5)
+    expect(nextPlaybackRate(1.5)).to.equal(2)
+    expect(nextPlaybackRate(2)).to.equal(1)
+  })
+
+  it('falls back to 1 for an unknown rate', () => {
+    expect(nextPlaybackRate(1.25)).to.equal(1)
+    expect(nextPlaybackRate(0)).to.equal(1)
+  })
+})
