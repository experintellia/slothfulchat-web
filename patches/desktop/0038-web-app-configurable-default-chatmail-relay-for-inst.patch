+  // configured default for exactly these (non-account, non-login) cases.
+  const configuredHost =
+    isDefaultInstance &&
+    welcomeQr?.qr.kind !== 'account' &&
+    welcomeQr?.qr.kind !== 'login'
+      ? instanceDefaultChatmailHost()
+      : undefined
+
   return (
     <>
