@@ -38,9 +39,27 @@ export default function UserAgreement() {
   const { welcomeQr } = useInstantOnboarding()
   const isDefaultInstance = isQRWithDefaultInstance(welcomeQr)
 
+  // slothfulchat-web: when the operator configured their own default chatmail
+  // relay (SLOTHFUL_DEFAULT_CHATMAIL) and the account is actually created on
+  // it — i.e. the user didn't scan a specific account/login QR — the consent
