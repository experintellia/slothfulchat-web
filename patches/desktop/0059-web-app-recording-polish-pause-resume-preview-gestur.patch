diff --git a/packages/frontend/src/tests/audioRecorder.test.ts b/packages/frontend/src/tests/audioRecorder.test.ts
new file mode 100644
index 000000000..0e3368103
--- /dev/null
+++ b/packages/frontend/src/tests/audioRecorder.test.ts
@@ -0,0 +1,98 @@
+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import {
+  CANCEL_DX,
+  LOCK_DY,
+  TAP_MAX_MS,
+  classifyGesture,
+  originalAudioHonored,
+  timerElapsedMs,
+  timerPause,
+  timerResume,
+  timerStart,
+} from '../components/AudioRecorder/recorderLogic.js'
+
+describe('AudioRecorder / classifyGesture', () => {
+  it('a quick press with no slide is a tap', () => {
+    expect(classifyGesture(0, 0, 100)).to.equal('tap')
+    expect(classifyGesture(-5, -5, TAP_MAX_MS - 1)).to.equal('tap')
+  })
+
+  it('a held press with no slide is a hold-release', () => {
+    expect(classifyGesture(0, 0, TAP_MAX_MS)).to.equal('hold-release')
+    expect(classifyGesture(-10, -10, 1000)).to.equal('hold-release')
+  })
+
+  it('sliding left past the cancel threshold cancels', () => {
+    expect(classifyGesture(CANCEL_DX, 0, 1000)).to.equal('cancel')
+    expect(classifyGesture(CANCEL_DX - 20, 0, 50)).to.equal('cancel')
+  })
+
+  it('sliding up past the lock threshold locks', () => {
+    expect(classifyGesture(0, LOCK_DY, 1000)).to.equal('lock')
+    expect(classifyGesture(-10, LOCK_DY - 20, 50)).to.equal('lock')
+  })
+
+  it('just short of a threshold does NOT trigger it', () => {
+    expect(classifyGesture(CANCEL_DX + 1, 0, 1000)).to.equal('hold-release')
+    expect(classifyGesture(0, LOCK_DY + 1, 1000)).to.equal('hold-release')
+  })
+
+  it('cancel wins over lock on a diagonal down-left flick', () => {
+    // slid far left AND far up: destructive intent (cancel) takes precedence.
+    expect(classifyGesture(CANCEL_DX - 10, LOCK_DY - 10, 50)).to.equal('cancel')
+  })
+})
+
+describe('AudioRecorder / paused-time-excluding timer', () => {
+  it('counts only active wall-clock time across a pause', () => {
+    let s = timerStart(0)
+    expect(timerElapsedMs(s, 1000)).to.equal(1000)
+    s = timerPause(s, 2000) // banked 2000ms active
+    // time passes while paused — must not count
+    expect(timerElapsedMs(s, 5000)).to.equal(2000)
+    s = timerResume(s, 5000)
+    expect(timerElapsedMs(s, 6000)).to.equal(3000) // 2000 + 1000 more active
+  })
+
+  it('pause/resume are idempotent (no double-banking, no reset)', () => {
+    let s = timerStart(0)
+    s = timerPause(s, 1000)
+    s = timerPause(s, 9000) // second pause is a no-op
+    expect(timerElapsedMs(s, 9000)).to.equal(1000)
+    s = timerResume(s, 9000)
+    s = timerResume(s, 99999) // second resume is a no-op
+    expect(timerElapsedMs(s, 10000)).to.equal(2000)
+  })
+})
+
+describe('AudioRecorder / originalAudioHonored', () => {
+  it('null when the mic/browser reports none of the keys', () => {
+    expect(originalAudioHonored({ sampleRate: 48000 })).to.equal(null)
+    expect(originalAudioHonored({})).to.equal(null)
+  })
+
+  it('true only when every reported processing key is off', () => {
+    expect(
+      originalAudioHonored({
+        noiseSuppression: false,
+        echoCancellation: false,
+        autoGainControl: false,
+      })
+    ).to.equal(true)
+    // reported but a subset present, all off → still honored
+    expect(originalAudioHonored({ noiseSuppression: false })).to.equal(true)
+  })
+
+  it('false when any reported key is still on (request ignored)', () => {
+    expect(
+      originalAudioHonored({
+        noiseSuppression: true,
+        echoCancellation: false,
+        autoGainControl: false,
+      })
+    ).to.equal(false)
+    expect(originalAudioHonored({ noiseSuppression: true })).to.equal(false)
+  })
+})
