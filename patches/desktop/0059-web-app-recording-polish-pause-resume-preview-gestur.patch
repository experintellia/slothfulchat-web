diff --git a/packages/frontend/src/components/AudioRecorder/recorderLogic.ts b/packages/frontend/src/components/AudioRecorder/recorderLogic.ts
new file mode 100644
index 000000000..c2abd7403
--- /dev/null
+++ b/packages/frontend/src/components/AudioRecorder/recorderLogic.ts
@@ -0,0 +1,93 @@
+// Pure, browser-free logic for the experimental recorder polish (phase B):
+// press-and-hold gesture classification and a paused-time-excluding timer.
+// Kept import-free so it runs under mocha/node and is unit-testable.
+
+// --- press-and-hold gesture -------------------------------------------------
+
+// ponytail: fixed thresholds (device-pixel deltas), not calibrated per screen
+// DPI. Ceiling: on a very high-DPI touch panel 80px is a shorter physical
+// slide; upgrade path = scale by a measured px-per-mm if it feels off. Up is
+// negative dy, left is negative dx (pointer coordinate convention).
+export const CANCEL_DX = -80 // slid this far left → discard
+export const LOCK_DY = -60 // slid this far up → hands-free lock
+export const TAP_MAX_MS = 300 // released this fast with no slide → tap-to-toggle
+
+export type Gesture = 'cancel' | 'lock' | 'hold-release' | 'tap'
+
+/**
+ * Classify a completed (or in-progress) press-and-hold on the mic button.
+ * dx/dy are pointer deltas from the press origin (up = negative dy, left =
+ * negative dx); elapsedMs is how long the pointer was down.
+ *
+ * Cancel and lock win over the time test so a fast flick still cancels/locks.
+ * Cancel is checked before lock so a diagonal down-left flick discards rather
+ * than latching a recording the user was trying to throw away.
+ */
+export function classifyGesture(
+  dx: number,
+  dy: number,
+  elapsedMs: number
+): Gesture {
+  if (dx <= CANCEL_DX) {
+    return 'cancel'
+  }
+  if (dy <= LOCK_DY) {
+    return 'lock'
+  }
+  if (elapsedMs < TAP_MAX_MS) {
+    return 'tap'
+  }
+  return 'hold-release'
+}
+
+// --- paused-time-excluding timer -------------------------------------------
+
+// Wall-clock accumulator that only counts time while running. Pausing banks the
+// running segment; the display reads total banked + the current open segment.
+// More correct than skipping setInterval ticks (no ±1s slop at each pause
+// boundary), and trivially testable with an injected clock.
+export type TimerState = { accumulatedMs: number; runningSince: number | null }
+
+export function timerStart(now: number): TimerState {
+  return { accumulatedMs: 0, runningSince: now }
+}
+
+export function timerPause(s: TimerState, now: number): TimerState {
+  if (s.runningSince == null) {
+    return s // already paused → no-op (idempotent)
+  }
+  return {
+    accumulatedMs: s.accumulatedMs + (now - s.runningSince),
+    runningSince: null,
+  }
+}
+
+export function timerResume(s: TimerState, now: number): TimerState {
+  if (s.runningSince != null) {
+    return s // already running → no-op (idempotent)
+  }
+  return { accumulatedMs: s.accumulatedMs, runningSince: now }
+}
+
+export function timerElapsedMs(s: TimerState, now: number): number {
+  return s.accumulatedMs + (s.runningSince != null ? now - s.runningSince : 0)
+}
+
+// --- advisory getUserMedia constraints -------------------------------------
+
+/**
+ * Whether an "original audio" request was actually honored, read back from
+ * `track.getSettings()`. getSettings may omit these keys entirely (the mic /
+ * browser doesn't expose them) → null = "can't tell / unsupported". When
+ * present, honored only if every reported key is false (no processing applied).
+ */
+export function originalAudioHonored(
+  settings: Record<string, unknown>
+): boolean | null {
+  const keys = ['noiseSuppression', 'echoCancellation', 'autoGainControl']
+  const present = keys.filter(k => k in settings)
+  if (present.length === 0) {
+    return null
+  }
+  return present.every(k => settings[k] === false)
+}
