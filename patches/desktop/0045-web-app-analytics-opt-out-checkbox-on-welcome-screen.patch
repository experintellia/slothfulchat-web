+
+/**
+ * The anonymous-usage-statistics consent bridge installed by slothfulchat-web's
+ * runtime.ts as `window.__slothfulAnalyticsUi`. Stats are opt-out: `enabled()`
+ * reflects the current (localStorage-backed) choice, `setEnabled()` records a
+ * new one, `showInfo()` opens the runtime's info dialog explaining what is
+ * collected — its Opt out / Accept buttons record a choice too, so re-read
+ * `enabled()` once the returned promise resolves (dialog closed).
+ */
+export type AnalyticsUi = {
+  enabled: () => boolean
+  setEnabled: (on: boolean) => void
+  showInfo: () => Promise<void>
+}
+
+/**
+ * The analytics consent bridge, or `undefined` when this instance was built
+ * without analytics (every self-hosted build) or on upstream runtimes — so
+ * callers simply hide their checkbox.
+ */
+export function instanceAnalyticsUi(): AnalyticsUi | undefined {
+  const ui = (window as any).__slothfulAnalyticsUi
+  return ui?.configured ? ui : undefined
+}
