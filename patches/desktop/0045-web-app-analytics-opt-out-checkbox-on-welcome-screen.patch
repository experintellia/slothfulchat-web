+// slothfulchat: opt-out switch for the anonymous usage statistics. The consent
+// lives in the host page's localStorage (window.__slothfulAnalyticsUi, see
+// slothfulchat-web's runtime.ts), not in desktop settings, so this is a small
+// self-contained switch rather than a DesktopSettingsSwitch.
+function AnalyticsSwitch() {
+  const analyticsUi = instanceAnalyticsUi()
+  const [enabled, setEnabled] = useState(() => analyticsUi?.enabled() ?? false)
+
+  if (!analyticsUi) {
+    return null
+  }
+  return (
+    <>
+      <SettingsSwitch
+        label='Share anonymous usage statistics'
+        description='Anonymous, aggregated counts only — never message content, contacts, or free text.'
+        value={enabled}
+        onChange={next => {
+          analyticsUi.setEnabled(next)
+          setEnabled(next)
+        }}
+      />
+      <SettingsButton
+        onClick={() =>
+          runtime.openLink(new URL('privacy.html', document.baseURI).href)
+        }
+      >
+        {/* link-blue like settingsSelectorValue, so the row reads as a link */}
+        <span style={{ color: 'var(--colorPrimary)' }}>
+          {'Learn more in the privacy policy'}
+        </span>
+      </SettingsButton>
+    </>
+  )
+}
