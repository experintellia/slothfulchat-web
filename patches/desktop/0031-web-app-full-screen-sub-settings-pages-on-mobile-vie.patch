From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: slothfulchat <dev@slothfulchat.local>
Date: Fri, 10 Jul 2026 11:48:16 +0000
Subject: [PATCH 31/39] web-app: full-screen sub settings pages on mobile
 viewports

The big-dialogs-fullscreen patch made the settings root dialog go edge to
edge on phones, but every page it opens on top still rendered as a small
floating dialog: the four settings sections (chats & media, notifications,
appearance, advanced), the connectivity view and the profile editor. Opt
them all into fullscreenOnMobile so navigating through settings stays
full-screen. Deeper pickers and alerts (select dialogs, confirmations)
intentionally stay small popups.
---
 packages/frontend/src/components/Settings/Settings.tsx          | 2 +-
 packages/frontend/src/components/dialogs/ConnectivityDialog.tsx | 2 +-
 .../frontend/src/components/dialogs/EditProfileDialog/index.tsx | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/packages/frontend/src/components/Settings/Settings.tsx b/packages/frontend/src/components/Settings/Settings.tsx
index c3e736d6b..1abbb9d9d 100644
--- a/packages/frontend/src/components/Settings/Settings.tsx
+++ b/packages/frontend/src/components/Settings/Settings.tsx
@@ -152,7 +152,7 @@ function SettingsSectionDialog(
   } as const satisfies Partial<Parameters<typeof DialogHeader>[0]>
 
   return (
-    <Dialog onClose={closeThisDialog} fixed width={400}>
+    <Dialog onClose={closeThisDialog} fixed width={400} fullscreenOnMobile>
       {settingsMode === 'chats_and_media' && (
         <>
           <DialogHeader title={tx('pref_chats')} {...commonHeaderProps} />
diff --git a/packages/frontend/src/components/dialogs/ConnectivityDialog.tsx b/packages/frontend/src/components/dialogs/ConnectivityDialog.tsx
index 3ec99b6f5..7a6e51588 100644
--- a/packages/frontend/src/components/dialogs/ConnectivityDialog.tsx
+++ b/packages/frontend/src/components/dialogs/ConnectivityDialog.tsx
@@ -16,7 +16,7 @@ export default function ConnectivityDialog({ onClose }: DialogProps) {
   const tx = useTranslationFunction()
 
   return (
-    <Dialog onClose={onClose} canOutsideClickClose={true}>
+    <Dialog onClose={onClose} canOutsideClickClose={true} fullscreenOnMobile>
       <DialogHeader title={tx('connectivity')} onClose={onClose} />
       <ConnectivityDialogInner />
     </Dialog>
diff --git a/packages/frontend/src/components/dialogs/EditProfileDialog/index.tsx b/packages/frontend/src/components/dialogs/EditProfileDialog/index.tsx
index 9835fd5fb..b6f7e49dc 100644
--- a/packages/frontend/src/components/dialogs/EditProfileDialog/index.tsx
+++ b/packages/frontend/src/components/dialogs/EditProfileDialog/index.tsx
@@ -32,7 +32,7 @@ export default function EditProfileDialog({ onClose, ...props }: Props) {
   const tx = useTranslationFunction()
 
   return (
-    <Dialog canOutsideClickClose={false} onClose={onClose}>
+    <Dialog canOutsideClickClose={false} onClose={onClose} fullscreenOnMobile>
       <DialogHeader title={tx('pref_profile_info_headline')} />
       <EditProfileDialogInner onClose={onClose} {...props} />
     </Dialog>
