diff --git a/packages/frontend/src/components/dialogs/PublicBots/index.tsx b/packages/frontend/src/components/dialogs/PublicBots/index.tsx
new file mode 100644
index 000000000..657774e56
--- /dev/null
+++ b/packages/frontend/src/components/dialogs/PublicBots/index.tsx
@@ -0,0 +1,319 @@
+import React, { useCallback, useMemo, useState } from 'react'
+
+import Dialog, {
+  DialogBody,
+  DialogContent,
+  DialogFooter,
+  DialogHeader,
+  FooterActionButton,
+  FooterActions,
+} from '../../Dialog'
+import { Avatar } from '../../Avatar'
+import { ClickableNonMailtoLink } from '../../helpers/ClickableLink'
+import { BackendRemote } from '../../../backend-com'
+import { selectedAccountId } from '../../../ScreenController'
+import SettingsStoreInstance, {
+  useSettingsStore,
+} from '../../../stores/settings'
+import useProcessQR, { SCAN_CONTEXT_TYPE } from '../../../hooks/useProcessQr'
+import { useFetchGeneric } from '../../../hooks/useFetch'
+import useTranslationFunction from '../../../hooks/useTranslationFunction'
+import { unknownErrorToString } from '@deltachat-desktop/shared/unknownErrorToString'
+import { getLogger } from '@deltachat-desktop/shared/logger'
+
+import type { DialogProps } from '../../../contexts/DialogContext'
+
+import styles from './styles.module.scss'
+
+const log = getLogger('renderer/dialogs/PublicBots')
+
+export const PUBLIC_BOTS_REPO_URL =
+  'https://github.com/deltachat-bot/public-bots'
+export const PUBLIC_BOTS_ISSUES_URL =
+  'https://github.com/deltachat-bot/public-bots/issues'
+const PUBLIC_BOTS_DATA_URL =
+  'https://raw.githubusercontent.com/deltachat-bot/public-bots/main/frontend/data.json'
+
+type PublicBotsJson = {
+  bots: { description: string; lang: string; admin: string; url: string }[]
+  /** language code -> human readable name, e.g. `{ en: 'English' }` */
+  langs?: { [key: string]: string }
+}
+
+interface BotEntry {
+  name: string
+  addr: string
+  admin: string
+  lang: string
+  description: string
+  url: string
+  color: string
+}
+
+/**
+ * Stable avatar color per bot; the directory entries are not core
+ * contacts (yet), so no core-assigned color exists for them.
+ */
+function colorFromString(str: string): string {
+  let hash = 0
+  for (let i = 0; i < str.length; i++) {
+    hash = (hash * 31 + str.charCodeAt(i)) | 0
+  }
+  return `hsl(${((hash % 360) + 360) % 360}, 54%, 46%)`
+}
+
+function parseBotsJson(base64: string): {
+  bots: BotEntry[]
+  langs: { [key: string]: string }
+} {
+  const text = atob(base64)
+  const bytes = new Uint8Array(text.length)
+  for (let i = 0; i < text.length; i++) {
+    bytes[i] = text.charCodeAt(i)
+  }
+  const data = JSON.parse(
+    new TextDecoder().decode(bytes)
+  ) as null | PublicBotsJson
+  if (data == null || !Array.isArray(data.bots)) {
+    throw new Error(`unexpected data format from ${PUBLIC_BOTS_DATA_URL}`)
+  }
+  const bots = data.bots.map(bot => {
+    // The invite link carries the bot's name and address in its
+    // URL fragment, e.g. https://i.delta.chat/#FINGERPRINT&a=bot%40host&n=Bot
+    let name = ''
+    let addr = ''
+    try {
+      const params = new URLSearchParams(new URL(bot.url).hash.slice(1))
+      addr = params.get('a') ?? ''
+      name = params.get('n') ?? ''
+    } catch (error) {
+      log.warn('failed to parse bot invite link', bot.url, error)
+    }
+    if (name === '') {
+      name = addr !== '' ? addr : bot.admin
+    }
+    return { ...bot, name, addr, color: colorFromString(name + addr) }
+  })
+  return { bots, langs: data.langs ?? {} }
+}
+
+/**
+ * Browsable directory of community-made public bots, reachable from the
+ * "New Chat" dialog. The list is loaded from the third-party
+ * deltachat-bot/public-bots repository, so the first use asks for consent.
+ */
+export default function PublicBotsDialog(props: DialogProps) {
+  const { onClose } = props
+  const settingsStore = useSettingsStore()[0]
+  const consented =
+    settingsStore?.desktopSettings.publicBotsRemoteLoadConsent === true
+
+  return (
+    <Dialog
+      width={400}
+      onClose={onClose}
+      fixed
+      dataTestid='public-bots-dialog'
+      fullscreenOnMobile
+    >
+      {consented ? (
+        <PublicBotsList onClose={onClose} />
+      ) : (
+        <PublicBotsConsent onClose={onClose} />
+      )}
+    </Dialog>
+  )
+}
+
+function PublicBotsConsent({ onClose }: { onClose: () => void }) {
+  const tx = useTranslationFunction()
+
+  const accept = () => {
+    // Flipping the setting swaps this screen for the list right away
+    // (the dialog re-renders on the settings store update).
+    SettingsStoreInstance.effect.setDesktopSetting(
+      'publicBotsRemoteLoadConsent',
+      true
+    )
+  }
+
+  return (
+    <>
+      <DialogHeader title='Public Bots' onClose={onClose} />
+      <DialogBody>
+        <DialogContent>
+          <div className={styles.consentText}>
+            <p>
+              This is a <b>community-made</b> directory of public bots. The
+              bots are run by volunteers — they are <b>not</b> checked,
+              endorsed or operated by us, and we are not responsible for them
+              or their content. Talk to them at your own discretion.
+            </p>
+            <p>
+              The list is loaded from a third-party site:{' '}
+              <ClickableNonMailtoLink href={PUBLIC_BOTS_REPO_URL}>
+                github.com/deltachat-bot/public-bots
+              </ClickableNonMailtoLink>
+              . Continuing will fetch data from there.
+            </p>
+            <p>
+              If you have an issue with one of the bots, please complain
+              directly over there, in that project's{' '}
+              <ClickableNonMailtoLink href={PUBLIC_BOTS_ISSUES_URL}>
+                GitHub issues
+              </ClickableNonMailtoLink>
+              .
+            </p>
+          </div>
+        </DialogContent>
+      </DialogBody>
+      <DialogFooter>
+        <FooterActions align='spaceBetween'>
+          <FooterActionButton onClick={onClose}>
+            {tx('cancel')}
+          </FooterActionButton>
+          <FooterActionButton
+            styling='primary'
+            data-testid='public-bots-accept'
+            onClick={accept}
+          >
+            Accept &amp; Load
+          </FooterActionButton>
+        </FooterActions>
+      </DialogFooter>
+    </>
+  )
+}
+
+function PublicBotsList({ onClose }: { onClose: () => void }) {
+  const tx = useTranslationFunction()
+  const accountId = selectedAccountId()
+  const processQr = useProcessQR()
+  const [queryStr, setQueryStr] = useState('')
+
+  const fetchBots = useCallback(async () => {
+    // Through core's HTTP so this works the same on all runtimes
+    // (in the browser edition it ends up as a plain `fetch()`).
+    const response = await BackendRemote.rpc.getHttpResponse(
+      accountId,
+      PUBLIC_BOTS_DATA_URL
+    )
+    return parseBotsJson(response.blob)
+  }, [accountId])
+  const botsFetch = useFetchGeneric(fetchBots)
+
+  const fetched = botsFetch.result?.ok ? botsFetch.result.value : null
+
+  const filteredBots = useMemo(() => {
+    if (fetched == null) {
+      return null
+    }
+    const query = queryStr.trim().toLowerCase()
+    if (query === '') {
+      return fetched.bots
+    }
+    return fetched.bots.filter(bot =>
+      [
+        bot.name,
+        bot.admin,
+        bot.description,
+        bot.addr,
+        fetched.langs[bot.lang] ?? bot.lang,
+      ]
+        .join('\n')
+        .toLowerCase()
+        .includes(query)
+    )
+  }, [fetched, queryStr])
+
+  const onBotClick = (bot: BotEntry) => {
+    // Hand the invite link to the regular QR / invite-link machinery:
+    // it asks for confirmation and then sets up the chat.
+    processQr(accountId, bot.url, SCAN_CONTEXT_TYPE.DEFAULT)
+    onClose()
+  }
+
+  return (
+    <>
+      <DialogHeader onClose={onClose}>
+        <input
+          data-no-drag-region
+          className='search-input'
+          onChange={e => setQueryStr(e.target.value)}
+          value={queryStr}
+          placeholder={tx('search')}
+          aria-label={tx('search')}
+          autoFocus
+          spellCheck={false}
+        />
+      </DialogHeader>
+      <DialogBody className={styles.publicBotsBody}>
+        {botsFetch.loading ? (
+          <div className={styles.listStatus}>{tx('loading')}</div>
+        ) : botsFetch.result.ok !== true ? (
+          <div className={styles.listStatus}>
+            {tx(
+              'error_x',
+              `Failed to fetch the bot list\n(from ${PUBLIC_BOTS_DATA_URL})\n` +
+                unknownErrorToString(botsFetch.result.err)
+            )}
+          </div>
+        ) : filteredBots!.length === 0 ? (
+          <div className={styles.listStatus}>
+            {tx('search_no_result_for_x', queryStr)}
+          </div>
+        ) : (
+          <ol className={styles.botList}>
+            {filteredBots!.map(bot => (
+              <li key={bot.url}>
+                <button
+                  type='button'
+                  className={styles.botListItem}
+                  onClick={() => onBotClick(bot)}
+                >
+                  <Avatar
+                    displayName={bot.name}
+                    addr={bot.addr}
+                    color={bot.color}
+                    aria-hidden
+                  />
+                  <div className={styles.botInfo}>
+                    <div className={styles.botHeadline}>
+                      <span className={styles.botName}>{bot.name}</span>
+                      {bot.lang !== '' && (
+                        <span className={styles.botLang}>
+                          {fetched!.langs[bot.lang] ?? bot.lang}
+                        </span>
+                      )}
+                    </div>
+                    <div className={styles.botAdmin}>
+                      {bot.addr}
+                      {bot.admin !== '' && ` · by ${bot.admin}`}
+                    </div>
+                    <div className={styles.botDescription}>
+                      {bot.description}
+                    </div>
+                  </div>
+                </button>
+              </li>
+            ))}
+          </ol>
+        )}
+      </DialogBody>
+      <DialogFooter>
+        <div className={styles.footerNote}>
+          Community-made list, not endorsed by us — report problems with a bot
+          in the{' '}
+          <ClickableNonMailtoLink href={PUBLIC_BOTS_ISSUES_URL}>
+            GitHub issues
+          </ClickableNonMailtoLink>{' '}
+          of{' '}
+          <ClickableNonMailtoLink href={PUBLIC_BOTS_REPO_URL}>
+            deltachat-bot/public-bots
+          </ClickableNonMailtoLink>
+          .
+        </div>
+      </DialogFooter>
+    </>
+  )
+}
