diff --git a/packages/frontend/src/components/KeyboardShortcutHint.tsx b/packages/frontend/src/components/KeyboardShortcutHint.tsx
index 7da2c3720..5c5ea4269 100644
--- a/packages/frontend/src/components/KeyboardShortcutHint.tsx
+++ b/packages/frontend/src/components/KeyboardShortcutHint.tsx
@@ -202,6 +202,12 @@ export function getKeybindings(
         title: tx('force_refresh_network'),
         keyBindings: [['F5']],
       },
