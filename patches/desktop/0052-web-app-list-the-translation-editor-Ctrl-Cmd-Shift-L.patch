+        // SlothfulChat: the in-app translation editor (runtime.ts), available in
+        // every build. No catalogue string for this dev/translator tool.
+        title: 'Translation editor',
+        keyBindings: [[ctrl, 'Shift', 'L']],
+      },
     ].map(Shortcut),
     {
       title: tx('message_input_shortcut_section'),
