From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Tue, 14 Jul 2026 12:25:58 +0000
Subject: [PATCH 48/64] web-app: un-gate the call button + WhoCanCallMe setting
 for the browser runtime
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Calls now have a home (packages/calls) and a runtime bridge
(packages/web-app/src/runtime.ts), so the browser target should get the
same call-button entry point as electron. Message.tsx's CallIconButton
already has no target gate (it just disables itself while the runtime
hooks are stubbed), so no change is needed there.

M5 (docs/calls.md: "Settings: expose WhoCanCallMe"): the Notifications
settings page gated the who_can_call_me toggle the same way (electron
only) — un-gate it too, for the same reason and by the same one-line
target check, so the browser build can expose the privacy setting.
---
 packages/frontend/src/components/ChatView/ChatView.tsx   | 8 +++++---
 .../frontend/src/components/Settings/Notifications.tsx   | 9 ++++++---
 2 files changed, 11 insertions(+), 6 deletions(-)

diff --git a/packages/frontend/src/components/ChatView/ChatView.tsx b/packages/frontend/src/components/ChatView/ChatView.tsx
index 19fbda5..2e08871 100644
--- a/packages/frontend/src/components/ChatView/ChatView.tsx
+++ b/packages/frontend/src/components/ChatView/ChatView.tsx
@@ -321,9 +321,11 @@ function ChatNavButtons({
           <Icon coloring='navbar' icon='map' size={18} />
         </Button>
       )}
-      {/* Calls are only implemented on Electron; Tauri and Browser
-        runtimes do not implement `startOutgoingVideoCall`. */}
-      {runtime.getRuntimeInfo().target === 'electron' &&
+      {/* Calls are implemented on Electron and our Browser runtime (see
+        packages/calls + packages/web-app/src/runtime.ts); Tauri does not
+        implement `startOutgoingVideoCall`. */}
+      {(runtime.getRuntimeInfo().target === 'electron' ||
+        runtime.getRuntimeInfo().target === 'browser') &&
         chat.canSend &&
         chat.isEncrypted &&
         // Core only allows placing calls in chats of type "single"
diff --git a/packages/frontend/src/components/Settings/Notifications.tsx b/packages/frontend/src/components/Settings/Notifications.tsx
index ab90726..b29ea71 100644
--- a/packages/frontend/src/components/Settings/Notifications.tsx
+++ b/packages/frontend/src/components/Settings/Notifications.tsx
@@ -85,9 +85,12 @@ export default function Notifications({ desktopSettings }: Props) {
         disabled={isMuted || !desktopSettings['notifications']}
         disabledValue={false}
       />
-      {runtime.getRuntimeInfo().target === 'electron' && (
-        // Calls are only implemented on Electron.
-        // https://github.com/deltachat/deltachat-desktop/pull/6044#issuecomment-3977395069
+      {(runtime.getRuntimeInfo().target === 'electron' ||
+        runtime.getRuntimeInfo().target === 'browser') && (
+        // Calls are implemented on Electron and our Browser runtime (see
+        // packages/calls + packages/web-app/src/runtime.ts); Tauri does not
+        // implement startOutgoingVideoCall. This mirrors the ChatView.tsx
+        // call-button un-gate in this same patch.
         <SettingsSwitch
           label={tx('pref_calls')}
           description={tx('pref_calls_explain')}
