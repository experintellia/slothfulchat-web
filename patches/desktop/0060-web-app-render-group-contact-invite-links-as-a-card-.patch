+/**
+ * Like `window.getSelection()?.toString()`, but elements marked with
+ * `data-no-copy` (the visible words of invite-link cards, which carry the
+ * real URL in a visually-hidden sibling instead) are excluded — matching
+ * what native Ctrl+C produces for them via `user-select: none`, which
+ * `Selection.toString()` ignores in Chromium.
+ *
+ * Only selections living entirely inside a single message's text are
+ * rewritten: `textContent` of the cloned fragment has no CSS awareness, so
+ * on anything wider it would drop `toString()`'s block-boundary newlines
+ * and include CSS-hidden text (e.g. `.can-hide` author lines).
+ * ponytail: cross-message selections containing a card therefore keep the
+ * old visible-words copy; a `copy` event handler that serializes a rendered
+ * clone would cover that case if it ever matters.
+ */
+function getSelectedText(): string | undefined {
+  const selection = window.getSelection()
+  const plain = selection?.toString()
+  if (!selection || selection.rangeCount !== 1 || !plain) {
+    return plain
+  }
+  const range = selection.getRangeAt(0)
+  const ancestor =
+    range.commonAncestorContainer instanceof Element
+      ? range.commonAncestorContainer
+      : range.commonAncestorContainer.parentElement
+  if (!ancestor?.closest('.msg-body > .text')) {
+    return plain
+  }
+  const container = document.createElement('div')
+  container.append(range.cloneContents())
+  if (!container.querySelector('[data-no-copy]')) {
+    // no card in the selection — keep the exact toString() behavior
+    return plain
+  }
+  container.querySelectorAll('[data-no-copy]').forEach(el => el.remove())
+  return container.textContent ?? plain
+}
