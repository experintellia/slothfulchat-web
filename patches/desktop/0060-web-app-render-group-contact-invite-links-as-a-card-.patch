+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import { parseInviteLink } from '../utils/inviteLink.js'
+
+const FPR = '77E64B2C8CBB4B01827B3A5D9B7888DAE9AE0C34'
+
+describe('parseInviteLink', () => {
+  it('parses a group invite with percent-encoded name', () => {
+    expect(
+      parseInviteLink(
+        `https://i.delta.chat/#${FPR}&a=alice%40example.org&g=Tuesday%20Climbing%20Crew&x=abc123&i=xyz&s=def`
+      )
+    ).to.deep.equal({ kind: 'group', name: 'Tuesday Climbing Crew' })
+  })
+
+  it('decodes + as space and trailing _ as ellipsis (core decode_name)', () => {
+    expect(
+      parseInviteLink(
+        `https://i.delta.chat/#${FPR}&a=a%40b.org&g=Very+Long+Name_&x=g&i=i&s=s`
+      )
+    ).to.deep.equal({ kind: 'group', name: 'Very Long Name…' })
+  })
+
+  it('parses a channel invite (b=)', () => {
+    expect(
+      parseInviteLink(
+        `https://i.delta.chat/#${FPR}&a=a%40b.org&b=News&x=g&i=i&s=s`
+      )
+    ).to.deep.equal({ kind: 'channel', name: 'News' })
+  })
+
+  it('parses a contact invite, falling back to addr without n=', () => {
+    expect(
+      parseInviteLink(
+        `https://i.delta.chat/#${FPR}&a=alice%40b.org&n=Alice&i=i&s=s`
+      )
+    ).to.deep.equal({ kind: 'contact', name: 'Alice' })
+    expect(
+      parseInviteLink(`https://i.delta.chat/#${FPR}&a=alice%40b.org&i=i&s=s`)
+    ).to.deep.equal({ kind: 'contact', name: 'alice@b.org' })
+  })
+
+  it('returns null for junk, non-invite URLs and broken encoding', () => {
+    expect(parseInviteLink('https://example.org/#a=x&g=y')).to.equal(null)
+    expect(parseInviteLink('https://i.delta.chat/#brokenpayload')).to.equal(
+      null
+    )
+    expect(
+      parseInviteLink(
+        `https://i.delta.chat/#${FPR}&a=a%40b.org&g=%E0%A4%A&x=x&i=i&s=s`
+      )
+    ).to.equal(null)
+  })
+
+  it('gates like core check_qr: fingerprint, a=, s=, and x= for groups', () => {
+    // g= without x= (grpid) is a contact invite to core — no group card
+    expect(
+      parseInviteLink(
+        `https://i.delta.chat/#${FPR}&a=bob%40x.org&n=Bob&i=i&s=s&g=Delta+Chat+Team`
+      )
+    ).to.equal(null)
+    // no authcode s= — core would not offer to join anything
+    expect(
+      parseInviteLink(`https://i.delta.chat/#${FPR}&a=a%40b.org&g=Crew&x=x&i=i`)
+    ).to.equal(null)
+    // first fragment segment must be a hex fingerprint
+    expect(
+      parseInviteLink(
+        'https://i.delta.chat/#nothexatall&a=a%40b.org&g=Crew&x=x&i=i&s=s'
+      )
+    ).to.equal(null)
+    // v3 links have s= but no i= — still valid
+    expect(
+      parseInviteLink(`https://i.delta.chat/#${FPR}&a=a%40b.org&g=Crew&x=x&s=s`)
+    ).to.deep.equal({ kind: 'group', name: 'Crew' })
+  })
+
+  it('strips bidi overrides and control chars from names', () => {
+    expect(
+      parseInviteLink(
+        `https://i.delta.chat/#${FPR}&a=a%40b.org&g=evil%E2%80%AEcrew%0Aline&x=x&i=i&s=s`
+      )
+    ).to.deep.equal({ kind: 'group', name: 'evilcrewline' })
+  })
+})
diff --git a/packages/frontend/src/utils/colorFromString.ts b/packages/frontend/src/utils/colorFromString.ts
new file mode 100644
index 0000000..206199c
--- /dev/null
+++ b/packages/frontend/src/utils/colorFromString.ts
@@ -0,0 +1,12 @@
+/**
+ * Stable avatar color for things that are not core contacts (so no
+ * core-assigned color exists): public-bot directory entries, names parsed
+ * out of invite links, etc.
+ */
+export function colorFromString(str: string): string {
+  let hash = 0
+  for (let i = 0; i < str.length; i++) {
+    hash = (hash * 31 + str.charCodeAt(i)) | 0
+  }
+  return `hsl(${((hash % 360) + 360) % 360}, 54%, 46%)`
+}
diff --git a/packages/frontend/src/utils/inviteLink.ts b/packages/frontend/src/utils/inviteLink.ts
new file mode 100644
index 0000000..ea08e1d
--- /dev/null
+++ b/packages/frontend/src/utils/inviteLink.ts
@@ -0,0 +1,75 @@
+import { isInviteLink } from '@deltachat-desktop/shared/util.js'
+
+export type InviteLinkInfo = {
+  kind: 'group' | 'channel' | 'contact'
+  /** Display name straight from the link — sender-controlled, cosmetic only. */
+  name: string
+}
+
+/** Mirrors core's qr.rs decode_name: `+` means space, a trailing `_` marks a
+ * name that was truncated when the link was generated (shown as `…`). */
+function decodeName(value: string): string | null {
+  let name: string
+  try {
+    name = decodeURIComponent(value.replace(/\+/g, '%20'))
+  } catch {
+    return null
+  }
+  // strip control chars and bidi/zero-width overrides so a crafted name
+  // can't reorder or invisibly pad the card's text
+  name = name.replace(
+    // eslint-disable-next-line no-control-regex
+    /[\u0000-\u001f\u007f\u200b-\u200f\u202a-\u202e\u2066-\u2069]/g,
+    ''
+  )
+  return name.endsWith('_') ? name.slice(0, -1) + '…' : name
+}
+
+/**
+ * Extract what an `https://i.delta.chat/#…` invite link is for, from the link
+ * alone — the fragment carries the names (`g=` group, `b=` channel,
+ * `n=`/`a=` contact). Deliberately NOT core's checkQr, which would create a
+ * hidden contact as a side effect just for rendering a message.
+ * Returns null when the fragment is unreadable; callers then render the
+ * plain link and clicking still goes through the usual checkQr flow.
+ */
+export function parseInviteLink(url: string): InviteLinkInfo | null {
+  if (!isInviteLink(url)) {
+    return null
+  }
+  const fragment = url.slice(url.indexOf('#') + 1)
+  const [fingerprint = '', ...rest] = fragment.split('&')
+  const params = new Map<string, string>()
+  for (const part of rest) {
+    const eq = part.indexOf('=')
+    if (eq > 0) {
+      params.set(part.slice(0, eq), part.slice(eq + 1))
+    }
+  }
+  // Gate like core's check_qr, so the card never labels a payload
+  // differently than the dialog that opens on click: a securejoin link
+  // starts with a hex fingerprint and carries the address plus the
+  // authcode (the invitenumber i=/j= is optional since securejoin v3),
+  // and group/channel invites also carry the grpid (x=).
+  if (
+    !/^[0-9A-Fa-f]{40,}$/.test(fingerprint) ||
+    params.get('a') === undefined ||
+    params.get('s') === undefined
+  ) {
+    return null
+  }
+  const group = params.get('g')
+  if (group !== undefined) {
+    const name = params.get('x') !== undefined ? decodeName(group) : null
+    return name ? { kind: 'group', name } : null
+  }
+  const channel = params.get('b')
+  if (channel !== undefined) {
+    const name = params.get('x') !== undefined ? decodeName(channel) : null
+    return name ? { kind: 'channel', name } : null
+  }
+  const contactName = params.get('n')
+  const name =
+    (contactName && decodeName(contactName)) || decodeName(params.get('a')!)
+  return name ? { kind: 'contact', name } : null
+}
