+// --- Experimental estimated time-to-read on the unread badge ---
+
+/** Cap on how many trailing messages are fetched for one estimate. */
+const READ_TIME_FETCH_CAP = 100
+const readTimeCache = new Map<
+  string,
+  { counter: number; label: Promise<string | null> }
+>()
+
+function unreadReadTime(
+  accountId: number,
+  chatId: number,
+  counter: number
+): Promise<string | null> {
+  const key = `${accountId}:${chatId}`
+  const cached = readTimeCache.get(key)
+  // the unread set changed <=> the counter changed, so this invalidates itself
+  if (cached && cached.counter === counter) return cached.label
+  const label = (async () => {
+    // ponytail: fetches the chat's full id list (cheap u32s, in-browser rpc);
+    // if it ever hurts, ask core for a windowed/fresh-only id query instead.
+    const ids = await BackendRemote.rpc.getMessageIds(
+      accountId,
+      chatId,
+      false,
+      false
+    )
+    // the unread messages are among the newest ones; fetch a padded window of
+    // trailing messages and scale up if the window didn't reach all of them
+    const window = ids.slice(-Math.min(counter + 20, READ_TIME_FETCH_CAP))
+    const messages = await BackendRemote.rpc.getMessages(accountId, window)
+    const fresh = Object.values(messages).filter(
+      m => m.kind === 'message' && m.state === C.DC_STATE_IN_FRESH
+    ) as Type.Message[]
+    return readTimeLabel(unreadSeconds(fresh), fresh.length, counter)
+  })()
+  label.catch(() => readTimeCache.delete(key))
+  readTimeCache.set(key, { counter, label })
+  return label
+}
+
+function useUnreadReadTime(chatId: number, counter: number): string | null {
+  const enabled =
+    useSettingsStore()[0]?.desktopSettings.experimentalUnreadReadTime === true
+  const [label, setLabel] = useState<string | null>(null)
+  useEffect(() => {
+    if (!enabled || counter === 0) {
+      setLabel(null)
+      return
+    }
+    let stale = false
+    unreadReadTime(selectedAccountId(), chatId, counter)
+      .then(l => {
+        if (!stale) setLabel(l)
+      })
+      .catch(() => {})
+    return () => {
+      stale = true
+    }
+  }, [enabled, chatId, counter])
+  return label
+}
