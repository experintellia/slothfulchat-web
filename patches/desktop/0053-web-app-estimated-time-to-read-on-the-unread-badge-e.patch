@@ -0,0 +1,51 @@
+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import {
+  unreadSeconds,
+  readTimeLabel,
+  MEDIA_SECONDS,
+} from '../components/chat/readTimeEstimate.js'
+
+const text = (words: number) => ({
+  text: Array(words).fill('word').join(' '),
+  viewType: 'Text',
+  duration: 0,
+})
+
+describe('unread read-time estimate', () => {
+  it('counts words at 200 wpm', () => {
+    expect(unreadSeconds([text(200)])).to.equal(60)
+    expect(unreadSeconds([text(100), text(100)])).to.equal(60)
+    expect(unreadSeconds([])).to.equal(0)
+  })
+
+  it('voice/audio uses its duration, other media a constant', () => {
+    expect(
+      unreadSeconds([{ text: null, viewType: 'Voice', duration: 42000 }])
+    ).to.equal(42)
+    expect(
+      unreadSeconds([{ text: null, viewType: 'Voice', duration: 0 }])
+    ).to.equal(MEDIA_SECONDS)
+    expect(
+      unreadSeconds([{ text: null, viewType: 'Image', duration: 0 }])
+    ).to.equal(MEDIA_SECONDS)
+  })
+
+  it('a captioned media message counts both text and media', () => {
+    expect(unreadSeconds([{ ...text(200), viewType: 'Image' }])).to.equal(
+      60 + MEDIA_SECONDS
+    )
+  })
+
+  it('labels round to at least ~1 min and cap at 10+', () => {
+    expect(readTimeLabel(5, 1, 1)).to.equal('~1 min')
+    expect(readTimeLabel(250, 1, 1)).to.equal('~4 min')
+    expect(readTimeLabel(3600, 1, 1)).to.equal('10+ min')
+  })
+
+  it('scales a sampled estimate to the full unread count', () => {
+    expect(readTimeLabel(120, 2, 4)).to.equal('~4 min')
+    expect(readTimeLabel(0, 0, 5)).to.equal(null)
+  })
+})
