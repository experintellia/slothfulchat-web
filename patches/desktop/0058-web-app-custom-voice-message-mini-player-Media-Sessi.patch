+    // must coerce to {} so no accessor throws (and the store self-heals).
+    for (const raw of ['null', '5', '[1,2]']) {
+      const s = makePositionStore({ getItem: () => raw, setItem: () => {} })
+      expect(s.getPosition('a')).to.equal(null)
+      expect(() => s.setPosition('a', 3)).to.not.throw()
+      expect(() => s.clearPosition('a')).to.not.throw()
+    }
+  })
+})
+
+describe('GlobalVoiceMessagePlayer / mediaSessionMetadata', () => {
+  const details = {
+    senderName: 'Alice',
+    chatName: 'Team',
+    avatarUrl: 'blob:abc',
+  }
+
+  it('suppressed: generic title, no artist/artwork (privacy default)', () => {
+    const m = mediaSessionMetadata(true, 'Voice Message', details)
+    expect(m.title).to.equal('Voice Message')
+    expect(m.artist).to.equal('')
+    expect(m.artwork).to.deep.equal([])
+  })
+
+  it('detailed: sender as title, chat as artist, avatar as artwork', () => {
+    const m = mediaSessionMetadata(false, 'Voice Message', details)
+    expect(m.title).to.equal('Alice')
+    expect(m.artist).to.equal('Team')
+    expect(m.artwork).to.deep.equal([{ src: 'blob:abc' }])
+  })
+
+  it('detailed with no avatar: empty artwork (guarded)', () => {
+    const m = mediaSessionMetadata(false, 'Voice Message', {
+      senderName: 'Alice',
+      chatName: 'Team',
+    })
+    expect(m.artwork).to.deep.equal([])
+  })
+
+  it('detailed but details unavailable: falls back to generic title', () => {
+    const m = mediaSessionMetadata(false, 'Voice Message', {
+      senderName: '',
+      chatName: '',
+    })
+    expect(m.title).to.equal('Voice Message')
+    expect(m.artwork).to.deep.equal([])
+  })
+})
+
+describe('GlobalVoiceMessagePlayer / clampSeek', () => {
+  it('seeks within bounds', () => {
+    expect(clampSeek(10, 10, 60)).to.equal(20)
+    expect(clampSeek(30, -10, 60)).to.equal(20)
+  })
+
+  it('clamps to [0, duration]', () => {
+    expect(clampSeek(5, -10, 60)).to.equal(0)
+    expect(clampSeek(55, 10, 60)).to.equal(60)
+  })
+
+  it('non-finite duration only clamps the lower bound', () => {
+    expect(clampSeek(5, 10, Infinity)).to.equal(15)
+    expect(clampSeek(5, -10, Infinity)).to.equal(0)
+  })
 })
