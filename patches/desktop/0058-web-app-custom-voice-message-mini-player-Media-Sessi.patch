@@ -0,0 +1,50 @@
+// Pure helpers for wiring `navigator.mediaSession` from the voice-message
+// mini-player. Kept free of browser/React APIs so they're unit-testable; the
+// hook in GlobalVoiceMessagePlayer.tsx turns these into MediaMetadata /
+// setPositionState / action-handler calls.
+
+export type MediaSessionDetails = {
+  senderName: string
+  chatName: string
+  /** Sender avatar URL (blob: works), or undefined when there is none. */
+  avatarUrl?: string
+}
+
+/**
+ * The metadata to publish to the OS media session.
+ *
+ * `suppressed` (the default) hides who/what is playing — only a generic
+ * localized "Voice message" title, no artist, no artwork — because on some
+ * systems the media session shows on the lock screen (forum 5423). When the
+ * user opts in, the sender/chat/avatar are exposed.
+ */
+export function mediaSessionMetadata(
+  suppressed: boolean,
+  voiceMessageLabel: string,
+  details: MediaSessionDetails
+): { title: string; artist: string; artwork: { src: string }[] } {
+  if (suppressed) {
+    return { title: voiceMessageLabel, artist: '', artwork: [] }
+  }
+  return {
+    title: details.senderName || voiceMessageLabel,
+    artist: details.chatName,
+    artwork: details.avatarUrl ? [{ src: details.avatarUrl }] : [],
+  }
+}
+
+/**
+ * New playback position after seeking `delta` seconds from `t`, clamped to
+ * `[0, duration]`. A non-finite `duration` (stream / not-yet-known) only
+ * clamps the lower bound.
+ */
+export function clampSeek(t: number, delta: number, duration: number): number {
+  const next = t + delta
+  if (next < 0) {
+    return 0
+  }
+  if (Number.isFinite(duration) && next > duration) {
+    return duration
+  }
+  return next
+}
