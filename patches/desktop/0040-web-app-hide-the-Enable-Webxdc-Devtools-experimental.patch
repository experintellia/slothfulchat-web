From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: experintellia <280144245+experintellia@users.noreply.github.com>
Date: Fri, 10 Jul 2026 22:14:39 +0000
Subject: [PATCH 40/47] web-app: hide the 'Enable Webxdc Devtools' experimental
 setting

The devtools toggle only gates Electron's DevTools on a webxdc app's
iframe; there is no equivalent in a browser, where the built-in developer
tools can't be disabled by the app anyway. Webxdc apps don't run in this
build yet either, so the switch is inert. Hide it like the other upstream
settings that can't work here (proxy, second-device backup transfer).
---
 .../src/components/Settings/ExperimentalFeatures.tsx | 12 ------------
 1 file changed, 12 deletions(-)

diff --git a/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx b/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
index 185e50b3c..b4ed923b9 100644
--- a/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
+++ b/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
@@ -90,18 +90,6 @@ export function ExperimentalFeatures() {
       >
         {tx('webxdc_store_url')}
       </SettingsSelector>
-      <DesktopSettingsSwitch
-        settingsKey='enableWebxdcDevTools'
-        label='Enable Webxdc Devtools'
-        // See https://delta.chat/en/2023-05-22-webxdc-security,
-        // "XDC-01-004 WP1: Data exfiltration via desktop app DevTools"
-        //
-        // Although thanks to another hardening measure this shouldn't be
-        // easy to pull off. Namely, direct internet access is sort of
-        // disabled for the Electron part of the app:
-        // 853b584251a5dacf60ebc616f7fb10edffb5c5e5/src/main/index.ts#L12-L21
-        description='Careful: opening developer tools on a malicious webxdc app could lead to the app getting access to the Internet'
-      />
     </>
   )
 }
