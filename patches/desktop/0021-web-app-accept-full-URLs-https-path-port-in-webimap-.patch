-      .replace(/\/+$/, '')
-    if (trimmed === '') {
+    const parsedHost = parseWebimapHost(host)
+    if (parsedHost === '') {
       setError('This does not look like a valid server address.')
       return
     }
 
-    const url = `webimapaccount:${trimmed}`
+    const url = `webimapaccount:${parsedHost}`
