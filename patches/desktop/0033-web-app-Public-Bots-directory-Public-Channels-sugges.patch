+/**
+ * Instance-level config baked in by slothfulchat-web builds as
+ * `window.__slothfulConfig` (see packages/web-app/instance-config.mjs in the
+ * slothfulchat-web repo). Absent on upstream Electron/Tauri runtimes.
+ */
+
+/**
+ * `SLOTHFUL_HIDE_PUBLIC_SUGGESTIONS`: the operator hid the community
+ * suggestions ("Public Bots", "Public Channels") for the whole instance —
+ * the New Chat entries, both dialogs, and their settings toggles.
+ */
+export function instanceHidesPublicSuggestions(): boolean {
+  return (window as any).__slothfulConfig?.hidePublicSuggestions === true
+}
