diff --git a/packages/frontend/src/components/message/DownloadOnDemandPlaceholder.tsx b/packages/frontend/src/components/message/DownloadOnDemandPlaceholder.tsx
new file mode 100644
index 0000000..7eba074
--- /dev/null
+++ b/packages/frontend/src/components/message/DownloadOnDemandPlaceholder.tsx
@@ -0,0 +1,201 @@
+import React from 'react'
+import { filesize } from 'filesize'
+import { T } from '@deltachat/jsonrpc-client'
+
+import { runtime } from '@deltachat-desktop/runtime-interface'
+import { BackendRemote } from '../../backend-com'
+import { getExtension, isImage } from '../attachment/Attachment'
+import { formatDuration } from '../dialogs/MessageDetail/BasicMessageInfo'
+import useTranslationFunction from '../../hooks/useTranslationFunction'
+
+/**
+ * The type the message will have *after* it is downloaded. It's a fork-only
+ * field on the pre-message placeholder that upstream's generated jsonrpc
+ * bindings don't declare yet (core regenerates them later in the build), so we
+ * read it through this one typed accessor.
+ *
+ * ponytail: single typed cast lives here instead of scattering `as any` at call
+ * sites; drop the cast once the regenerated bindings carry `postMessageViewType`.
+ */
+export function getPostMessageViewType(message: T.Message): T.Viewtype | null {
+  return (
+    (message as { postMessageViewType?: T.Viewtype | null })
+      .postMessageViewType ?? null
+  )
+}
+
+// Core appends " [Label – 123 KiB]" to the placeholder text (message.rs:645-674,
+// bracketed, with an en-dash before the size). Strip that trailing tag so our
+// own UI shows the size instead of duplicating it in the caption.
+//
+// ponytail: regex on the bracket/en-dash shape; upgrade path = a core field
+// carrying the raw caption without the appended tag.
+const DOWNLOAD_TAG_RE = /\s*\[[^\]]*–[^\]]*\]\s*$/
+
+export function placeholderCaption(text: string | null): string {
+  return (text ?? '').replace(DOWNLOAD_TAG_RE, '').trim()
+}
+
+type PlaceholderProps = {
+  message: T.Message
+  postMessageViewType: T.Viewtype
+  accountId: number
+  tabindexForInteractiveContents: -1 | 0
+}
+
+function DownloadControls({
+  message,
+  accountId,
+  tabindexForInteractiveContents,
+}: Omit<PlaceholderProps, 'postMessageViewType'>) {
+  const tx = useTranslationFunction()
+  const { downloadState } = message
+  return (
+    <div className='download-on-demand-controls'>
+      {downloadState === 'Failure' && (
+        <span className='failed'>{tx('download_failed')}</span>
+      )}
+      {downloadState === 'InProgress' ? (
+        <button
+          type='button'
+          className='download-button'
+          disabled
+          tabIndex={tabindexForInteractiveContents}
+        >
+          {tx('downloading')}
+        </button>
+      ) : (
+        <button
+          type='button'
+          className='download-button'
+          onClick={() =>
+            BackendRemote.rpc.downloadFullMessage(accountId, message.id)
+          }
+          tabIndex={tabindexForInteractiveContents}
+        >
+          {tx('download')}
+        </button>
+      )}
+      <span className='size'>{filesize(message.fileBytes ?? 0)}</span>
+    </div>
+  )
+}
+
+/**
+ * Styled placeholder shown for a download-on-demand pre-message while
+ * `downloadState !== 'Done'`. It mirrors the "Done"-path markup/classes from
+ * `messageAttachment.tsx` (`.message-attachment-media`, `-audio`, `-generic`,
+ * `.webxdc`) but swaps the real attachment for a blurred thumbnail (or a grey
+ * box) plus a prominent download button and the target file size.
+ */
+export default function DownloadOnDemandPlaceholder({
+  message,
+  postMessageViewType,
+  accountId,
+  tabindexForInteractiveContents,
+}: PlaceholderProps) {
+  const controls = (
+    <DownloadControls
+      message={message}
+      accountId={accountId}
+      tabindexForInteractiveContents={tabindexForInteractiveContents}
+    />
+  )
+
+  const viewType = postMessageViewType
+
+  // Image / Gif / Sticker: blurred thumbnail (or grey box) with centered overlay.
+  if (isImage(viewType) || viewType === 'Sticker') {
+    return (
+      <div className='message-attachment-media download-on-demand'>
+        {message.file ? (
+          <img
+            className='attachment-content'
+            src={runtime.transformBlobURL(message.file)}
+            alt=''
+          />
+        ) : (
+          <div className='download-on-demand-empty' />
+        )}
+        <div className='download-on-demand-overlay'>{controls}</div>
+      </div>
+    )
+  }
+
+  // Video: same media box, black background, play glyph behind the overlay.
+  if (viewType === 'Video') {
+    return (
+      <div className='message-attachment-media video download-on-demand'>
+        {message.file ? (
+          <img
+            className='attachment-content'
+            src={runtime.transformBlobURL(message.file)}
+            alt=''
+          />
+        ) : (
+          <div className='download-on-demand-empty' />
+        )}
+        <div className='play-glyph' aria-hidden='true' />
+        <div className='download-on-demand-overlay'>
+          {message.duration > 0 && (
+            <span className='duration'>{formatDuration(message.duration)}</span>
+          )}
+          {controls}
+        </div>
+      </div>
+    )
+  }
+
+  // Audio / Voice: an icon-less row with name, optional duration, and controls.
+  if (viewType === 'Audio' || viewType === 'Voice') {
+    return (
+      <div className='message-attachment-audio download-on-demand'>
+        <div className='text-part'>
+          <div className='name'>{message.fileName}</div>
+          {message.duration > 0 && (
+            <div className='duration'>{formatDuration(message.duration)}</div>
+          )}
+        </div>
+        {controls}
+      </div>
+    )
+  }
+
+  // Webxdc: the app card, with the app icon (thumbnail) or default asset.
+  if (viewType === 'Webxdc') {
+    return (
+      <div className='webxdc download-on-demand'>
+        {message.file ? (
+          <img src={runtime.transformBlobURL(message.file)} alt='' />
+        ) : (
+          // No thumbnail yet and no .xdc downloaded to derive an icon from, so
+          // fall back to the grey box rather than getWebxdcIconURL (which is
+          // unimplemented on target-browser and can't work for a pre-message).
+          <div className='download-on-demand-empty' />
+        )}
+        <div className='info-text'>
+          <div className='name'>{message.fileName}</div>
+        </div>
+        {controls}
+      </div>
+    )
+  }
+
+  // Generic file (and any other type): the file card with extension + name.
+  const extension = getExtension(message)
+  return (
+    <div className='message-attachment-generic download-on-demand'>
+      <div className='file-icon' title={message.fileMime || 'null'}>
+        {extension ? (
+          <div className='file-extension'>
+            {message.fileMime === 'application/octet-stream' ? '' : extension}
+          </div>
+        ) : null}
+      </div>
+      <div className='text-part'>
+        <div className='name'>{message.fileName}</div>
+        {controls}
+      </div>
+    </div>
+  )
+}
