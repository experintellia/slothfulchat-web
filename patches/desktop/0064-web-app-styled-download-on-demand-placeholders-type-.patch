@@ -0,0 +1,118 @@
+// Styled download-on-demand placeholders (see DownloadOnDemandPlaceholder.tsx).
+// Reuses the .message-attachment-* / .webxdc boxes from _message-attachment.scss
+// and adds: a blurred thumbnail, a grey fallback box, and a centered overlay
+// with a prominent download button plus the target file size.
+
+.download-on-demand {
+  // Media types (image / gif / sticker / video) share the media box.
+  &.message-attachment-media {
+    display: block;
+    min-height: 160px;
+
+    // Blur the thumbnail so it reads as "not yet downloaded".
+    & > .attachment-content {
+      width: 100%;
+      height: 100%;
+      min-height: 160px;
+      object-fit: cover;
+      filter: blur(6px);
+      // blur() samples transparent pixels past the edge; scale up to hide it.
+      transform: scale(1.1);
+    }
+
+    & > .download-on-demand-empty {
+      width: 100%;
+      min-height: 160px;
+      background-color: var(--messageAttachmentIconBg);
+    }
+
+    &.video > .attachment-content,
+    &.video > .download-on-demand-empty {
+      background-color: black;
+    }
+
+    // CSS play triangle, centered behind the overlay controls.
+    & > .play-glyph {
+      position: absolute;
+      top: 50%;
+      left: 50%;
+      transform: translate(-40%, -140%);
+      width: 0;
+      height: 0;
+      border-style: solid;
+      border-width: 14px 0 14px 24px;
+      border-color: transparent transparent transparent
+        rgba(255, 255, 255, 0.85);
+    }
+  }
+
+  .download-on-demand-overlay {
+    position: absolute;
+    inset: 0;
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    justify-content: center;
+    gap: 8px;
+
+    .duration {
+      color: white;
+      font-size: 12px;
+      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
+    }
+  }
+
+  // Non-media rows (audio / file / webxdc) lay controls out inline.
+  &.message-attachment-audio,
+  &.message-attachment-generic,
+  &.webxdc {
+    align-items: center;
+  }
+
+  .text-part > .duration {
+    color: var(--messageAttachmentFileInfo);
+    font-size: 11px;
+    line-height: 16px;
+    margin-top: 3px;
+  }
+}
+
+.download-on-demand-controls {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 4px;
+
+  .download-button {
+    padding: 8px 18px;
+    border: none;
+    border-radius: 18px;
+    background-color: var(--colorPrimary, #415e6b);
+    color: white;
+    font-size: 14px;
+    cursor: pointer;
+
+    &:disabled {
+      opacity: 0.6;
+      cursor: default;
+    }
+  }
+
+  .size {
+    font-size: 11px;
+    letter-spacing: 0.3px;
+    color: var(--messageAttachmentFileInfo);
+  }
+
+  // Over a blurred thumbnail the size text needs contrast.
+  .download-on-demand-overlay & .size,
+  .download-on-demand-overlay & .failed {
+    color: white;
+    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
+  }
+
+  .failed {
+    color: var(--errorText, #e6512c);
+    font-size: 12px;
+  }
+}
