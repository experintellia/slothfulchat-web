+@use 'sass:map';
+@use '../variables';
+
+// Floats above the composer, left-aligned to the textarea. Anchored to
+// `.lower-bar` (which is `position: relative`) rather than the caret, so no
+// per-character pixel measuring is needed.
+//
+// ponytail: an ancestor with `overflow: hidden` could clip the top of a tall
+// list. Ceiling: fine for the chat layout today (the composer column doesn't
+// clip vertically). Upgrade path: portal to <body> + fixed at the textarea's
+// getBoundingClientRect.
+.completion-menu {
+  position: absolute;
+  bottom: calc(100% + 4px);
+  inset-inline-start: 8px;
+  z-index: map.get(variables.$z-index, emoji-sticker-picker);
+
+  width: min(320px, calc(100% - 16px));
+  max-height: 240px;
+  overflow-y: auto;
+
+  background-color: var(--bgPrimary);
+  color: var(--textPrimary);
+  border: 1px solid var(--separatorColor);
+  border-radius: 8px;
+  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
+
+  .completion-menu-item {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+    padding: 7px 12px;
+    cursor: default;
+
+    &.active {
+      background-color: var(--chatListItemSelectedBg);
+      color: var(--chatListItemSelectedText, var(--textPrimary));
+    }
+  }
+
+  .completion-menu-preview {
+    font-size: 20px;
+    width: 22px;
+    text-align: center;
+    flex: 0 0 auto;
+  }
+
+  .completion-menu-label {
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+}
