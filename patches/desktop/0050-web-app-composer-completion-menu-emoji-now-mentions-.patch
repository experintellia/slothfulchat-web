@@ -0,0 +1,31 @@
+// Shared contract for the composer completion menu. The menu itself is generic;
+// each trigger (`:` for emoji now, `@` for mentions later) is a provider.
+
+export type CompletionItem = {
+  /** stable key, e.g. the emoji shortcode id */
+  id: string
+  /** text shown on the row, e.g. `:smile:` */
+  label: string
+  /** what gets inserted into the draft, e.g. the Unicode glyph */
+  value: string
+  /** optional glyph/preview rendered at the start of the row */
+  preview?: string
+}
+
+export type CompletionProvider = {
+  /** the character that opens this provider, e.g. ':' */
+  trigger: string
+  /** minimum chars after the trigger before the menu shows */
+  minChars: number
+  /** matches for the typed term, best first */
+  query: (term: string) => CompletionItem[]
+}
+
+export type ActiveToken = {
+  trigger: string
+  term: string
+  /** offset of the trigger char in the text */
+  start: number
+  /** caret offset (end of the term) */
+  end: number
+}
