+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import { findActiveToken } from '../components/composer/completion/findActiveToken.js'
+import { emojiProvider } from '../components/composer/completion/emojiProvider.js'
+
+import type { CompletionItem } from '../components/composer/completion/types.js'
+
+const emoji = {
+  trigger: emojiProvider.trigger,
+  minChars: emojiProvider.minChars,
+}
+
+// caret marker `|` in the input string keeps the cases readable
+const at = (s: string) => s.indexOf('|')
+const tok = (s: string) => findActiveToken(s.replace('|', ''), at(s), emoji)
+
+describe('composer completion / findActiveToken', () => {
+  it('fires after the trigger + 2 chars and reports the term + range', () => {
+    expect(tok('hi :sm|')).to.deep.equal({
+      trigger: ':',
+      term: 'sm',
+      start: 3,
+      end: 6,
+    })
+  })
+
+  it('stays quiet for a lone trigger or a single char', () => {
+    expect(tok(':|')).to.equal(null)
+    expect(tok('go :s|')).to.equal(null)
+  })
+
+  it('does not fire inside URLs or times (boundary guard)', () => {
+    expect(tok('see http://ho|st')).to.equal(null)
+    expect(tok('at 12:30|')).to.equal(null)
+  })
+
+  it('treats start-of-input as a valid boundary', () => {
+    expect(tok(':sm|')).to.deep.equal({
+      trigger: ':',
+      term: 'sm',
+      start: 0,
+      end: 3,
+    })
+  })
+
+  it('ends the token at whitespace and at an already-closed shortcode', () => {
+    expect(tok('hi :sm |')).to.equal(null)
+    expect(tok('hi :smile:|')).to.equal(null)
+  })
+})
+
+describe('composer completion / emojiProvider', () => {
+  it('ranks the exact/prefix shortcode first and inserts the Unicode glyph', () => {
+    const items = emojiProvider.query('smile') as CompletionItem[]
+    expect(items[0].id).to.equal('smile')
+    expect(items[0].label).to.equal(':smile:')
+    expect(items[0].value).to.equal('😄')
+  })
+
+  it('matches on keywords, not just the shortcode', () => {
+    const items = emojiProvider.query('happy') as CompletionItem[]
+    expect(items.some(i => i.id === 'smile')).to.equal(true)
+  })
+})
