+/**
+ * Base URL the core's webimap transport will use for `host`. Mirrors the
+ * core's `base_url()` (patches/core/0011): everything is https, except the
+ * `localhost` / `127.0.0.1` / `[::1]` test hatch which is plain http — so the
+ * probe below hits the same scheme the account will actually be created over.
+ */
+function webimapBaseUrl(host: string): string {
+  const name = host.startsWith('[')
+    ? host.slice(1).split(']')[0] // bracketed IPv6, `[::1]` or `[::1]:8443`
+    : host.split(':')[0]
+  const scheme =
+    name === 'localhost' || name === '127.0.0.1' || name === '::1'
+      ? 'http'
+      : 'https'
+  return `${scheme}://${host}`
+}
+
+/**
+ * Tell "server unreachable" apart from "server reachable but blocking the
+ * browser (CORS)" before we hand off to onboarding. Account creation is done
+ * by the core with `POST <base>/new`; if the madmail server is down or isn't
+ * sending CORS headers, that fails deep inside the wasm core with an opaque
+ * `fetch POST JsValue(TypeError: NetworkError…)` alert that gives the user
+ * nothing to act on.
+ *
+ * A cross-origin `fetch` that fails throws the same opaque TypeError whether
+ * the cause is CORS or a dead host — the browser hides the difference on
+ * purpose. So we probe twice:
+ *   - a normal (`cors`) GET to `<base>/` resolves (for any HTTP status) only if
+ *     the server sent an Access-Control-Allow-Origin the app's origin is
+ *     allowed by;
+ *   - if that throws, a `no-cors` GET resolves (as an opaque response) as long
+ *     as the server is reachable at all, CORS headers or not.
+ * cors-ok → 'ok'; cors-throws + no-cors-ok → 'cors'; both throw →
+ * 'unreachable'.
+ *
+ * This is a best-effort heuristic, not a guarantee — the caller only warns on
+ * it (the user can proceed anyway). Caveats: it probes `/` (side-effect-free,
+ * unlike POST /new which would provision an account), assuming madmail serves
+ * CORS headers on `/` too; and a plain GET is a CORS "simple request", so an
+ * 'ok' here does not prove the later preflighted requests (the auth-header
+ * `GET /webimap/*` calls) will pass. On its own errors it returns 'ok' so a
+ * flaky probe never blocks a server that would in fact work.
+ */
+async function diagnoseWebimapServer(
+  host: string
+): Promise<'ok' | 'cors' | 'unreachable'> {
+  const base = `${webimapBaseUrl(host)}/`
+  const reaches = async (mode: RequestMode): Promise<boolean> => {
+    const controller = new AbortController()
+    const timer = setTimeout(() => controller.abort(), 6000)
+    try {
+      await fetch(base, {
+        method: 'GET',
+        mode,
+        cache: 'no-store',
+        signal: controller.signal,
+      })
+      return true
+    } catch {
+      return false
+    } finally {
+      clearTimeout(timer)
+    }
+  }
+  try {
+    if (await reaches('cors')) return 'ok'
+    if (await reaches('no-cors')) return 'cors'
+    return 'unreachable'
+  } catch {
+    return 'ok'
+  }
+}
+
