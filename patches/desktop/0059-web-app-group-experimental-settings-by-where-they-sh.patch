From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Claude <claude.ai.2026@simonlaux.de>
Date: Mon, 20 Jul 2026 17:18:53 +0000
Subject: [PATCH 58/58] web-app: group experimental settings by where they show
 up
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Sub-headings in the Experimental section: Composer (emoji completion,
link previews), Chats (read-time badge, location streaming), System
(screen security, background sync, webxdc store URL) — related toggles
now sit together instead of historical order.
---
 .../Settings/ExperimentalFeatures.tsx         | 30 ++++++++++++-------
 1 file changed, 19 insertions(+), 11 deletions(-)

diff --git a/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx b/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
index be25c59f9..5d9cbd008 100644
--- a/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
+++ b/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
@@ -5,6 +5,8 @@ import SettingsStoreInstance, {
   type SettingsStoreState,
 } from '../../stores/settings'
 import DesktopSettingsSwitch from './DesktopSettingsSwitch'
+import SettingsHeading from './SettingsHeading'
+import SettingsSeparator from './SettingsSeparator'
 import useTranslationFunction from '../../hooks/useTranslationFunction'
 import SettingsSwitch from './SettingsSwitch'
 import { runtime } from '@deltachat-desktop/runtime-interface'
@@ -62,14 +64,15 @@ export function ExperimentalFeatures() {
     })
   }
 
+  // grouped by where the feature shows up, so related toggles sit together
   return (
     <>
+      <SettingsHeading>Composer</SettingsHeading>
       <DesktopSettingsSwitch
-        settingsKey='enableOnDemandLocationStreaming'
-        label={tx('pref_on_demand_location_streaming')}
-        callback={value =>
-          showExperimentalInfoDialog('enableOnDemandLocationStreaming', value)
-        }
+        settingsKey='experimentalCompletionMenu'
+        label='Emoji completion menu'
+        description='Type a colon and a name in the composer (e.g. :smile) to pick an emoji from a pop-up menu. Off by default (experimental).'
+        forkAdded
       />
       <DesktopSettingsSwitch
         settingsKey='linkPreviewSuggestions'
@@ -77,18 +80,23 @@ export function ExperimentalFeatures() {
         description='When your message contains a link and has no image, offer to attach a preview card. Off by default; turn on to be prompted.'
         forkAdded
       />
-      <DesktopSettingsSwitch
-        settingsKey='experimentalCompletionMenu'
-        label='Emoji completion menu'
-        description='Type a colon and a name in the composer (e.g. :smile) to pick an emoji from a pop-up menu. Off by default (experimental).'
-        forkAdded
-      />
+      <SettingsSeparator />
+      <SettingsHeading>Chats</SettingsHeading>
       <DesktopSettingsSwitch
         settingsKey='experimentalUnreadReadTime'
         label='Estimated read time on unread badge'
         description='Show roughly how long the unread messages in a chat take to read (e.g. "~4 min") next to the unread counter. Off by default (experimental).'
         forkAdded
       />
+      <DesktopSettingsSwitch
+        settingsKey='enableOnDemandLocationStreaming'
+        label={tx('pref_on_demand_location_streaming')}
+        callback={value =>
+          showExperimentalInfoDialog('enableOnDemandLocationStreaming', value)
+        }
+      />
+      <SettingsSeparator />
+      <SettingsHeading>System</SettingsHeading>
       {runtime.getRuntimeInfo().isContentProtectionSupported && (
         <DesktopSettingsSwitch
           settingsKey='contentProtectionEnabled'
