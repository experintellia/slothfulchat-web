 .../dialogs/About/styles.module.scss          | 13 +++++----
 .../WelcomeScreen/OnboardingScreen.tsx        | 27 ++++++++++++-------
 .../screens/WelcomeScreen/styles.module.scss  | 15 +++++++++++
 4 files changed, 49 insertions(+), 23 deletions(-)

