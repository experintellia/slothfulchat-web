From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Claude <claude.ai.2026@simonlaux.de>
Date: Mon, 20 Jul 2026 20:32:35 +0000
Subject: [PATCH 61/61] web-app: enable the emoji completion menu by default

The :emoji: completion menu has proven itself; flip the
experimentalCompletionMenu default to true so everyone gets it without
digging through Settings -> Experimental features. The switch stays
there for anyone who wants it off, and a previously saved "off" choice
is respected as before -- only the default for fresh profiles changes.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 .../frontend/src/components/Settings/ExperimentalFeatures.tsx   | 2 +-
 .../frontend/src/components/composer/ComposerMessageInput.tsx   | 2 +-
 packages/shared/shared-types.d.ts                               | 2 +-
 packages/shared/state.ts                                        | 2 +-
 4 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx b/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
index 5d9cbd00..3704aa87 100644
--- a/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
+++ b/packages/frontend/src/components/Settings/ExperimentalFeatures.tsx
@@ -71,7 +71,7 @@ export function ExperimentalFeatures() {
       <DesktopSettingsSwitch
         settingsKey='experimentalCompletionMenu'
         label='Emoji completion menu'
-        description='Type a colon and a name in the composer (e.g. :smile) to pick an emoji from a pop-up menu. Off by default (experimental).'
+        description='Type a colon and a name in the composer (e.g. :smile) to pick an emoji from a pop-up menu. On by default.'
         forkAdded
       />
       <DesktopSettingsSwitch
diff --git a/packages/frontend/src/components/composer/ComposerMessageInput.tsx b/packages/frontend/src/components/composer/ComposerMessageInput.tsx
index 3184458f..cb9d28ae 100644
--- a/packages/frontend/src/components/composer/ComposerMessageInput.tsx
+++ b/packages/frontend/src/components/composer/ComposerMessageInput.tsx
@@ -53,7 +53,7 @@ type ComposerMessageInputProps = {
   chatId: number
   sendMessageOrEditRequest: () => void
   enterKeySends: boolean
-  /** Enable the :emoji: completion menu (experimental, off by default). */
+  /** Enable the :emoji: completion menu (on by default). */
   completionMenu?: boolean
   onPaste?: (e: React.ClipboardEvent<HTMLTextAreaElement>) => void
   // used to show/hide send button
diff --git a/packages/shared/shared-types.d.ts b/packages/shared/shared-types.d.ts
index 8d93c75a..00c76415 100644
--- a/packages/shared/shared-types.d.ts
+++ b/packages/shared/shared-types.d.ts
@@ -43,7 +43,7 @@ export interface DesktopSettingsType {
   linkPreviewSuggestions: boolean
   /** webapp: strip known tracking params (utm_*, YouTube si=, …) on paste and open. On by default. */
   stripTrackingLinks: boolean
-  /** webapp: composer :emoji: completion menu. Off by default (experimental). */
+  /** webapp: composer :emoji: completion menu. On by default. */
   experimentalCompletionMenu: boolean
   /** webapp: estimated time-to-read next to the unread badge. Off by default (experimental). */
   experimentalUnreadReadTime: boolean
diff --git a/packages/shared/state.ts b/packages/shared/state.ts
index 8501d91d..7488ea78 100644
--- a/packages/shared/state.ts
+++ b/packages/shared/state.ts
@@ -16,7 +16,7 @@ export function getDefaultState(): DesktopSettingsType {
     enableOnDemandLocationStreaming: false,
     linkPreviewSuggestions: false,
     stripTrackingLinks: true,
-    experimentalCompletionMenu: false,
+    experimentalCompletionMenu: true,
     experimentalUnreadReadTime: false,
     chatViewBgImg: undefined,
     lastChats: {},
