diff --git a/packages/frontend/src/hooks/useDownloadProgress.ts b/packages/frontend/src/hooks/useDownloadProgress.ts
new file mode 100644
index 000000000..7d9274a2e
--- /dev/null
+++ b/packages/frontend/src/hooks/useDownloadProgress.ts
@@ -0,0 +1,30 @@
+import { useEffect, useState } from 'react'
+import { onDCEvent } from '../backend-com'
+import { permilleToPercent } from '../utils/downloadProgress'
+
+/**
+ * Latest download progress (0-100) for a message whose `downloadState`
+ * is `'InProgress'`, driven by the core's `DownloadProgress` event.
+ * Returns `null` until the first event for this message arrives.
+ */
+export function useDownloadProgress(
+  accountId: number,
+  messageId: number,
+  isDownloading: boolean
+): number | null {
+  const [percent, setPercent] = useState<number | null>(null)
+
+  useEffect(() => {
+    if (!isDownloading) {
+      setPercent(null)
+      return
+    }
+    return onDCEvent(accountId, 'DownloadProgress', ({ msgId, permille }) => {
+      if (msgId === messageId) {
+        setPercent(permilleToPercent(permille))
+      }
+    })
+  }, [accountId, messageId, isDownloading])
+
+  return percent
+}
diff --git a/packages/frontend/src/tests/downloadProgress.test.ts b/packages/frontend/src/tests/downloadProgress.test.ts
new file mode 100644
index 000000000..2b4701496
--- /dev/null
+++ b/packages/frontend/src/tests/downloadProgress.test.ts
@@ -0,0 +1,14 @@
+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import { permilleToPercent } from '../utils/downloadProgress.js'
+
+describe('permilleToPercent', () => {
+  it('floors permille (0-1000) down to whole percent (0-100)', () => {
+    expect(permilleToPercent(1)).to.equal(0)
+    expect(permilleToPercent(499)).to.equal(49)
+    expect(permilleToPercent(500)).to.equal(50)
+    expect(permilleToPercent(999)).to.equal(99)
+    expect(permilleToPercent(1000)).to.equal(100)
+  })
+})
diff --git a/packages/frontend/src/utils/downloadProgress.ts b/packages/frontend/src/utils/downloadProgress.ts
new file mode 100644
index 000000000..592044888
--- /dev/null
+++ b/packages/frontend/src/utils/downloadProgress.ts
@@ -0,0 +1,7 @@
+// Pure math for the download-progress percentage shown next to the
+// 'downloading' label. Kept import-free so the unit test needs no backend.
+
+/** `permille` (0-1000) -> whole percent (0-100), as shown to the user. */
+export function permilleToPercent(permille: number): number {
+  return Math.floor(permille / 10)
+}
