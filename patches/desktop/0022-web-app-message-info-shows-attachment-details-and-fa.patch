+// Prominent banner shown when a message failed to send. This dialog is where
+// the failed-status icon in the message bubble now takes the user, so the
+// error needs to read clearly at the top.
+.errorRow {
+  display: flex;
+  align-items: baseline;
+  gap: 8px;
+  margin: 0 10px 14px;
+  padding: 10px 14px;
+  border-radius: 8px;
+  background-color: color-mix(in srgb, var(--errorColor) 12%, transparent);
+  color: var(--errorColor);
+}
+
+// Leading warning glyph (⚠) — avoids a build-time SVG asset dependency.
+.errorIcon::before {
+  content: '\26A0';
+  font-weight: 700;
+}
+
+.errorText {
+  font-weight: 500;
+  word-break: break-word;
+}
+
 .infoRow {
   display: flex;
   justify-content: space-between;
