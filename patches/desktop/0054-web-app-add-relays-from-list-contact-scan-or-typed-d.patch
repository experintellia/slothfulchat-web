@@ -0,0 +1,66 @@
+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import { contactRelayCandidates } from '../components/dialogs/Transports/contactRelays.js'
+
+// The contact addresses come from the account's own contact list, but the
+// aggregation still has to be defensive: skip anything that isn't a plausible
+// mail address, count per relay domain, drop excluded hosts, and hand back a
+// stable most-used-first order for the picker's contact section.
+describe('contactRelayCandidates', () => {
+  it('counts contacts per relay domain, lowercased', () => {
+    expect(
+      contactRelayCandidates(
+        ['a@nine.testrun.org', 'b@Nine.Testrun.Org', 'c@mehl.cloud'],
+        new Set()
+      )
+    ).to.eql([
+      { host: 'nine.testrun.org', contacts: 2 },
+      { host: 'mehl.cloud', contacts: 1 },
+    ])
+  })
+
+  it('excludes given hosts', () => {
+    expect(
+      contactRelayCandidates(
+        ['a@nine.testrun.org', 'b@mehl.cloud', 'c@mehl.cloud'],
+        new Set(['nine.testrun.org'])
+      )
+    ).to.eql([{ host: 'mehl.cloud', contacts: 2 }])
+  })
+
+  it('skips malformed addresses', () => {
+    expect(
+      contactRelayCandidates(
+        [
+          'no-at-sign',
+          '@nolocal.example',
+          'user@',
+          'user@bad host.example',
+          'user@no-dots',
+          'ok@nine.testrun.org',
+        ],
+        new Set()
+      )
+    ).to.eql([{ host: 'nine.testrun.org', contacts: 1 }])
+  })
+
+  it('sorts by contacts desc, then host alphabetically', () => {
+    expect(
+      contactRelayCandidates(
+        [
+          'a@zeta.example',
+          'b@zeta.example',
+          'c@alpha.example',
+          'd@alpha.example',
+          'e@beta.example',
+        ],
+        new Set()
+      )
+    ).to.eql([
+      { host: 'alpha.example', contacts: 2 },
+      { host: 'zeta.example', contacts: 2 },
+      { host: 'beta.example', contacts: 1 },
+    ])
+  })
+})
