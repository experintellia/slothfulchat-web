+
+/**
+ * Which deviceId to actually record with: the persisted one if it's still in
+ * the enumerated inputs, else null (system default). A stale id would make
+ * getUserMedia({ deviceId: { exact } }) throw OverconstrainedError; falling
+ * back to null keeps the recording alive. Pure so it's unit-testable; start()
+ * additionally catches the runtime race where a device vanishes mid-flight.
+ */
+export function resolveDeviceId(
+  persisted: string | null,
+  availableIds: string[]
+): string | null {
+  return persisted != null && availableIds.indexOf(persisted) !== -1
+    ? persisted
+    : null
+}
