           srcDoc={connectivityHTML}
           sandbox={''}
         />
+        <BrowserBridgeInfo />
       </DialogContent>
     </DialogBody>
   )
 }
 
+/** slothfulchat: the browser edition tunnels IMAP/SMTP through a WS→TCP
+ * bridge (window.__slothfulchatBridge is set by its runtime.js). Show which
+ * bridge is in use and let the user open the edit dialog from here. */
+function BrowserBridgeInfo() {
+  const bridge = (window as any).__slothfulchatBridge
+  if (runtime.getRuntimeInfo().target !== 'browser' || !bridge) return null
+  return (
+    <div style={{ marginTop: '8px', fontSize: '13px' }}>
+      Bridge: <code>{bridge.url()}</code>{' '}
+      <button type='button' onClick={() => bridge.openDialog()}>
+        Change…
+      </button>
+    </div>
+  )
+}
+
 async function getConnectivityHTML(
   stylesToInject?: string | undefined
 ): Promise<string> {
