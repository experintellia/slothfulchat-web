index da4e27a51..20af835b4 100644
--- a/packages/frontend/src/components/dialogs/ExportChatToHtml.tsx
+++ b/packages/frontend/src/components/dialogs/ExportChatToHtml.tsx
@@ -83,6 +83,14 @@ export default function ExportChatToHtml({ chat, onClose }: Props) {
       () => cancelled.current
     )
       .then(filename => {
+        // slothfulchat: anonymous analytics — the user exported a chat, with
+        // or without a custom date range (yes = at least one date was filled)
