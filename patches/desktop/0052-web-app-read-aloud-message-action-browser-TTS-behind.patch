 import { ContextMenuItem } from '../ContextMenu'
 import { onDCEvent, BackendRemote } from '../../backend-com'
 import { selectedAccountId } from '../../ScreenController'
+import SettingsStoreInstance from '../../stores/settings'
 import { ProtectionEnabledDialog } from '../dialogs/ProtectionStatusDialog'
 import useDialog from '../../hooks/dialog/useDialog'
 import useMessage from '../../hooks/chat/useMessage'
@@ -312,6 +313,14 @@ function buildContextMenu(
   // Do not show "react" for system messages
   const showSendReaction = showReactionsUi(message, chat)
 
+  // "Read aloud" via the browser's built-in speechSynthesis (experimental,
+  // off by default). Fully local: OS voices, no network.
+  const showReadAloud =
+    SettingsStoreInstance.state?.desktopSettings.experimentalReadAloud ===
+      true &&
+    'speechSynthesis' in window &&
+    !!text
+
   // Only show in groups, don't show on info messages or outgoing messages
   const showReplyPrivately =
     (conversationType.chatType === 'Group' ||
@@ -387,6 +396,22 @@ function buildContextMenu(
       },
     // copy item (selection or all text)
     text !== '' && copy_item,
+    // Read message aloud (experimental)
+    showReadAloud && {
+      label: tx('menu_read_aloud'),
+      action: () => {
+        // ponytail: default voice/language; the browser picks per its locale,
+        // a per-message language guess would need detection with no API for it
+        window.speechSynthesis.cancel()
+        window.speechSynthesis.speak(new SpeechSynthesisUtterance(text))
+      },
+    },
+    // Stop an ongoing read-aloud (only shown while speaking)
+    showReadAloud &&
+      window.speechSynthesis.speaking && {
+        label: tx('menu_stop_reading_aloud'),
+        action: () => window.speechSynthesis.cancel(),
+      },
     // Copy image
     showCopyImage && {
       label: tx('menu_copy_image_to_clipboard'),
