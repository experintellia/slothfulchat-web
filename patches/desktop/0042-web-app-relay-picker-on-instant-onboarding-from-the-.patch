diff --git a/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx b/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx
new file mode 100644
index 000000000..859c5a79c
--- /dev/null
+++ b/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx
@@ -0,0 +1,327 @@
+import React, { useCallback, useEffect, useRef, useState } from 'react'
+
+import useInstantOnboarding from '../../../hooks/useInstantOnboarding'
+import {
+  defaultRelayHost,
+  fetchRelayDirectory,
+  probeRelay,
+} from './relayDirectory'
+import { normalizeRelayHost } from './relayDirectoryParse'
+import styles from './styles.module.scss'
+
+// English is hardcoded here (like the rest of patch desktop/0042) so the relay
+// picker stays a self-contained patch and doesn't have to touch every locale
+// file. See PATCHES.md.
+
+type ProbeStatus = 'probing' | 'reachable' | 'unreachable'
+type Probe = { status: ProbeStatus; latencyMs: number | null }
+
+/**
+ * slothfulchat-web: dropdown on the instant-onboarding ("create profile")
+ * screen to pick which public chatmail relay the new address is created on.
+ *
+ * The list comes live from the chatmail relay directory (relayDirectory.ts),
+ * default relay first. Fetching that list is cheap and done on mount; probing
+ * each relay over the WS→TCP bridge is not, so it happens lazily — only when
+ * the user opens the dropdown. Each relay then shows a live state: a spinner
+ * while probing, a rough latency once its IMAPS handshake answers, or greyed
+ * out and unselectable when the bridge can't resolve it. An "Other…" entry
+ * lets the user type any chatmail relay by hostname.
+ *
+ * Renders nothing while the directory is loading, when it is unavailable, when
+ * there is nothing to choose (fewer than two relays), or when a scanned
+ * `dcaccount:`/`dclogin:` QR already pins the server.
+ */
+export default function RelayPicker() {
+  const { welcomeQr, selectedRelayHost, setSelectedRelayHost } =
+    useInstantOnboarding()
+  const [relays, setRelays] = useState<string[] | null>(null)
+  const [open, setOpen] = useState(false)
+  const [probes, setProbes] = useState<Record<string, Probe>>({})
+  const [customHost, setCustomHost] = useState<string | undefined>(undefined)
+  const [customOpen, setCustomOpen] = useState(false)
+  const [customInput, setCustomInput] = useState('')
+  const [customError, setCustomError] = useState(false)
+
+  const containerRef = useRef<HTMLDivElement>(null)
+  const probedRef = useRef<Set<string>>(new Set())
+  const mountedRef = useRef(true)
+  useEffect(() => {
+    mountedRef.current = true
+    return () => {
+      mountedRef.current = false
+    }
+  }, [])
+
+  const defaultHost = defaultRelayHost()
+
+  // With a scanned account/login QR the server is fixed — no choice to offer.
+  const relayChoosable =
+    welcomeQr?.qr.kind !== 'account' && welcomeQr?.qr.kind !== 'login'
+
+  useEffect(() => {
+    if (!relayChoosable) {
+      return
+    }
+    let stale = false
+    fetchRelayDirectory().then(list => {
+      if (!stale) {
+        setRelays(list)
+      }
+    })
+    return () => {
+      stale = true
+    }
+  }, [relayChoosable])
+
+  // A custom ("Other…") relay chosen earlier this onboarding session lives in
+  // the shared context (selectedRelayHost) but isn't in the fetched directory,
+  // so re-surface it when the picker remounts — otherwise the closed picker
+  // would show the default while account creation (and the consent link) still
+  // target the custom host.
+  useEffect(() => {
+    if (
+      relays &&
+      selectedRelayHost &&
+      selectedRelayHost !== defaultHost &&
+      !relays.includes(selectedRelayHost)
+    ) {
+      setCustomHost(selectedRelayHost)
+    }
+  }, [relays, selectedRelayHost, defaultHost])
+
+  const startProbe = useCallback((host: string) => {
+    if (probedRef.current.has(host)) {
+      return
+    }
+    probedRef.current.add(host)
+    setProbes(prev => ({
+      ...prev,
+      [host]: { status: 'probing', latencyMs: null },
+    }))
+    probeRelay(host).then(({ reachable, latencyMs }) => {
+      if (!mountedRef.current) {
+        return
+      }
+      setProbes(prev => ({
+        ...prev,
+        [host]: {
+          status: reachable ? 'reachable' : 'unreachable',
+          latencyMs,
+        },
+      }))
+    })
+  }, [])
+
+  // Probe reachability + latency lazily, only once the dropdown is opened.
+  useEffect(() => {
+    if (open && relays) {
+      relays.forEach(startProbe)
+      if (customHost) {
+        startProbe(customHost)
+      }
+    }
+  }, [open, relays, customHost, startProbe])
+
+  // Close on outside click / Escape while open.
+  useEffect(() => {
+    if (!open) {
+      return
+    }
+    const onPointerDown = (event: MouseEvent) => {
+      if (
+        containerRef.current &&
+        !containerRef.current.contains(event.target as Node)
+      ) {
+        setOpen(false)
+      }
+    }
+    const onKeyDown = (event: KeyboardEvent) => {
+      if (event.key === 'Escape') {
+        setOpen(false)
+      }
+    }
+    document.addEventListener('mousedown', onPointerDown)
+    document.addEventListener('keydown', onKeyDown)
+    return () => {
+      document.removeEventListener('mousedown', onPointerDown)
+      document.removeEventListener('keydown', onKeyDown)
+    }
+  }, [open])
+
+  if (!relayChoosable || relays === null || relays.length < 2) {
+    return null
+  }
+
+  const hosts =
+    customHost && !relays.includes(customHost) ? [...relays, customHost] : relays
+  const value =
+    selectedRelayHost && hosts.includes(selectedRelayHost)
+      ? selectedRelayHost
+      : defaultHost
+
+  const isSelectable = (host: string) =>
+    host === defaultHost || probes[host]?.status !== 'unreachable'
+
+  const choose = (host: string) => {
+    if (!isSelectable(host)) {
+      return
+    }
+    setSelectedRelayHost(host === defaultHost ? undefined : host)
+    setOpen(false)
+    setCustomOpen(false)
+  }
+
+  const submitCustom = () => {
+    const host = normalizeRelayHost(customInput)
+    if (!host) {
+      setCustomError(true)
+      return
+    }
+    setCustomHost(host)
+    setSelectedRelayHost(host === defaultHost ? undefined : host)
+    startProbe(host)
+    setCustomInput('')
+    setCustomError(false)
+    setCustomOpen(false)
+    setOpen(false)
+  }
+
+  const renderState = (host: string) => {
+    const probe = probes[host]
+    if (!probe || probe.status === 'probing') {
+      return <span className={styles.relayPickerSpinner} aria-hidden='true' />
+    }
+    if (probe.status === 'unreachable') {
+      return (
+        <span className={styles.relayPickerUnreachable}>unreachable</span>
+      )
+    }
+    if (probe.latencyMs !== null) {
+      return (
+        <span className={styles.relayPickerLatency}>{probe.latencyMs} ms</span>
+      )
+    }
+    return (
+      <span className={styles.relayPickerReachable} aria-hidden='true'>
+        ✓
+      </span>
+    )
+  }
+
+  return (
+    <div className={styles.relayPicker} ref={containerRef}>
+      <label id='relay-picker-label' className={styles.relayPickerLabel}>
+        Chatmail relay for your new address
+      </label>
+      <button
+        type='button'
+        id='relay-picker'
+        data-testid='relay-picker-button'
+        className={styles.relayPickerButton}
+        aria-haspopup='listbox'
+        aria-expanded={open}
+        aria-labelledby='relay-picker-label'
+        onClick={() => setOpen(current => !current)}
+      >
+        <span className={styles.relayPickerButtonValue}>{value}</span>
+        <span className={styles.relayPickerChevron} aria-hidden='true' />
+      </button>
+      {open && (
+        <div
+          className={styles.relayPickerMenu}
+          data-testid='relay-picker-menu'
+          role='listbox'
+        >
+          {hosts.map(host => (
+            <div
+              key={host}
+              role='option'
+              data-testid={`relay-option-${host}`}
+              aria-selected={host === value}
+              aria-disabled={!isSelectable(host)}
+              tabIndex={0}
+              className={[
+                styles.relayPickerOption,
+                host === value ? styles.relayPickerOptionSelected : '',
+                !isSelectable(host) ? styles.relayPickerOptionDisabled : '',
+              ]
+                .filter(Boolean)
+                .join(' ')}
+              onClick={() => choose(host)}
+              onKeyDown={event => {
+                if (event.key === 'Enter' || event.key === ' ') {
+                  event.preventDefault()
+                  choose(host)
+                }
+              }}
+            >
+              <span className={styles.relayPickerOptionHost}>
+                {host}
+                {host === defaultHost && (
+                  <span className={styles.relayPickerDefaultTag}>default</span>
+                )}
+              </span>
+              {renderState(host)}
+            </div>
+          ))}
+          {!customOpen && (
+            <div
+              role='option'
+              data-testid='relay-option-other'
+              aria-selected={false}
+              tabIndex={0}
+              className={`${styles.relayPickerOption} ${styles.relayPickerOther}`}
+              onClick={() => setCustomOpen(true)}
+              onKeyDown={event => {
+                if (event.key === 'Enter' || event.key === ' ') {
+                  event.preventDefault()
+                  setCustomOpen(true)
+                }
+              }}
+            >
+              Other…
+            </div>
+          )}
+          {customOpen && (
+            <div className={styles.relayPickerCustomRow}>
+              <input
+                type='text'
+                autoFocus={true}
+                data-testid='relay-custom-input'
+                className={[
+                  styles.relayPickerCustomInput,
+                  customError ? styles.relayPickerCustomInputError : '',
+                ]
+                  .filter(Boolean)
+                  .join(' ')}
+                placeholder='relay hostname, e.g. chat.example.org'
+                value={customInput}
+                onChange={event => {
+                  setCustomInput(event.target.value)
+                  if (customError) {
+                    setCustomError(false)
+                  }
+                }}
+                onKeyDown={event => {
+                  if (event.key === 'Enter') {
+                    event.preventDefault()
+                    submitCustom()
+                  }
+                }}
+              />
+              <button
+                type='button'
+                data-testid='relay-custom-confirm'
+                className={styles.relayPickerCustomConfirm}
+                onClick={submitCustom}
+              >
+                Use
+              </button>
+            </div>
+          )}
+        </div>
+      )}
+    </div>
+  )
+}
