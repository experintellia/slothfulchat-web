@@ -0,0 +1,63 @@
+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import { parseRelaysMarkdown } from '../components/screens/WelcomeScreen/relayDirectoryParse.js'
+
+// The relay directory (relays.markdown from the chatmail pages sources) is a
+// hand-maintained document, so the parser is a tolerant scanner rather than a
+// format: it must find relays wherever the author spelled the hostname out,
+// and must NOT be fooled by decorative links or prose mentioning domains.
+describe('parseRelaysMarkdown', () => {
+  it('finds self-named markdown links', () => {
+    const md = [
+      '# Public chatmail relays',
+      '',
+      '- [nine.testrun.org](https://nine.testrun.org) — the default relay',
+      '- [chatmail.example](https://chatmail.example/) operated by Example',
+    ].join('\n')
+    expect(parseRelaysMarkdown(md)).to.eql([
+      'nine.testrun.org',
+      'chatmail.example',
+    ])
+  })
+
+  it('finds dcaccount: signup targets, bare or as link', () => {
+    const md = [
+      '| relay | signup |',
+      '|---|---|',
+      '| Nine | [sign up](dcaccount:nine.testrun.org) |',
+      '| Other | dcaccount:https://other.example/new |',
+    ].join('\n')
+    expect(parseRelaysMarkdown(md)).to.eql([
+      'nine.testrun.org',
+      'other.example',
+    ])
+  })
+
+  it('finds autolinks and decorated link texts, deduplicated', () => {
+    const md = [
+      '- <https://relay.example>',
+      '- [`relay.example`](https://relay.example)',
+      '- [**bold.example**](https://bold.example/anything)',
+    ].join('\n')
+    expect(parseRelaysMarkdown(md)).to.eql(['relay.example', 'bold.example'])
