diff --git a/packages/frontend/src/tests/relayDirectory.test.ts b/packages/frontend/src/tests/relayDirectory.test.ts
new file mode 100644
index 000000000..7c8d38f4e
--- /dev/null
+++ b/packages/frontend/src/tests/relayDirectory.test.ts
@@ -0,0 +1,102 @@
+import { expect } from 'chai'
+import { describe, it } from 'mocha'
+
+import {
+  normalizeRelayHost,
+  parseRelayDirectory,
+} from '../components/screens/WelcomeScreen/relayDirectoryParse.js'
+
+// The relay directory JSON comes from an automated mirror of
+// https://chatmail.at/relays, but it is still network input: the extractor
+// must take the valid hosts and silently skip everything else — a malformed
+// document must never throw, it just yields fewer (or zero) relays.
+describe('parseRelayDirectory', () => {
+  it('extracts hosts in document order', () => {
+    const doc = {
+      source: 'https://chatmail.at/relays',
+      fetchedAt: '2026-07-12T02:14:06Z',
+      relays: [
+        { host: 'nine.testrun.org' },
+        { host: 'mehl.cloud' },
+        { host: 'chat.adminforge.de' },
+      ],
+    }
+    expect(parseRelayDirectory(doc)).to.eql([
+      'nine.testrun.org',
+      'mehl.cloud',
+      'chat.adminforge.de',
+    ])
+  })
+
+  it('lowercases, trims and deduplicates', () => {
+    const doc = {
+      relays: [
+        { host: ' Nine.Testrun.Org ' },
+        { host: 'nine.testrun.org' },
+        { host: 'MEHL.CLOUD' },
+      ],
+    }
+    expect(parseRelayDirectory(doc)).to.eql(['nine.testrun.org', 'mehl.cloud'])
+  })
+
+  it('skips junk entries but keeps the valid ones', () => {
+    const doc = {
+      relays: [
+        { host: 'nine.testrun.org' },
+        { host: 'https://not-a-bare-host.example' },
+        { host: 'no-dots' },
+        { host: 'bad host.example' },
+        { host: 42 },
+        { notHost: 'x.example' },
+        null,
+        'just-a-string.example',
+        { host: 'mehl.cloud', extraUnknownField: true },
+      ],
+    }
+    expect(parseRelayDirectory(doc)).to.eql(['nine.testrun.org', 'mehl.cloud'])
+  })
+
+  it('returns [] for malformed documents without throwing', () => {
+    for (const doc of [
+      null,
+      undefined,
+      'a string',
+      42,
+      [],
+      {},
+      { relays: 'not-an-array' },
+      { relays: {} },
+      { relays: [] },
+    ]) {
+      expect(parseRelayDirectory(doc)).to.eql([])
+    }
+  })
+})
+
+// A relay typed by hand into the picker's "Other…" field must be validated the
+// same way a fetched one is, so the plumbing (dcaccount:<host>, the consent
+// link) only ever sees a plausible bare hostname.
+describe('normalizeRelayHost', () => {
+  it('accepts and lowercases/trims a bare hostname', () => {
+    expect(normalizeRelayHost('  Chat.Example.Org ')).to.equal(
+      'chat.example.org'
+    )
+    expect(normalizeRelayHost('nine.testrun.org')).to.equal('nine.testrun.org')
+  })
+
+  it('rejects anything that is not a bare hostname', () => {
+    for (const value of [
+      '',
+      '   ',
+      'no-dots',
+      'https://chat.example.org',
+      'chat.example.org/new',
+      'user@chat.example.org',
+      'bad host.example',
+      'chat.example.',
+      '.example.org',
+    ]) {
+      expect(normalizeRelayHost(value), value).to.equal(undefined)
+    }
+  })
+})
