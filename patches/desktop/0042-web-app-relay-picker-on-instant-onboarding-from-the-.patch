diff --git a/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx b/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx
new file mode 100644
index 000000000..934629448
--- /dev/null
+++ b/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx
@@ -0,0 +1,95 @@
+import React, { useEffect, useState } from 'react'
+
+import useDialog from '../../../hooks/dialog/useDialog'
+import useInstantOnboarding from '../../../hooks/useInstantOnboarding'
+import RelayPickerDialog from './RelayPickerDialog'
+import { defaultRelayHost, fetchRelayDirectory } from './relayDirectory'
+import styles from './styles.module.scss'
+
+// English is hardcoded here (like the rest of patch desktop/0042) so the relay
+// picker stays a self-contained patch and doesn't have to touch every locale
+// file. See PATCHES.md.
+
+/**
+ * slothfulchat-web: on the instant-onboarding ("create profile") screen, a row
+ * showing which public chatmail relay the new address will be created on, with
+ * a button that opens the relay picker dialog (RelayPickerDialog) to change it.
+ *
+ * The list comes live from the chatmail relay directory (relayDirectory.ts);
+ * fetching it is cheap and done here on mount, but probing each relay over the
+ * WS→TCP bridge is not, so that happens in the dialog, once opened. The row
+ * always reflects the chosen relay (kept in InstantOnboardingContext), so the
+ * consent link and account creation can't disagree with what's shown.
+ *
+ * Renders nothing while the directory is loading, when it is unavailable, when
+ * there is nothing to choose (fewer than two relays), or when a scanned
+ * `dcaccount:`/`dclogin:` QR already pins the server.
+ */
+export default function RelayPicker() {
+  const { welcomeQr, selectedRelayHost, setSelectedRelayHost } =
+    useInstantOnboarding()
+  const { openDialog } = useDialog()
+  const [relays, setRelays] = useState<string[] | null>(null)
+
+  const defaultHost = defaultRelayHost()
+
+  // With a scanned account/login QR the server is fixed — no choice to offer.
+  const relayChoosable =
+    welcomeQr?.qr.kind !== 'account' && welcomeQr?.qr.kind !== 'login'
+
+  useEffect(() => {
+    if (!relayChoosable) {
+      return
+    }
+    let stale = false
+    fetchRelayDirectory().then(list => {
+      if (!stale) {
+        setRelays(list)
+      }
+    })
+    return () => {
+      stale = true
+    }
+  }, [relayChoosable])
+
+  if (!relayChoosable || relays === null || relays.length < 2) {
+    return null
+  }
+
+  // The chosen relay may be a directory relay, the default, or a custom host
+  // typed earlier this session (kept in context, so not in `relays`).
+  const current =
+    selectedRelayHost && selectedRelayHost !== defaultHost
+      ? selectedRelayHost
+      : defaultHost
+
+  const openPicker = () =>
+    openDialog(RelayPickerDialog, {
+      relays,
+      defaultHost,
+      selectedHost: current,
+      onSelect: (host?: string) => setSelectedRelayHost(host),
+    })
+
+  return (
+    <div className={styles.relayPicker}>
+      <span className={styles.relayPickerLabel}>
+        Chatmail relay for your new address
+      </span>
+      <button
+        type='button'
+        data-testid='relay-picker-button'
+        className={styles.relayPickerTrigger}
+        onClick={openPicker}
+      >
+        <span className={styles.relayPickerTriggerValue}>
+          {current}
+          {current === defaultHost && (
+            <span className={styles.relayPickerDefaultTag}>default</span>
+          )}
+        </span>
+        <span className={styles.relayPickerTriggerAction}>Change</span>
+      </button>
+    </div>
+  )
+}
diff --git a/packages/frontend/src/components/screens/WelcomeScreen/RelayPickerDialog.tsx b/packages/frontend/src/components/screens/WelcomeScreen/RelayPickerDialog.tsx
new file mode 100644
index 000000000..120289cdd
--- /dev/null
+++ b/packages/frontend/src/components/screens/WelcomeScreen/RelayPickerDialog.tsx
@@ -0,0 +1,238 @@
+import React, { useEffect, useRef, useState } from 'react'
+
+import Dialog, { DialogBody, DialogContent, DialogHeader } from '../../Dialog'
+import { probeRelay } from './relayDirectory'
+import { normalizeRelayHost } from './relayDirectoryParse'
+import styles from './styles.module.scss'
+
+import type { DialogProps } from '../../../contexts/DialogContext'
+import type { RelayProbe } from './relayDirectory'
+
+// English is hardcoded here (like the rest of patch desktop/0042) so the relay
+// picker stays a self-contained patch and doesn't have to touch every locale
+// file. See PATCHES.md.
+
+type Props = {
+  /** the pickable relays, default relay first (from the directory) */
+  relays: string[]
+  /** the instance's default relay — always selectable, tagged, never "down" */
+  defaultHost: string
+  /** the relay currently in effect (a directory relay, the default, or a
+   * previously-typed custom host) */
+  selectedHost: string
+  /** commit a choice; `undefined` means "use the default" */
+  onSelect: (host?: string) => void
+}
+
+/** A round-trip time bucket, just for the colour of the signal dot. */
+function latencyClass(ms: number): string {
+  if (ms < 100) return styles.relayDialogDotGood
+  if (ms < 250) return styles.relayDialogDotOkay
+  return styles.relayDialogDotSlow
+}
+
+/**
+ * slothfulchat-web: the "choose a chatmail relay" dialog opened from the
+ * instant-onboarding relay picker. A dialog (rather than an inline dropdown,
+ * which clipped against the onboarding dialog's edge) gives the relay list room
+ * to show live per-relay state: a spinner while probing, a round-trip latency
+ * when the relay answers on its IMAPS port over the bridge, or greyed-out and
+ * unselectable when the bridge can't reach it. Relays that resolve but can't be
+ * measured (an allowlisted hosted bridge blocks the probe) stay selectable but
+ * are shown as "unknown", never as a false success. An "Other…" field accepts
+ * any chatmail relay by hostname.
+ */
+export default function RelayPickerDialog({
+  relays,
+  defaultHost,
+  selectedHost,
+  onSelect,
+  onClose,
+}: Props & DialogProps) {
+  const [probes, setProbes] = useState<Record<string, RelayProbe>>({})
+  const [customOpen, setCustomOpen] = useState(false)
+  const [customInput, setCustomInput] = useState('')
+  const [customError, setCustomError] = useState(false)
+
+  const mountedRef = useRef(true)
+  const probedRef = useRef<Set<string>>(new Set())
+  useEffect(() => {
+    mountedRef.current = true
+    return () => {
+      mountedRef.current = false
+    }
+  }, [])
+
+  // A previously-chosen custom host isn't in the directory; show it too.
+  const hosts =
+    selectedHost !== defaultHost && !relays.includes(selectedHost)
+      ? [...relays, selectedHost]
+      : relays
+
+  // Opening the dialog IS the intent to choose, so probe every relay now — but
+  // through a small worker pool, not all at once: each probe opens a WebSocket
+  // to the bridge (a /dns then a /tcp), so firing a whole directory in parallel
+  // would flood a single-process local bridge (and could starve the runtime's
+  // own bridge health check). A handful in flight fills the list fast enough.
+  useEffect(() => {
+    let cancelled = false
+    const queue = hosts.filter(host => !probedRef.current.has(host))
+    queue.forEach(host => probedRef.current.add(host))
+    const CONCURRENCY = 5
+    let next = 0
+    const worker = async (): Promise<void> => {
+      while (!cancelled && next < queue.length) {
+        const host = queue[next++]
+        const probe = await probeRelay(host)
+        if (!cancelled && mountedRef.current) {
+          setProbes(prev => ({ ...prev, [host]: probe }))
+        }
+      }
+    }
+    for (let i = 0; i < Math.min(CONCURRENCY, queue.length); i++) {
+      void worker()
+    }
+    return () => {
+      cancelled = true
+    }
+    // hosts is derived from immutable props; probe once on open
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [])
+
+  const isSelectable = (host: string) =>
+    host === defaultHost || probes[host]?.status !== 'unreachable'
+
+  const choose = (host: string) => {
+    if (!isSelectable(host)) {
+      return
+    }
+    onSelect(host === defaultHost ? undefined : host)
+    onClose()
+  }
+
+  const submitCustom = () => {
+    const host = normalizeRelayHost(customInput)
+    if (!host) {
+      setCustomError(true)
+      return
+    }
+    onSelect(host === defaultHost ? undefined : host)
+    onClose()
+  }
+
+  const renderStatus = (host: string) => {
+    const probe = probes[host]
+    if (!probe) {
+      // sonar ping while this relay is being probed over the bridge
+      return (
+        <span className={styles.relayDialogPing} aria-hidden='true'>
+          <span className={styles.relayDialogPingRing} />
+          <span className={styles.relayDialogPingRing} />
+        </span>
+      )
+    }
+    if (probe.status === 'unreachable' || probe.latencyMs === null) {
+      return <span className={styles.relayDialogUnreachable}>unreachable</span>
+    }
+    return (
+      <span className={styles.relayDialogLatency}>
+        <span
+          className={`${styles.relayDialogDot} ${latencyClass(probe.latencyMs)}`}
+          aria-hidden='true'
+        />
+        {probe.latencyMs} ms
+      </span>
+    )
+  }
+
+  return (
+    <Dialog onClose={onClose} width={400}>
+      <DialogHeader title='Choose a chatmail relay' onClose={onClose} />
+      <DialogBody>
+        <DialogContent>
+          <div className={styles.relayDialogList} role='listbox'>
+            {hosts.map(host => (
+              <button
+                type='button'
+                key={host}
+                role='option'
+                aria-selected={host === selectedHost}
+                aria-disabled={!isSelectable(host)}
+                data-testid={`relay-option-${host}`}
+                disabled={!isSelectable(host)}
+                className={[
+                  styles.relayDialogRow,
+                  host === selectedHost ? styles.relayDialogRowSelected : '',
+                  !isSelectable(host) ? styles.relayDialogRowDisabled : '',
+                ]
+                  .filter(Boolean)
+                  .join(' ')}
+                onClick={() => choose(host)}
+              >
+                <span className={styles.relayDialogHost}>
+                  {host === selectedHost && (
+                    <span className={styles.relayDialogCheck} aria-hidden='true'>
+                      ✓{' '}
+                    </span>
+                  )}
+                  {host}
+                  {host === defaultHost && (
+                    <span className={styles.relayDialogDefaultTag}>default</span>
+                  )}
+                </span>
+                {renderStatus(host)}
+              </button>
+            ))}
+          </div>
+
+          {!customOpen ? (
+            <button
+              type='button'
+              className={styles.relayDialogOther}
+              data-testid='relay-option-other'
+              onClick={() => setCustomOpen(true)}
+            >
+              Other relay…
+            </button>
+          ) : (
+            <div className={styles.relayDialogCustomRow}>
+              <input
+                type='text'
+                autoFocus={true}
+                data-testid='relay-custom-input'
+                className={[
+                  styles.relayDialogCustomInput,
+                  customError ? styles.relayDialogCustomInputError : '',
+                ]
+                  .filter(Boolean)
+                  .join(' ')}
+                placeholder='relay hostname, e.g. chat.example.org'
+                value={customInput}
+                onChange={event => {
+                  setCustomInput(event.target.value)
+                  if (customError) {
+                    setCustomError(false)
+                  }
+                }}
+                onKeyDown={event => {
+                  if (event.key === 'Enter') {
+                    event.preventDefault()
+                    submitCustom()
+                  }
+                }}
+              />
+              <button
+                type='button'
+                data-testid='relay-custom-confirm'
+                className={styles.relayDialogCustomConfirm}
+                onClick={submitCustom}
+              >
+                Use
+              </button>
+            </div>
+          )}
+        </DialogContent>
+      </DialogBody>
+    </Dialog>
+  )
+}
