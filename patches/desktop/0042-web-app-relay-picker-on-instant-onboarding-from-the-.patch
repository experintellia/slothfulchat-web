diff --git a/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx b/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx
new file mode 100644
index 000000000..9d150b44b
--- /dev/null
+++ b/packages/frontend/src/components/screens/WelcomeScreen/RelayPicker.tsx
@@ -0,0 +1,65 @@
+import React, { useEffect, useState } from 'react'
+
+import useInstantOnboarding from '../../../hooks/useInstantOnboarding'
+import { DeltaSelect } from '../../Login-Styles'
+import { defaultRelayHost, fetchSelectableRelays } from './relayDirectory'
+
+/**
+ * slothfulchat-web: dropdown on the instant-onboarding ("create profile")
+ * screen to pick which public chatmail relay the new address is created on.
+ *
+ * The list comes live from the chatmail relay directory, filtered down to
+ * relays the WS→TCP bridge can resolve (see relayDirectory.ts); the default
+ * relay is always offered and listed first. Renders nothing while loading,
+ * when the directory is unavailable, when there is nothing to choose (fewer
+ * than two relays), or when a scanned `dcaccount:`/`dclogin:` QR already pins
+ * the server.
+ */
+export default function RelayPicker() {
+  const { welcomeQr, selectedRelayHost, setSelectedRelayHost } =
+    useInstantOnboarding()
+  const [relays, setRelays] = useState<string[] | null>(null)
+
+  // With a scanned account/login QR the server is fixed — no choice to offer.
+  const relayChoosable =
+    welcomeQr?.qr.kind !== 'account' && welcomeQr?.qr.kind !== 'login'
+
+  useEffect(() => {
+    if (!relayChoosable) {
+      return
+    }
+    let stale = false
+    fetchSelectableRelays().then(list => {
+      if (!stale) {
+        setRelays(list)
+      }
+    })
+    return () => {
+      stale = true
+    }
+  }, [relayChoosable])
+
+  if (!relayChoosable || relays === null || relays.length < 2) {
+    return null
+  }
+
+  const value =
+    selectedRelayHost && relays.includes(selectedRelayHost)
+      ? selectedRelayHost
+      : defaultRelayHost()
+
+  return (
+    <DeltaSelect
+      id='relay-picker'
+      label='Chatmail relay for your new address'
+      value={value}
+      onChange={event => setSelectedRelayHost(event.target.value)}
+    >
+      {relays.map(host => (
+        <option key={host} value={host}>
+          {host}
+        </option>
+      ))}
+    </DeltaSelect>
+  )
+}
