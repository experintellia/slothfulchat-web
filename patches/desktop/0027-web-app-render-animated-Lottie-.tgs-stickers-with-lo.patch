+/**
+ * Whether a message's attachment is a Telegram `.tgs` sticker (gzipped Lottie),
+ * which must be played by the lottie-web renderer rather than shown as an
+ * <img>. Scoped to `.tgs` so message rendering, the composer picker
+ * (`misc_get_stickers`), and "save to collection" all agree on one format.
+ */
+function isLottieStickerFile(
+  message: Pick<T.Message, 'file' | 'fileName' | 'fileMime'>
+): message is typeof message & { file: string } {
+  if (!message.file) {
+    return false
+  }
+  const name = (message.fileName ?? '').toLowerCase()
+  const mime = (message.fileMime ?? '').toLowerCase()
+  return name.endsWith('.tgs') || mime === 'application/x-tgsticker'
+}
+
 export default function Attachment({
   text,
   message,
@@ -152,6 +170,31 @@ export default function Attachment({
     message.dimensionsWidth * message.dimensionsHeight >
       LARGE_IMAGE_PIXEL_THRESHOLD
 
+  // Lottie stickers (gzipped .tgs or plain Lottie .json) can't be shown by an
+  // <img> — they need the lottie-web player. This covers a Sticker viewtype as
+  // well as a stray .tgs that arrived as a plain File (e.g. from a client that
+  // didn't tag it), so it sits ahead of the image/sticker and generic branches.
+  if (isLottieStickerFile(message)) {
+    return (
+      <button
+        type='button'
+        onClick={onClickAttachment}
+        tabIndex={tabindexForInteractiveContents}
+        className={classNames(
+          'message-attachment-media',
+          withCaption ? 'content-below' : null
+        )}
+      >
+        <LottieSticker
+          // remount per file so a recycled row doesn't keep a stale failure
+          key={message.file}
+          src={runtime.transformBlobURL(message.file)}
+          size={maxStickerSize}
+        />
+      </button>
+    )
+  }
+
   if (
     (isImage(message.viewType) || message.viewType === 'Sticker') &&
     !isOversizedImage
