+/**
+ * Wraps the delivery-status icon so that hovering it reveals a popover with the
+ * people who have read the message (avatar + name + relative timestamp). Only
+ * active for the "read" state — other delivery states get the plain icon.
+ */
+function ReadByHoverInfo(props: {
+  messageId: number
+  enabled: boolean
+  children: React.ReactNode
+}) {
+  if (!props.enabled) {
+    return <>{props.children}</>
+  }
+  return (
+    <HoverInfoTrigger
+      align='end'
+      card={<ReadByHoverCard messageId={props.messageId} />}
+    >
+      {props.children}
+    </HoverInfoTrigger>
+  )
+}
+
+function ReadByHoverCard(props: { messageId: number }) {
+  const tx = useTranslationFunction()
+  const accountId = selectedAccountId()
+
