@@ -88,3 +124,60 @@ export default function Reactions(props: Props) {
     </div>
   )
 }
+
+/**
+ * Popover contents for a single reaction (or the "+N" overflow pill): the
+ * people who reacted with any of `emojis`, each with their avatar and name.
+ * When hovering one emoji we show neither a title nor a per-row emoji — the
+ * user already knows which emoji they're pointing at. The overflow pill mixes
+ * several emojis, so it gets a "Reactions" title and shows each reactor's
+ * emoji. Reactors follow the core's most-used-first ordering.
+ */
+function ReactorsHoverCard(props: {
+  reactionsByContact: T.Reactions['reactionsByContact']
+  emojis: string[]
+  title?: React.ReactNode
+  showEmoji: boolean
+}) {
+  const tx = useTranslationFunction()
+  const { reactionsByContact, emojis, showEmoji } = props
+
+  const reactors = useMemo(() => {
+    const entries: { contactId: number; emoji: string }[] = []
+    for (const emoji of emojis) {
+      for (const [contactId, contactEmojis] of Object.entries(
+        reactionsByContact
+      )) {
+        // The dialog and the bubble only ever show a contact's first reaction,
+        // so we mirror that here.
+        if (contactEmojis[0] === emoji) {
+          entries.push({ contactId: Number(contactId), emoji })
+        }
+      }
+    }
+    return entries
+  }, [emojis, reactionsByContact])
+
+  const contacts = useContactsById(reactors.map(r => r.contactId))
+
+  const rows: PersonRow[] = reactors
+    .map(({ contactId, emoji }): PersonRow | null => {
+      const contact = contacts[contactId]
+      if (!contact) {
+        return null
+      }
+      return {
+        key: contactId,
+        contact,
+        detail: showEmoji ? (
+          <span className={styles.hoverEmoji}>{emoji}</span>
+        ) : undefined,
+        detailTitle: showEmoji ? tx('reacted_with', emoji) : undefined,
+      }
+    })
+    .filter((row): row is PersonRow => row !== null)
+
+  const loading = rows.length === 0 && reactors.length > 0
+
+  return <PeopleHoverCard title={props.title} rows={rows} loading={loading} />
+}
