From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: experintellia <280144245+experintellia@users.noreply.github.com>
Date: Tue, 7 Jul 2026 10:03:36 +0000
Subject: [PATCH 09/11] wasm: VFS-agnostic sqlite backup import/export

The backup DB swap was hardwired to MemVfsUtil; with the OPFS sahpool
VFS as default it silently targeted the wrong VFS. Route through the
shim's sqlite_vfs_import/take, which dispatch to whichever VFS is
default.
---
 src/imex.rs | 13 +++++--------
 src/sql.rs  |  8 +++-----
 2 files changed, 8 insertions(+), 13 deletions(-)

diff --git a/src/imex.rs b/src/imex.rs
index 7f44379ff..48055b0d8 100644
--- a/src/imex.rs
+++ b/src/imex.rs
@@ -795,15 +795,12 @@ async fn export_database(
         .ok();
     }
 
-    // Move the bytes from sqlite's in-memory VFS into the tokio memfs.
-    // MemVfsUtil is not Send; keep it inside a sync helper so the future stays Send.
+    // Move the bytes from sqlite's default VFS (memory, or opfs-sahpool when
+    // persistence is enabled) into the tokio memfs so the tar builder can
+    // read them. The helper is sync so the future stays Send.
     fn take_from_sqlite_vfs(name: &str) -> Result<Vec<u8>> {
-        let vfs = rusqlite::ffi::MemVfsUtil::<rusqlite::ffi::WasmOsCallback>::new();
-        let bytes = vfs
-            .export_db(name)
-            .map_err(|e| format_err!("failed to export database from sqlite VFS: {e}"))?;
-        vfs.delete_db(name);
-        Ok(bytes)
+        tokio::fs::sqlite_vfs_take(name)
+            .map_err(|e| format_err!("failed to export database from sqlite VFS: {e}"))
     }
     let bytes = take_from_sqlite_vfs(&dest_str)?;
     fs::write(dest, bytes).await?;
diff --git a/src/sql.rs b/src/sql.rs
index 1789da41c..433cfacf1 100644
--- a/src/sql.rs
+++ b/src/sql.rs
@@ -152,11 +152,9 @@ pub(crate) async fn import(&self, path: &Path, passphrase: String) -> Result<()>
         let mut pool = self.pool.write().await;
         pool.take(); // dropping the pool closes all connections
 
-        let vfs = rusqlite::ffi::MemVfsUtil::<rusqlite::ffi::WasmOsCallback>::new();
-        vfs.delete_db(&dbfile);
-        vfs.delete_db(&format!("{dbfile}-wal"));
-        vfs.delete_db(&format!("{dbfile}-journal"));
-        vfs.import_db(&dbfile, &bytes)
+        // dispatches to whichever VFS is the sqlite default (memory, or
+        // opfs-sahpool when persistence is enabled)
+        tokio::fs::sqlite_vfs_import(&dbfile, &bytes)
             .map_err(|e| anyhow::anyhow!("failed to import database into sqlite VFS: {e}"))?;
 
         *pool = Some(Self::new_pool(&self.dbfile, passphrase)?);
