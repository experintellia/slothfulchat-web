+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn test_admin_group_permissions() -> Result<()> {
+    let mut tcm = TestContextManager::new();
+    let alice = &tcm.alice().await;
+    let bob = &tcm.bob().await;
+    let charlie = &tcm.charlie().await;
+
+    let alice_chat_id = create_group_with_admin(alice, "Admin group").await?;
+    let alice_chat = Chat::load_from_db(alice, alice_chat_id).await?;
+    assert_eq!(
+        get_admin_contact_id(alice, &alice_chat.grpid).await?,
+        Some(ContactId::SELF)
+    );
+
+    let alice_bob = alice.add_or_lookup_contact_id(bob).await;
+    add_contact_to_chat(alice, alice_chat_id, alice_bob).await?;
+    let sent = alice.send_text(alice_chat_id, "welcome").await;
+    let bob_rcvd = bob.recv_msg(&sent).await;
+    let bob_chat_id = bob_rcvd.chat_id;
+    bob_chat_id.accept(bob).await?;
+
+    // Bob sees Alice as the admin.
+    let bob_chat = Chat::load_from_db(bob, bob_chat_id).await?;
+    let bob_alice = bob.add_or_lookup_contact_id(alice).await;
+    assert_eq!(
+        get_admin_contact_id(bob, &bob_chat.grpid).await?,
+        Some(bob_alice)
+    );
+
+    // Non-admin group management is rejected.
+    let bob_charlie = bob.add_or_lookup_contact_id(charlie).await;
+    assert!(
+        add_contact_to_chat(bob, bob_chat_id, bob_charlie)
+            .await
+            .is_err()
+    );
+    assert!(set_chat_name(bob, bob_chat_id, "hijacked").await.is_err());
+    assert!(
+        set_chat_description(bob, bob_chat_id, "hijacked")
+            .await
+            .is_err()
+    );
+    assert!(
+        bob_chat_id
+            .set_ephemeral_timer(bob, crate::ephemeral::Timer::Enabled { duration: 60 })
+            .await
+            .is_err()
+    );
+    assert!(
+        remove_contact_from_chat(bob, bob_chat_id, bob_alice)
+            .await
+            .is_err()
+    );
+
+    // ...but the admin can do all of that.
+    set_chat_name(alice, alice_chat_id, "Admin group 2").await?;
+
+    // Members can chat.
+    let bob_sent = bob.send_text(bob_chat_id, "hi all").await;
+    let alice_bob_msg = alice.recv_msg(&bob_sent).await;
+
+    // A non-admin cannot delete others' messages for everyone...
+    assert!(
+        message::delete_msgs_ex(bob, &[bob_rcvd.id], true)
+            .await
+            .is_err()
+    );
+    // ...the admin can, and the deletion is applied on the member's device.
+    let bob_cnt = bob_chat_id.get_msg_cnt(bob).await?;
+    message::delete_msgs_ex(alice, &[alice_bob_msg.id], true).await?;
+    let del = alice.pop_sent_msg().await;
+    bob.recv_msg_opt(&del).await;
+    assert_eq!(bob_chat_id.get_msg_cnt(bob).await?, bob_cnt - 1);
+
+    // A non-admin can still leave on their own,
+    // and the admin's device applies it.
+    remove_contact_from_chat(bob, bob_chat_id, ContactId::SELF).await?;
+    assert!(!is_contact_in_chat(bob, bob_chat_id, ContactId::SELF).await?);
+    let leave = bob.pop_sent_msg().await;
+    alice.recv_msg_opt(&leave).await;
+    assert!(!is_contact_in_chat(alice, alice_chat_id, alice_bob).await?);
+
+    // In REGULAR groups others' messages still cannot be deleted for
+    // everyone (deviation from ArcaneChat, which dropped this check).
+    let reg_chat_id = create_group(alice, "regular").await?;
+    add_contact_to_chat(alice, reg_chat_id, alice_bob).await?;
+    let reg_sent = alice.send_text(reg_chat_id, "regular group").await;
+    let bob_reg_rcvd = bob.recv_msg(&reg_sent).await;
+    bob_reg_rcvd.chat_id.accept(bob).await?;
+    let bob_reg_sent = bob.send_text(bob_reg_rcvd.chat_id, "mine").await;
+    let alice_reg_bob_msg = alice.recv_msg(&bob_reg_sent).await;
+    assert!(
+        message::delete_msgs_ex(alice, &[alice_reg_bob_msg.id], true)
+            .await
+            .is_err()
+    );
+
+    Ok(())
+}
+
+/// Not a test: generates the two-account demo state used for the admin-groups
+/// screenshots (see scripts/shot-group-admins.mjs) and exports both accounts
+/// as backups. Run on demand:
+/// `DEMO_OUT=/tmp/demo cargo test test_admin_group_demo_backups -- --ignored`
+#[ignore = "demo-state generator, needs DEMO_OUT"]
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn test_admin_group_demo_backups() -> Result<()> {
+    let out = std::env::var("DEMO_OUT").expect("set DEMO_OUT to an output directory");
+    let out = std::path::Path::new(&out);
+    let mut tcm = TestContextManager::new();
+    let alice = &tcm.alice().await;
+    let bob = &tcm.bob().await;
+    alice
+        .set_config(Config::Displayname, Some("Alice"))
+        .await?;
+    bob.set_config(Config::Displayname, Some("Bob")).await?;
+
+    let chat_id = create_group_with_admin(alice, "Sloth Lounge").await?;
+    let alice_bob = alice.add_or_lookup_contact_id(bob).await;
+    add_contact_to_chat(alice, chat_id, alice_bob).await?;
+
+    let sent = alice
+        .send_text(chat_id, "Welcome to the Sloth Lounge! 🦥").await;
+    let bob_rcvd = bob.recv_msg(&sent).await;
+    bob_rcvd.chat_id.accept(bob).await?;
+    let bob_sent = bob.send_text(bob_rcvd.chat_id, "Hi all, Bob here!").await;
+    alice.recv_msg(&bob_sent).await;
+    let sent2 = alice
+        .send_text(
+            chat_id,
+            "I'm the group admin: only I can rename the group, manage members or remove messages.",
+        )
+        .await;
+    bob.recv_msg(&sent2).await;
+
+    let alice_dir = out.join("alice");
+    let bob_dir = out.join("bob");
+    std::fs::create_dir_all(&alice_dir)?;
+    std::fs::create_dir_all(&bob_dir)?;
+    imex(alice, ImexMode::ExportBackup, &alice_dir, None).await?;
+    imex(bob, ImexMode::ExportBackup, &bob_dir, None).await?;
+    Ok(())
+}
