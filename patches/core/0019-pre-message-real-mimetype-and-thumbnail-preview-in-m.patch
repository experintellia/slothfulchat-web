+    /// Best-effort small preview JPEG (base64) for image-like and webxdc messages.
+    ///
+    /// A preview is never worth failing a send over, so every failure path warns and
+    /// yields `None`. Video/Audio/File get no thumbnail (frame extraction = new dep).
+    async fn thumbnail(context: &Context, message: &Message) -> Option<String> {
+        let bytes = match message.viewtype {
+            Viewtype::Image | Viewtype::Gif | Viewtype::Sticker => {
+                let path = message.get_file(context)?;
+                // read_file is wasm-safe and warns on failure itself.
+                crate::tools::read_file(context, &path).await.ok()?
+            }
+            Viewtype::Webxdc => {
+                let info = message.get_webxdc_info(context).await.ok()?;
+                match message.get_webxdc_blob(context, &info.icon).await {
+                    Ok(bytes) => bytes,
+                    Err(err) => {
+                        warn!(context, "Thumbnail: failed to read webxdc icon: {err:#}.");
+                        return None;
+                    }
+                }
+            }
+            _ => return None,
+        };
+        match crate::blob::thumbnail_base64(context, &bytes) {
+            Ok(thumbnail) => thumbnail,
+            Err(err) => {
+                warn!(context, "Thumbnail: failed to encode preview: {err:#}.");
+                None
+            }
+        }
+    }
+
     pub(crate) fn to_header_value(&self) -> Result<String> {
         Ok(serde_json::to_string(&self)?)
