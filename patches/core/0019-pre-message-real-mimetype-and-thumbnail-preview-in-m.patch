+/// Happy path: a large image placeholder carries a real mime and a decodable JPEG preview, and the
+/// arriving post-message replaces both with the real attachment.
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn test_receive_pre_message_image_preview() -> Result<()> {
+    let mut tcm = TestContextManager::new();
+    let alice = &tcm.alice().await;
+    let bob = &tcm.bob().await;
+    let alice_group_id = alice.create_group_with_members("test group", &[bob]).await;
+
+    let (pre_message, post_message, _alice_msg_id) =
+        send_large_image_message(alice, alice_group_id).await?;
+
+    let msg = bob.recv_msg(&pre_message).await;
+    assert_eq!(msg.download_state(), DownloadState::Available);
+    assert_eq!(msg.viewtype, Viewtype::Text);
+
+    // Real mime is set on the placeholder (images are recoded to JPEG when sent).
+    assert_eq!(msg.param.get(Param::MimeType), Some("image/jpeg"));
+    assert_eq!(msg.get_filemime().as_deref(), Some("image/jpeg"));
+
+    // `Param::File` holds the preview: a decodable JPEG no larger than 128px per edge.
+    let preview_path = msg.get_file(bob).context("placeholder has a preview file")?;
+    let preview_bytes = tokio::fs::read(&preview_path).await?;
+    assert_eq!(image::guess_format(&preview_bytes)?, image::ImageFormat::Jpeg);
+    let preview = image::load_from_memory(&preview_bytes)?;
+    assert!(preview.width() <= 128 && preview.height() <= 128);
+
+    // The post-message replaces preview + mime with the real attachment.
+    bob.recv_msg_trash(&post_message).await;
+    let msg = Message::load_from_db(bob, msg.id).await?;
+    assert_eq!(msg.download_state(), DownloadState::Done);
+    assert_eq!(msg.viewtype, Viewtype::Image);
+    assert_eq!(msg.get_filemime().as_deref(), Some("image/jpeg"));
+    let real_path = msg.get_file(bob).context("downloaded message has a file")?;
+    assert_ne!(real_path, preview_path);
+    let real = image::load_from_memory(&tokio::fs::read(&real_path).await?)?;
+    assert!(real.width() > 128 || real.height() > 128, "real image is full size");
+
+    Ok(())
+}
