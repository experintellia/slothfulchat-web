+/// Encodes a small JPEG thumbnail (longest edge 128px, quality 40) of `bytes` as base64.
+///
+/// `bytes` may be any image the `image` crate can guess (in-memory, so it also works for the
+/// webxdc app icon). Returns `Ok(None)` if the encoded thumbnail exceeds the size cap; an error
+/// only on decode/encode failure. Callers treat every non-`Some` outcome as "no preview" and
+/// never fail a send over it.
+pub(crate) fn thumbnail_base64(context: &Context, bytes: &[u8]) -> Result<Option<String>> {
+    // Same rationale as `constants::WORSE_AVATAR_BYTES`: a preview small enough to inline in the
+    // encrypted metadata header without bloating the pre-message.
+    const MAX_THUMBNAIL_BYTES: usize = 20_000;
+    tokio::task::block_in_place(|| {
+        let mut img = ImageReader::new(Cursor::new(bytes))
+            .with_guessed_format()?
+            .decode()
+            .context("thumbnail decode failure")?
+            .thumbnail(128, 128);
+        // JPEG has no alpha channel; flatten transparency onto white so it isn't rendered black.
+        if img.color().has_alpha() {
+            add_white_bg(&mut img);
+        }
+        let mut encoded = Vec::new();
+        encode_img(&img, ImageOutputFormat::Jpeg { quality: 40 }, &mut encoded)?;
+        if encoded.len() > MAX_THUMBNAIL_BYTES {
+            warn!(
+                context,
+                "Thumbnail {}B exceeds {}B cap, dropping preview.",
+                encoded.len(),
+                MAX_THUMBNAIL_BYTES
+            );
+            return Ok(None);
+        }
+        Ok(Some(
+            base64::engine::general_purpose::STANDARD.encode(&encoded),
+        ))
+    })
+}
