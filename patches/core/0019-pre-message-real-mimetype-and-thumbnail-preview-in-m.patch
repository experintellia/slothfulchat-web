+/// E9 lifecycle: the preview blob is a normal `Param::File` blob, so housekeeping GCs it once the
+/// placeholder is deleted or the post-message overwrites it, while the real file is kept.
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn test_pre_message_thumbnail_housekeeping() -> Result<()> {
+    let mut tcm = TestContextManager::new();
+    let alice = &tcm.alice().await;
+    let bob = &tcm.bob().await;
+    let alice_group_id = alice.create_group_with_members("test group", &[bob]).await;
+
+    // The three cases use content-distinct images so their preview blobs don't dedup into one
+    // shared file; otherwise a broken GC path could hide behind a still-referenced sibling blob.
+
+    // Case A: deleted placeholder -> preview blob becomes unreferenced.
+    let (pre_a, _post_a, _) = send_large_image_message_sized(alice, alice_group_id, 1080, 1920).await?;
+    let msg_a = bob.recv_msg(&pre_a).await;
+    let preview_a = msg_a.get_file(bob).context("preview A exists")?;
+    assert!(tokio::fs::try_exists(&preview_a).await?);
+    delete_msgs(bob, &[msg_a.id]).await?;
+
+    // Case B: post-message overwrites the preview -> old preview unreferenced, real file kept.
+    let (pre_b, post_b, _) = send_large_image_message_sized(alice, alice_group_id, 1200, 2000).await?;
+    let msg_b = bob.recv_msg(&pre_b).await;
+    let preview_b = msg_b.get_file(bob).context("preview B exists")?;
+    assert!(tokio::fs::try_exists(&preview_b).await?);
+    bob.recv_msg_trash(&post_b).await;
+    let msg_b = Message::load_from_db(bob, msg_b.id).await?;
+    assert_eq!(msg_b.download_state(), DownloadState::Done);
+    let real_b = msg_b.get_file(bob).context("real file B exists")?;
+    assert_ne!(real_b, preview_b);
+
+    // Case C: a live placeholder that is neither deleted nor downloaded -> its preview must SURVIVE
+    // housekeeping (its Param::File is still referenced from a type=Text row).
+    let (pre_c, _post_c, _) = send_large_image_message_sized(alice, alice_group_id, 1400, 1600).await?;
+    let msg_c = bob.recv_msg(&pre_c).await;
+    assert_eq!(msg_c.download_state(), DownloadState::Available);
+    let preview_c = msg_c.get_file(bob).context("preview C exists")?;
+    assert!(tokio::fs::try_exists(&preview_c).await?);
+    assert_ne!(preview_c, preview_a);
+    assert_ne!(preview_c, preview_b);
+
+    // Age all blobs past the 1h grace and run housekeeping.
+    SystemTime::shift(Duration::from_secs(65 * 60));
+    crate::sql::housekeeping(bob).await?;
+
+    assert!(!tokio::fs::try_exists(&preview_a).await?, "deleted placeholder's preview GC'd");
+    assert!(!tokio::fs::try_exists(&preview_b).await?, "overwritten preview GC'd");
+    assert!(tokio::fs::try_exists(&real_b).await?, "real downloaded file kept");
+    assert!(tokio::fs::try_exists(&preview_c).await?, "live placeholder's preview survives housekeeping");
+
+    Ok(())
+}
