@@ -111,17 +153,75 @@ pub(crate) fn apply_post_msg_metadata(
     }
 }
 
+/// Applies a received Pre-Message's metadata to `param`, including the parts that need the
+/// [`Context`]: the real MIME type and the optional preview thumbnail.
+///
+/// The thumbnail base64 is attacker-controlled, so its length is capped before decoding and it is
+/// stored as a normal `Param::File` blob. A preview is never worth failing receipt over: every
+/// failure warns and leaves the placeholder without a preview.
+pub(crate) fn apply_received_metadata(
+    context: &Context,
+    param: &mut Params,
+    metadata: &PostMsgMetadata,
+) {
+    param.apply_post_msg_metadata(metadata);
+    // Make jsonrpc `fileMime` real on placeholders (guaranteed value from the sender).
+    param.set_optional(Param::MimeType, metadata.mime.as_deref());
+    let Some(thumbnail) = &metadata.thumbnail else {
+        return;
+    };
+    // Trust boundary: the base64 is attacker-controlled, so cap its length before decoding.
+    // 60_000 chars ~ 45 KiB decoded, well above our 20_000-byte send cap.
+    if thumbnail.len() > 60_000 {
+        warn!(
+            context,
+            "Pre-message thumbnail too large ({} chars), ignoring.",
+            thumbnail.len()
+        );
+        return;
+    }
+    // ponytail: deliberate mismatch — `file` holds the preview JPEG while `fileMime` names the
+    // real target mime. The frontend renders `file` as a preview while downloadState != Done; the
+    // arriving post-message then overwrites `file`/`fileMime` with the real attachment.
+    match crate::blob::BlobObject::store_from_base64(context, thumbnail) {
+        Ok(Some(name)) => {
+            param.set(Param::File, name);
+        }
+        Ok(None) => warn!(
+            context,
+            "Pre-message thumbnail: invalid base64, placeholder without preview."
+        ),
+        Err(err) => warn!(context, "Pre-message thumbnail: failed to store: {err:#}."),
+    }
+}
