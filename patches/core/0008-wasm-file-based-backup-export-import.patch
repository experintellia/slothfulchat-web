     /// Imports the database from a separate file with the given passphrase.
+    ///
+    /// wasm variant: sqlite on wasm (sqlite-wasm-rs) has no `sqlcipher_export()`,
+    /// so instead of copying table-by-table into the open database we close the
+    /// pool, swap the database file bytes inside sqlite's in-memory VFS and reopen.
+    /// ponytail: encrypted backups are unsupported on wasm (needs sqlcipher);
+    /// the main database on wasm is always unencrypted.
+    #[cfg(target_arch = "wasm32")]
+    pub(crate) async fn import(&self, path: &Path, passphrase: String) -> Result<()> {
+        anyhow::ensure!(
+            passphrase.is_empty(),
+            "encrypted backups are not supported on wasm"
+        );
+        let dbfile = self
+            .dbfile
+            .to_str()
+            .with_context(|| format!("path {:?} is not valid unicode", self.dbfile))?
+            .to_string();
+        let bytes = tokio::fs::read(path)
+            .await
+            .context("failed to read unpacked backup database")?;
+
+        // Keep `config_cache` locked all the time the db is imported so that nobody can use
+        // invalid values from there. And clear it immediately so as not to forget in case of errors.
+        let mut config_cache = self.config_cache.write().await;
+        config_cache.clear();
+
+        let mut pool = self.pool.write().await;
+        pool.take(); // dropping the pool closes all connections
+
+        let vfs = rusqlite::ffi::MemVfsUtil::<rusqlite::ffi::WasmOsCallback>::new();
+        vfs.delete_db(&dbfile);
+        vfs.delete_db(&format!("{dbfile}-wal"));
+        vfs.delete_db(&format!("{dbfile}-journal"));
+        vfs.import_db(&dbfile, &bytes)
+            .map_err(|e| anyhow::anyhow!("failed to import database into sqlite VFS: {e}"))?;
+
+        *pool = Some(Self::new_pool(&self.dbfile, passphrase)?);
+        Ok(())
+    }
+
