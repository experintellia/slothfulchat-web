 /// overwritten.
 ///
 /// This also verifies that IO is not running during the export.
+///
+/// wasm variant: sqlite on wasm (sqlite-wasm-rs) has no `sqlcipher_export()`,
+/// so we `VACUUM INTO` sqlite's in-memory VFS and then copy the bytes over
+/// into the tokio memfs so the tar builder can read them.
+/// ponytail: encrypted export is unsupported on wasm (needs sqlcipher).
+#[cfg(target_arch = "wasm32")]
+async fn export_database(
+    context: &Context,
+    dest: &Path,
+    passphrase: String,
+    timestamp: i64,
+) -> Result<()> {
+    ensure!(
+        !context.scheduler.is_running().await,
+        "cannot export backup, IO is running"
+    );
+    ensure!(
+        passphrase.is_empty(),
+        "encrypted backup export is not supported on wasm"
+    );
+    let timestamp = timestamp.try_into().context("32-bit UNIX time overflow")?;
+    let dest_str = dest
+        .to_str()
+        .with_context(|| format!("path {} is not valid unicode", dest.display()))?
+        .to_string();
+
+    context.set_config(Config::BccSelf, Some("1")).await?;
+    context
+        .sql
+        .set_raw_config_int("backup_time", timestamp)
+        .await?;
+    context
+        .sql
+        .set_raw_config_int("backup_version", DCBACKUP_VERSION)
+        .await?;
+    sql::housekeeping(context).await.log_err(context).ok();
+    let vacuum_dest = dest_str.clone();
+    context
+        .sql
+        .call_write(move |conn| {
+            conn.execute("VACUUM INTO ?", (vacuum_dest,))
+                .context("failed to VACUUM INTO backup database")?;
+            Ok(())
+        })
+        .await?;
+
+    // Downgrade verified_one_on_one_chats in the backup, like the native version.
+    // Deprecated 2025-07. If verified_one_on_one_chats was not set, this errors, which we ignore.
+    if let Ok(conn) = rusqlite::Connection::open(&dest_str) {
+        conn.execute(
+            "UPDATE config SET value='0' WHERE keyname='verified_one_on_one_chats';",
+            [],
+        )
+        .ok();
+    }
+
+    // Move the bytes from sqlite's in-memory VFS into the tokio memfs.
+    // MemVfsUtil is not Send; keep it inside a sync helper so the future stays Send.
+    fn take_from_sqlite_vfs(name: &str) -> Result<Vec<u8>> {
+        let vfs = rusqlite::ffi::MemVfsUtil::<rusqlite::ffi::WasmOsCallback>::new();
+        let bytes = vfs
+            .export_db(name)
+            .map_err(|e| format_err!("failed to export database from sqlite VFS: {e}"))?;
+        vfs.delete_db(name);
+        Ok(bytes)
+    }
+    let bytes = take_from_sqlite_vfs(&dest_str)?;
+    fs::write(dest, bytes).await?;
+    Ok(())
+}
