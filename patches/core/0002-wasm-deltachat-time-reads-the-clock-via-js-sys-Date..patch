From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: experintellia <280144245+experintellia@users.noreply.github.com>
Date: Mon, 6 Jul 2026 00:57:11 +0000
Subject: [PATCH 02/20] wasm: deltachat-time reads the clock via js-sys
 Date.now()

SystemTime::now() panics on wasm32-unknown-unknown; UNIX_EPOCH + Duration
from the JS clock does not.
---
 deltachat-time/Cargo.toml |  3 +++
 deltachat-time/src/lib.rs | 13 ++++++++++++-
 2 files changed, 15 insertions(+), 1 deletion(-)

diff --git a/deltachat-time/Cargo.toml b/deltachat-time/Cargo.toml
index a2931d726..7055fb985 100644
--- a/deltachat-time/Cargo.toml
+++ b/deltachat-time/Cargo.toml
@@ -6,3 +6,6 @@ edition = "2021"
 license = "MPL-2.0"
 
 [dependencies]
+
+[target.'cfg(target_arch = "wasm32")'.dependencies]
+js-sys = "0.3"
diff --git a/deltachat-time/src/lib.rs b/deltachat-time/src/lib.rs
index b3b8b2a21..a40a75f0b 100644
--- a/deltachat-time/src/lib.rs
+++ b/deltachat-time/src/lib.rs
@@ -13,7 +13,18 @@ impl SystemTimeTools {
     pub const UNIX_EPOCH: SystemTime = SystemTime::UNIX_EPOCH;
 
     pub fn now() -> SystemTime {
-        return SystemTime::now() + *SYSTEM_TIME_SHIFT.read().unwrap();
+        return Self::system_now() + *SYSTEM_TIME_SHIFT.read().unwrap();
+    }
+
+    #[cfg(not(target_arch = "wasm32"))]
+    fn system_now() -> SystemTime {
+        SystemTime::now()
+    }
+
+    /// `SystemTime::now()` panics on wasm32-unknown-unknown; epoch + JS clock doesn't.
+    #[cfg(target_arch = "wasm32")]
+    fn system_now() -> SystemTime {
+        SystemTime::UNIX_EPOCH + Duration::from_millis(js_sys::Date::now() as u64)
     }
 
     /// Simulates a system clock forward adjustment by `duration`.
