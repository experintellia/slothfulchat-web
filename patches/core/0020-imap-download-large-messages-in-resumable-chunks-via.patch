+
+/// Tests that `remove_unused_files` keeps the staging file of a pending chunked
+/// download (there is a `download` row whose message is still sitting in `imap`
+/// with a non-empty `target`), while an orphaned staging file with no matching
+/// `download`/`imap` rows is removed as usual.
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn test_housekeeping_keeps_pending_download_staging() -> Result<()> {
+    let t = TestContext::new().await;
+
+    let transport_id = 1;
+    let folder = "INBOX";
+    let uidvalidity = 33;
+    let uid = 7;
+    let rfc724_mid = "staging-test@example.org";
+
+    t.sql
+        .execute(
+            "INSERT INTO download (rfc724_mid, msg_id) VALUES (?, 0)",
+            (rfc724_mid,),
+        )
+        .await?;
+    t.sql
+        .execute(
+            "INSERT INTO imap (transport_id, rfc724_mid, folder, target, uid, uidvalidity)
+             VALUES (?, ?, ?, 'INBOX', ?, ?)",
+            (transport_id, rfc724_mid, folder, uid, uidvalidity),
+        )
+        .await?;
+
+    let referenced_name =
+        crate::download::StagingFile::name(transport_id, folder, uidvalidity, uid);
+    let referenced_path = t.get_blobdir().join(&referenced_name);
+    tokio::fs::write(&referenced_path, b"partial data").await?;
+
+    // No download/imap rows reference this one.
+    let orphan_path = t.get_blobdir().join("partial-t9-deadbeef-v1-u1");
+    tokio::fs::write(&orphan_path, b"orphaned data").await?;
+
+    // Push the housekeeping "not modified for the last hour" cutoff into the future,
+    // so both files (whose real mtimes are "now") count as stale without needing to
+    // touch the filesystem clock, same trick as `blob_tests::test_create_and_deduplicate_from_bytes`.
+    SystemTime::shift(Duration::from_secs(65 * 60));
+
+    remove_unused_files(&t).await?;
+
+    assert!(
+        referenced_path.exists(),
+        "staging file of a pending chunked download was deleted by housekeeping"
+    );
+    assert!(
+        !orphan_path.exists(),
+        "orphaned staging file was not cleaned up by housekeeping"
+    );
+
+    Ok(())
+}
