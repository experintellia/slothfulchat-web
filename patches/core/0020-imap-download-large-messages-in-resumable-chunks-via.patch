+    #[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+    async fn test_chunked_fetch_happy_path() -> Result<()> {
+        let mut tcm = TestContextManager::new();
+        let (t, msg_id) = real_msg_id(&mut tcm).await?;
+        t.evtracker.clear_events();
+
+        let data = fake_message(1_048_576); // 1 MiB
+        let mut staging = open_staging(&t, 1).await;
+        let fetcher = FakeFetcher::new(data.clone());
+        let calls = fetcher.calls_handle();
+
+        let outcome = chunked_fetch_loop(
+            &t,
+            &mut staging,
+            Some(data.len() as u64),
+            Some(msg_id),
+            fetcher,
+        )
+        .await?;
+        let ChunkOutcome::Complete(body) = outcome else {
+            panic!("expected Complete");
+        };
+        assert_eq!(body, data);
+
+        // Adaptive doubling: 128K, 256K, 512K, 1024K, terminated by the
+        // short final chunk (only 128K left of the 1 MiB message).
+        assert_eq!(
+            *calls.lock().unwrap(),
+            vec![
+                (0, 128 * 1024),
+                (128 * 1024, 256 * 1024),
+                (384 * 1024, 512 * 1024),
+                (896 * 1024, 1024 * 1024),
+            ]
+        );
+
+        let permilles: Vec<u16> = t
+            .evtracker
+            .take_events()
+            .into_iter()
+            .filter_map(|ev| match ev.typ {
+                EventType::DownloadProgress {
+                    msg_id: id,
+                    permille,
+                } if id == msg_id => Some(permille),
+                _ => None,
+            })
+            .collect();
+        assert_eq!(permilles, vec![125, 375, 875, 999]);
+        assert!(permilles.windows(2).all(|w| w[0] <= w[1]));
+        assert!(permilles.iter().all(|&p| p <= 999));
+
+        Ok(())
+    }
