+        &mut self,
+        uid: u32,
+        offset: u32,
+        count: u32,
+    ) -> Result<PartialFetchResult> {
+        let query = format!("(BODY.PEEK[]<{offset}.{count}>)");
+        // NB: async-imap terminates a FETCH response stream at the tagged
+        // response without surfacing its NO/BAD status, so a rejected
+        // partial FETCH normally shows up as an EMPTY stream (`Gone`) —
+        // the caller re-probes the UID to distinguish "message gone" from
+        // "partial FETCH rejected". The `Error::No`/`Error::Bad` arms below
+        // are defensive, for error paths that do surface them.
+        let mut list = match self.uid_fetch(uid.to_string(), &query).await {
+            Ok(list) => list,
+            Err(async_imap::error::Error::No(_) | async_imap::error::Error::Bad(_)) => {
+                return Ok(PartialFetchResult::Unsupported);
+            }
+            Err(err) => {
+                return Err(err).with_context(|| format!("partial fetch of UID {uid}"));
+            }
+        };
+
+        let mut result = PartialFetchResult::Gone;
+        loop {
+            match list.try_next().await {
+                Ok(Some(msg)) => {
+                    // A response for our UID without a body section is
+                    // unsolicited (e.g. a flag change); keep waiting.
+                    if msg.uid == Some(uid)
+                        && matches!(result, PartialFetchResult::Gone)
+                        && let Some(data) = partial_fetch_data(&msg)
+                    {
+                        result = PartialFetchResult::Data {
+                            origin: msg.body_origin(),
+                            bytes: data,
+                        };
+                    }
+                }
+                Ok(None) => break,
+                Err(async_imap::error::Error::No(_) | async_imap::error::Error::Bad(_)) => {
+                    result = PartialFetchResult::Unsupported;
+                }
+                Err(err) => {
+                    return Err(err).with_context(|| format!("partial fetch of UID {uid}"));
+                }
+            }
+        }
+        Ok(result)
+    }
+}
+
+/// Returns the body bytes of a partial FETCH response,
+/// or `Some(vec![])` when the server returned a body section without data
+/// (`BODY[]<origin> ""` or NIL), which means the requested range starts
+/// at or past the end of the message.
+///
+/// Returns `None` if the response carries no body section at all.
+fn partial_fetch_data(msg: &Fetch) -> Option<Vec<u8>> {
+    if let Some(body) = msg.body() {
+        Some(body.to_vec())
+    } else if msg.body_origin().is_some() {
+        // ponytail: relies on `body_origin()` matching a body section even
+        // with NIL data; a full `BODY[]` with NIL data would be missed, but
+        // servers only return NIL/"" for out-of-range partial requests.
+        Some(Vec::new())
+    } else {
+        None
+    }
 }
