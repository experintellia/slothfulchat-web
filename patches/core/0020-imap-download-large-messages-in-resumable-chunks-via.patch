+/// Disables chunked downloads for the transport for the rest of the process
+/// lifetime and informs the user once per account that the server lacks
+/// partial FETCH.
+async fn disable_chunked_download(context: &Context, transport_id: u32) -> Result<()> {
+    warn!(
+        context,
+        "Server of transport {transport_id} does not support partial FETCH, disabling chunked downloads."
+    );
+    context
+        .chunked_download_disabled
+        .lock()
+        .insert(transport_id);
+
+    let text = "⚠️ Your email server does not support downloading messages in parts \
+                (IMAP partial fetch, RFC 3501). Large messages are downloaded in one piece \
+                and interrupted downloads cannot be resumed"
+        .to_string();
+    let mut msg = Message::new_text(text);
+    add_device_msg(
+        context,
+        Some("chunked-download-unsupported"),
+        Some(&mut msg),
+    )
+    .await?;
+    Ok(())
+}
