+    /// could produce (origin mismatch, `Gone`, ignoring the requested
+    /// range); `fail_at` makes the n-th call (1-indexed) return an error, to
+    /// test that staging survives an I/O failure. Every requested
+    /// `(offset, count)` is recorded; grab a handle with `calls_handle`
+    /// before handing the fetcher to `chunked_fetch_loop` since it consumes
+    /// it by value.
+    type RespondFn = dyn Fn(u32, u32, &[u8]) -> PartialFetchResult + Send;
+
+    struct FakeFetcher {
+        data: Vec<u8>,
+        calls: Arc<Mutex<Vec<(u32, u32)>>>,
+        fail_at_call: Option<usize>,
+        respond: Option<Box<RespondFn>>,
+    }
+
+    impl FakeFetcher {
+        fn new(data: Vec<u8>) -> Self {
+            Self {
+                data,
+                calls: Arc::new(Mutex::new(Vec::new())),
+                fail_at_call: None,
+                respond: None,
+            }
+        }
+
+        fn fail_at(mut self, call_no: usize) -> Self {
+            self.fail_at_call = Some(call_no);
+            self
+        }
+
+        fn respond_with(
+            mut self,
+            f: impl Fn(u32, u32, &[u8]) -> PartialFetchResult + Send + 'static,
+        ) -> Self {
+            self.respond = Some(Box::new(f));
+            self
+        }
+
+        fn calls_handle(&self) -> Arc<Mutex<Vec<(u32, u32)>>> {
+            self.calls.clone()
+        }
+    }
+
+    impl RangeFetcher for FakeFetcher {
+        fn fetch_range(
+            &mut self,
+            offset: u32,
+            count: u32,
+        ) -> Pin<Box<dyn Future<Output = Result<PartialFetchResult>> + Send + '_>> {
+            self.calls.lock().unwrap().push((offset, count));
+            let call_no = self.calls.lock().unwrap().len();
+            if self.fail_at_call == Some(call_no) {
+                return Box::pin(async move { bail!("fake fetch error") });
+            }
+            let result = if let Some(respond) = &self.respond {
+                respond(offset, count, &self.data)
+            } else {
+                let start = offset as usize;
+                let end = std::cmp::min(start.saturating_add(count as usize), self.data.len());
+                let bytes = if start >= self.data.len() {
+                    Vec::new()
+                } else {
+                    self.data[start..end].to_vec()
+                };
+                PartialFetchResult::Data {
+                    origin: Some(offset),
+                    bytes,
+                }
+            };
+            Box::pin(async move { Ok(result) })
+        }
+    }
