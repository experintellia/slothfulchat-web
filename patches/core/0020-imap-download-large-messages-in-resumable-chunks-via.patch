+    #[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+    async fn test_chunked_fetch_server_ignores_range() -> Result<()> {
+        let t = TestContext::new().await;
+        let data = fake_message(500_000);
+
+        // Fresh download: server sends the whole message right away, larger
+        // than the requested count. `origin == offset (0)` on this very
+        // first request looks compliant, so the loop appends it whole and
+        // asks again; the follow-up request lands past the end of the
+        // message and gets an empty short-read, which is what actually
+        // terminates the loop with the fully assembled body.
+        let mut staging = open_staging(&t, 1).await;
+        let fetcher = FakeFetcher::new(data.clone()).respond_with(|offset, _count, data| {
+            if offset == 0 {
+                PartialFetchResult::Data {
+                    origin: Some(0),
+                    bytes: data.to_vec(),
+                }
+            } else {
+                PartialFetchResult::Data {
+                    origin: Some(offset),
+                    bytes: Vec::new(),
+                }
+            }
+        });
+        let calls = fetcher.calls_handle();
+        let outcome = chunked_fetch_loop(&t, &mut staging, None, None, fetcher).await?;
+        let ChunkOutcome::Complete(body) = outcome else {
+            panic!("expected Complete");
+        };
+        assert_eq!(body, data);
+        assert_eq!(
+            *calls.lock().unwrap(),
+            vec![(0, 128 * 1024), (data.len() as u32, 256 * 1024)],
+            "over-long first chunk is accepted, then a follow-up short read terminates the loop"
+        );
+
+        // Resume case, origin Some(0): must not splice the pre-staged bytes
+        // in front of the freshly returned full message.
+        let mut staging = open_staging(&t, 2).await;
+        staging.append(&data[..1000]).await?;
+        let fetcher = FakeFetcher::new(data.clone()).respond_with(|_offset, _count, data| {
+            PartialFetchResult::Data {
+                origin: Some(0),
+                bytes: data.to_vec(),
+            }
+        });
+        let outcome = chunked_fetch_loop(&t, &mut staging, None, None, fetcher).await?;
+        let ChunkOutcome::Complete(body) = outcome else {
+            panic!("expected Complete");
+        };
+        assert_eq!(body, data);
+
+        // Origin None past the start is NOT accepted as the full message:
+        // a plain `BODY[]` response to a mid-message range request could be
+        // either the full message or just the requested range — guessing
+        // wrong would splice a corrupt message, so the loop gives up on
+        // chunking instead.
+        let mut staging = open_staging(&t, 3).await;
+        staging.append(&data[..1000]).await?;
+        let fetcher = FakeFetcher::new(data.clone()).respond_with(|_offset, _count, data| {
+            PartialFetchResult::Data {
+                origin: None,
+                bytes: data.to_vec(),
+            }
+        });
+        let outcome = chunked_fetch_loop(&t, &mut staging, None, None, fetcher).await?;
+        assert!(matches!(outcome, ChunkOutcome::Unsupported));
+
+        // Fresh download from a server that omits the origin octet entirely:
+        // safe at offset 0, so a message fitting into the first chunk
+        // completes as a short read.
+        let small = fake_message(100_000);
+        let mut staging = open_staging(&t, 4).await;
+        let fetcher = FakeFetcher::new(small.clone()).respond_with(|_offset, _count, data| {
+            PartialFetchResult::Data {
+                origin: None,
+                bytes: data.to_vec(),
+            }
+        });
+        let outcome = chunked_fetch_loop(&t, &mut staging, None, None, fetcher).await?;
+        let ChunkOutcome::Complete(body) = outcome else {
+            panic!("expected Complete");
+        };
+        assert_eq!(body, small);
+        Ok(())
+    }
