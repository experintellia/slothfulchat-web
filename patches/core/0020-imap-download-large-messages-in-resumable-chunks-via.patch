+/// Initial chunk size for chunked downloads.
+///
+/// Small enough for fine-grained progress and quick failure on bad links.
+const CHUNK_SIZE_START: u32 = 128 * 1024;
+
+/// Maximum chunk size. The chunk size doubles with every fetched chunk
+/// up to this cap to amortize round-trip latency on large messages.
+const CHUNK_SIZE_MAX: u32 = 4 * 1024 * 1024;
+
+/// Short hash of a folder name for use in staging file names;
+/// folder names themselves are not filesystem-safe.
+fn folder_hash(folder: &str) -> String {
+    let mut hash = hex::encode(Sha256::digest(folder.as_bytes()));
+    hash.truncate(8);
+    hash
+}
+
+/// Staging file for a chunked download, stored in the blobdir.
+///
+/// The file length is the resume offset: chunks are appended as they arrive
+/// and a download interrupted at any point continues where the file ends.
+/// The name is keyed by the server-side identity of the message
+/// (transport, folder, UIDVALIDITY, UID), so stale bytes can never be
+/// resumed against a different message.
+pub(crate) struct StagingFile {
+    path: PathBuf,
+    len: u64,
+}
+
+impl StagingFile {
+    /// Returns the blobdir file name for the given message identity.
+    pub(crate) fn name(transport_id: u32, folder: &str, uidvalidity: u32, uid: u32) -> String {
+        let folder_hash = folder_hash(folder);
+        format!("partial-t{transport_id}-{folder_hash}-v{uidvalidity}-u{uid}")
+    }
+
+    /// Prefix of all staging file names for the given folder,
+    /// regardless of UIDVALIDITY.
+    fn folder_prefix(transport_id: u32, folder: &str) -> String {
+        let folder_hash = folder_hash(folder);
+        format!("partial-t{transport_id}-{folder_hash}-")
+    }
+
+    /// Opens the staging file, creating the bookkeeping for a fresh one
+    /// if it does not exist yet.
+    async fn open(
+        context: &Context,
+        transport_id: u32,
+        folder: &str,
+        uidvalidity: u32,
+        uid: u32,
+    ) -> Result<Self> {
+        let path = context
+            .get_blobdir()
+            .join(Self::name(transport_id, folder, uidvalidity, uid));
+        let len = match tokio::fs::metadata(&path).await {
+            Ok(metadata) => metadata.len(),
+            Err(_) => 0,
+        };
+        Ok(Self { path, len })
+    }
+
+    /// Returns the number of bytes staged so far, i.e. the resume offset.
+    fn len(&self) -> u64 {
+        self.len
+    }
+
+    async fn append(&mut self, bytes: &[u8]) -> Result<()> {
+        let mut file = tokio::fs::OpenOptions::new()
+            .create(true)
+            .append(true)
+            .open(&self.path)
+            .await
+            .with_context(|| format!("failed to open staging file {}", self.path.display()))?;
+        file.write_all(bytes).await?;
+        // tokio file writes complete in the background; without the flush a
+        // read_all() right after append() could see a truncated file and
+        // consecutive appends could land out of order.
+        file.flush().await?;
+        self.len = self.len.saturating_add(bytes.len() as u64);
+        Ok(())
+    }
+
+    async fn read_all(&self) -> Result<Vec<u8>> {
+        Ok(tokio::fs::read(&self.path).await?)
+    }
+
+    async fn delete(self) -> Result<()> {
+        // The file does not exist if no chunk was ever appended.
+        if let Err(err) = tokio::fs::remove_file(&self.path).await
+            && err.kind() != std::io::ErrorKind::NotFound
+        {
+            return Err(err.into());
+        }
+        Ok(())
+    }
+}
+
+/// Removes staging files of the folder that do not belong
+/// to the current UIDVALIDITY. Called when UIDVALIDITY changes:
+/// UIDs are no longer valid then, so partial downloads cannot be resumed.
+pub(crate) async fn discard_partial_files(
+    context: &Context,
+    transport_id: u32,
+    folder: &str,
+    uidvalidity: u32,
+) -> Result<()> {
+    let prefix = StagingFile::folder_prefix(transport_id, folder);
+    let keep_marker = format!("-v{uidvalidity}-");
+    let mut dir = tokio::fs::read_dir(context.get_blobdir()).await?;
+    while let Ok(Some(entry)) = dir.next_entry().await {
+        let name = entry.file_name();
+        let name = name.to_string_lossy();
+        if name.starts_with(&prefix) && !name.contains(&keep_marker) {
+            info!(context, "Discarding stale partial download {name}.");
+            tokio::fs::remove_file(entry.path()).await.ok();
+        }
+    }
+    Ok(())
+}
+
+/// Outcome of [`chunked_fetch_loop`].
+enum ChunkOutcome {
+    /// The fully assembled raw message.
+    Complete(Vec<u8>),
+
+    /// The server does not support partial FETCH;
+    /// the caller falls back to a full fetch.
+    Unsupported,
+
+    /// The server sent no FETCH response for the UID.
+    ///
+    /// Ambiguous: the message may be gone, but a tagged NO/BAD also
+    /// produces an empty response stream (async-imap terminates a FETCH
+    /// stream at the tagged response without surfacing its status), so
+    /// the caller must re-probe to distinguish the two.
+    Gone,
+
+    /// The staged length left the u32 offset range of partial FETCH;
+    /// the server keeps returning full-size chunks and cannot be trusted.
+    TooLarge,
+}
+
+/// One partial FETCH of a message byte range.
+///
+/// This seam keeps [`chunked_fetch_loop`] testable without an IMAP session.
+/// The returned future is boxed instead of using an `async fn`/`AsyncFnMut`
+/// so that the loop's future stays `Send`
+/// (rustc cannot prove that for opaque lending futures, see rust#110338).
+trait RangeFetcher: Send {
+    fn fetch_range(
+        &mut self,
+        offset: u32,
+        count: u32,
+    ) -> Pin<Box<dyn Future<Output = Result<PartialFetchResult>> + Send + '_>>;
+}
+
+/// [`RangeFetcher`] performing partial FETCHes of one UID
+/// over an IMAP session.
+struct SessionRangeFetcher<'a> {
+    session: &'a mut Session,
+    uid: u32,
+}
+
+impl RangeFetcher for SessionRangeFetcher<'_> {
+    fn fetch_range(
+        &mut self,
+        offset: u32,
+        count: u32,
+    ) -> Pin<Box<dyn Future<Output = Result<PartialFetchResult>> + Send + '_>> {
+        Box::pin(self.session.uid_fetch_partial(self.uid, offset, count))
+    }
+}
+
+/// Downloads a message in chunks, appending to the staging file,
+/// starting from the staged length, until the server returns a chunk
+/// shorter than requested.
+///
+/// `expected_size` (`RFC822.SIZE`) is used for progress reporting only,
+/// never to decide termination: servers may misreport it.
+///
+async fn chunked_fetch_loop(
+    context: &Context,
+    staging: &mut StagingFile,
+    expected_size: Option<u64>,
+    msg_id: Option<MsgId>,
+    mut fetcher: impl RangeFetcher,
+) -> Result<ChunkOutcome> {
+    let mut chunk_size = CHUNK_SIZE_START;
+    loop {
+        let Ok(offset) = u32::try_from(staging.len()) else {
+            return Ok(ChunkOutcome::TooLarge);
+        };
+
+        let (origin, bytes) = match fetcher.fetch_range(offset, chunk_size).await? {
+            PartialFetchResult::Data { origin, bytes } => (origin, bytes),
+            PartialFetchResult::Gone => return Ok(ChunkOutcome::Gone),
+            PartialFetchResult::Unsupported => return Ok(ChunkOutcome::Unsupported),
+        };
+
+        match origin {
+            Some(origin) if origin == offset => {}
+            // A response without an origin octet is only safe to use from
+            // the very beginning of the message.
+            None if offset == 0 => {}
+            // A server that ignores the requested range but returns the
+            // whole message from the beginning is harmless.
+            Some(0) if bytes.len() as u64 > u64::from(offset) => {
+                info!(
+                    context,
+                    "Server ignored the requested range and returned the full message."
+                );
+                return Ok(ChunkOutcome::Complete(bytes));
+            }
+            // Anything else — wrong origin, or a plain `BODY[]` response to
+            // a mid-message range request, which could be either the full
+            // message or just the range (indistinguishable, and guessing
+            // wrong would splice a corrupt message) — means partial FETCH
+            // cannot be trusted on this server.
+            _ => {
+                warn!(
+                    context,
+                    "Partial FETCH returned origin {origin:?}, requested {offset}."
+                );
+                return Ok(ChunkOutcome::Unsupported);
+            }
+        }
+
+        let short_chunk = (bytes.len() as u64) < u64::from(chunk_size);
+        staging.append(&bytes).await?;
+
+        if let (Some(msg_id), Some(size)) = (msg_id, expected_size)
+            && let Some(permille) = staging.len().saturating_mul(1000).checked_div(size)
+        {
+            let permille = permille.clamp(1, 999) as u16;
+            context.emit_event(EventType::DownloadProgress { msg_id, permille });
+        }
+
+        if short_chunk {
+            // The server truncates the range at the end of the message;
+            // this is the ground truth for "message complete".
+            return Ok(ChunkOutcome::Complete(staging.read_all().await?));
+        }
+
+        chunk_size = std::cmp::min(chunk_size.saturating_mul(2), CHUNK_SIZE_MAX);
+    }
+}
