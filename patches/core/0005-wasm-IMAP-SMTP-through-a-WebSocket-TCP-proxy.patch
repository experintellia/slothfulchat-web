+++ b/src/net/ws_tcp.rs
@@ -0,0 +1,151 @@
+//! wasm32 TCP transport: tunnels byte streams through a WebSocket proxy.
+//!
+//! Browsers cannot open TCP sockets. A trivial proxy (see the prototype's
+//! `scripts/ws-tcp-proxy.mjs`) exposes `/tcp/{ip}/{port}` as a raw byte
+//! tunnel and `/dns/{host}` for name resolution. TLS still terminates inside
+//! wasm against the real server — the proxy only ever relays ciphertext.
+//!
+//! JS WebSocket handles are `!Send`, but core requires `Send` streams and
+//! connection futures. The socket therefore lives in a `spawn_local` task
+//! bridged to a `tokio::io::duplex` pair, which is plain Rust and `Send`.
+
+use std::net::{IpAddr, SocketAddr};
+use std::pin::Pin;
+use std::str::FromStr;
+use std::sync::OnceLock;
+use std::task::{Context as TaskContext, Poll};
+use std::time::Duration;
+
+use anyhow::{Context as _, Result, format_err};
+use futures::StreamExt;
+use tokio::io::{AsyncRead, AsyncWrite, DuplexStream, ReadBuf};
+use tokio_util::compat::FuturesAsyncReadCompatExt;
+
+use crate::net::session::SessionStream;
+
+static WS_PROXY_URL: OnceLock<String> = OnceLock::new();
+
+/// Configures the WebSocket proxy base URL (e.g. `ws://localhost:8641`).
+/// Must be called before any network operation; subsequent calls are ignored.
+pub fn set_ws_proxy_url(url: String) {
+    let _ = WS_PROXY_URL.set(url);
+}
+
+fn proxy_url(kind: &str, host: &str, port: Option<u16>) -> Result<String> {
+    let base = WS_PROXY_URL
+        .get()
+        .context("no WebSocket proxy configured — call set_ws_proxy_url() first")?;
+    let base = base.trim_end_matches('/');
+    Ok(match port {
+        Some(port) => format!("{base}/{kind}/{host}/{port}"),
+        None => format!("{base}/{kind}/{host}"),
+    })
+}
+
+/// A TCP connection tunneled through the WebSocket proxy.
+#[derive(Debug)]
+pub(crate) struct WsTcpStream {
+    inner: DuplexStream,
+    peer: SocketAddr,
+}
+
+impl AsyncRead for WsTcpStream {
+    fn poll_read(
+        mut self: Pin<&mut Self>,
+        cx: &mut TaskContext<'_>,
+        buf: &mut ReadBuf<'_>,
+    ) -> Poll<std::io::Result<()>> {
+        Pin::new(&mut self.inner).poll_read(cx, buf)
+    }
+}
+
+impl AsyncWrite for WsTcpStream {
+    fn poll_write(
+        mut self: Pin<&mut Self>,
+        cx: &mut TaskContext<'_>,
+        buf: &[u8],
+    ) -> Poll<std::io::Result<usize>> {
+        Pin::new(&mut self.inner).poll_write(cx, buf)
+    }
+
+    fn poll_flush(
+        mut self: Pin<&mut Self>,
+        cx: &mut TaskContext<'_>,
+    ) -> Poll<std::io::Result<()>> {
+        Pin::new(&mut self.inner).poll_flush(cx)
+    }
+
+    fn poll_shutdown(
+        mut self: Pin<&mut Self>,
+        cx: &mut TaskContext<'_>,
+    ) -> Poll<std::io::Result<()>> {
+        Pin::new(&mut self.inner).poll_shutdown(cx)
+    }
+}
+
+impl SessionStream for WsTcpStream {
+    fn set_read_timeout(&mut self, _timeout: Option<Duration>) {
+        // ponytail: no per-read timeouts on the tunneled stream; callers'
+        // tokio::time::timeout (wasmtimer on wasm) covers the hang case.
+    }
+
+    fn peer_addr(&self) -> Result<SocketAddr> {
+        Ok(self.peer)
+    }
+}
+
+/// Opens a tunneled TCP connection to `addr` via the proxy.
+///
+/// The returned future and stream are `Send`; the `!Send` JS socket lives in
+/// a local task.
+pub(crate) async fn connect_ws_tcp(addr: SocketAddr) -> Result<WsTcpStream> {
+    let url = proxy_url("tcp", &addr.ip().to_string(), Some(addr.port()))?;
+    let (tx, rx) = futures::channel::oneshot::channel();
+    wasm_bindgen_futures::spawn_local(async move {
+        let _ = tx.send(connect_inner(&url).await);
+    });
+    let inner = rx.await.context("ws connect task dropped")??;
+    Ok(WsTcpStream { inner, peer: addr })
+}
+
+async fn connect_inner(url: &str) -> Result<DuplexStream> {
+    let (_meta, ws) = ws_stream_wasm::WsMeta::connect(url, None)
+        .await
+        .map_err(|e| format_err!("WebSocket connect to {url} failed: {e}"))?;
+    let ws_io = ws.into_io();
+    let (client, server) = tokio::io::duplex(64 * 1024);
+    wasm_bindgen_futures::spawn_local(async move {
+        let mut ws_io = ws_io.compat();
+        let mut server = server;
+        // Runs until either side closes; dropping both ends tears down the
+        // WebSocket and signals EOF to core.
+        let _ = tokio::io::copy_bidirectional(&mut ws_io, &mut server).await;
+    });
+    Ok(client)
+}
+
+/// Resolves a hostname through the proxy's `/dns/{host}` endpoint.
+pub(crate) async fn ws_dns_lookup(host: &str) -> Result<Vec<IpAddr>> {
+    let url = proxy_url("dns", host, None)?;
+    let (tx, rx) = futures::channel::oneshot::channel();
+    wasm_bindgen_futures::spawn_local(async move {
+        let _ = tx.send(dns_inner(&url).await);
+    });
+    rx.await.context("ws dns task dropped")?
+}
+
+async fn dns_inner(url: &str) -> Result<Vec<IpAddr>> {
+    let (_meta, mut ws) = ws_stream_wasm::WsMeta::connect(url, None)
+        .await
+        .map_err(|e| format_err!("WebSocket connect to {url} failed: {e}"))?;
+    let message = ws.next().await.context("no DNS reply from proxy")?;
+    let text = match message {
+        ws_stream_wasm::WsMessage::Text(text) => text,
+        ws_stream_wasm::WsMessage::Binary(bytes) => String::from_utf8(bytes)?,
+    };
+    let ips: Vec<String> = serde_json::from_str(&text).context("bad DNS reply")?;
+    Ok(ips
+        .iter()
+        .filter_map(|ip| IpAddr::from_str(ip).ok())
+        .collect())
+}
