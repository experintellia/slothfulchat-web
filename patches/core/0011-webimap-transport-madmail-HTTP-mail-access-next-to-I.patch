+//! # WebIMAP transport (madmail).
+//!
+//! Mail access over an HTTPS REST API instead of IMAP/SMTP,
+//! as implemented by madmail's webimap/websmtp
+//! (<https://github.com/themadorg/madmail>, TDD doc `10-webimap.md`).
+//! Browsers can speak it directly (CORS `*`), no TCP proxy needed:
+//!
+//! * `GET /webimap/messages?since_uid=N&wait=S` long-polls for messages,
+//! * `GET /webimap/message/{uid}` returns the raw RFC 5322 message,
+//! * `DELETE /webimap/message/{uid}` deletes it,
+//! * `POST /webimap/send` submits mail.
+//!
+//! Authentication is the `X-Email`/`X-Password` header pair.
+
+use std::time::Duration;
+
+use anyhow::{Context as _, Result, bail, format_err};
+use futures_lite::FutureExt;
+use serde::Deserialize;
+use tokio::sync::oneshot;
+
+use crate::context::Context;
+use crate::events::EventType;
+use crate::imap::Imap;
+use crate::log::warn;
+use crate::net::http::request;
+use crate::receive_imf::receive_imf_inner;
+use crate::scheduler::ImapConnectionHandlers;
+use crate::smtp::{SendResult, Smtp};
+use crate::transport::ConfiguredLoginParam;
+
+/// Seconds the server is asked to keep a message long-poll open.
+const LONG_POLL_WAIT_SECS: u64 = 60;
+
+/// Client-side timeout for ordinary webimap API requests;
+/// long polls use [`LONG_POLL_WAIT_SECS`] plus slack instead.
+pub(crate) const REQUEST_TIMEOUT: Duration = Duration::from_secs(30);
+
+/// Returns the HTTP base URL for a webimap instance at `host` (`host[:port]`).
+pub(crate) fn base_url(host: &str) -> String {
+    // ponytail: plain http is a test hatch so mock-server e2e tests can run
+    // without TLS plumbing; everything except localhost — spelled
+    // `localhost`, `127.0.0.1` or IPv6 `[::1]` — is always https.
+    let name = if let Some(rest) = host.strip_prefix('[') {
+        // Bracketed IPv6 literal, `[::1]` or `[::1]:8443`.
+        rest.split(']').next().unwrap_or(rest)
+    } else {
+        host.split(':').next().unwrap_or(host)
+    };
+    if name == "localhost" || name == "127.0.0.1" || name == "::1" {
+        format!("http://{host}")
+    } else {
+        format!("https://{host}")
+    }
+}
+
+/// Message metadata returned by `GET /webimap/messages`.
+#[derive(Debug, Deserialize)]
+struct MessageMeta {
+    uid: u32,
+}
+
+/// Message returned by `GET /webimap/message/{uid}`;
+/// `body` is the full raw RFC 5322 message.
+#[derive(Debug, Deserialize)]
+struct MessageBody {
+    body: String,
+}
+
+/// Authenticated client for one webimap account.
+pub(crate) struct WebimapClient {
+    base_url: String,
+    addr: String,
+    password: String,
+}
+
+impl WebimapClient {
+    /// Creates a client from configured login parameters.
+    pub(crate) fn new(lp: &ConfiguredLoginParam) -> Result<Self> {
+        let host = &lp
+            .imap
+            .first()
+            .context("webimap transport without host")?
+            .connection
+            .host;
+        Ok(Self {
+            base_url: base_url(host),
+            addr: lp.addr.clone(),
+            password: lp.imap_password.clone(),
+        })
+    }
+
+    /// Performs an authenticated request against the webimap API.
+    ///
+    /// Redirects are not followed: they would re-send the credential
+    /// headers to the redirect target.
+    async fn req(
+        &self,
+        context: &Context,
+        method: &str,
+        path: &str,
+        body: Option<String>,
+        timeout: Duration,
+    ) -> Result<(u16, Vec<u8>)> {
+        let url = format!("{}{}", self.base_url, path);
+        let mut headers = vec![
+            ("X-Email", self.addr.as_str()),
+            ("X-Password", self.password.as_str()),
+        ];
+        if body.is_some() {
+            headers.push(("Content-Type", "application/json"));
+        }
+        let (status, response) =
+            request(context, method, &url, &headers, body, timeout, false).await?;
+        Ok((status, response.blob))
+    }
+
+    /// Checks that the server is reachable and the credentials work.
+    pub(crate) async fn verify(&self, context: &Context) -> Result<()> {
+        let (status, body) = self
+            .req(context, "GET", "/webimap/mailboxes", None, REQUEST_TIMEOUT)
+            .await?;
+        if !(200..300).contains(&status) {
+            bail!(
+                "webimap login at {} failed with status {status}: {}",
+                self.base_url,
+                String::from_utf8_lossy(&body)
+            );
+        }
+        Ok(())
+    }
+
+    /// Long-polls the server for messages in INBOX.
+    async fn list_messages(&self, context: &Context) -> Result<Vec<MessageMeta>> {
+        // ponytail: always restart at since_uid=0 instead of persisting UIDs;
+        // processed messages are deleted from the server and receive_imf()
+        // dedups reruns by Message-ID anyway.
+        let (status, body) = self
+            .req(
+                context,
+                "GET",
+                &format!("/webimap/messages?since_uid=0&wait={LONG_POLL_WAIT_SECS}"),
+                None,
+                // The server may hold the poll open for the full wait;
+                // only give up well after that.
+                Duration::from_secs(LONG_POLL_WAIT_SECS.saturating_add(30)),
+            )
+            .await?;
+        if !(200..300).contains(&status) {
+            bail!("webimap message listing failed with status {status}");
+        }
+        serde_json::from_slice(&body).context("bad webimap message list")
+    }
+
+    /// Downloads a message, feeds it to receive_imf and deletes it on success.
+    async fn fetch_message(&self, context: &Context, uid: u32) -> Result<()> {
+        let (status, body) = self
+            .req(
+                context,
+                "GET",
+                &format!("/webimap/message/{uid}"),
+                None,
+                REQUEST_TIMEOUT,
+            )
+            .await?;
+        if !(200..300).contains(&status) {
+            bail!("webimap fetch of UID {uid} failed with status {status}");
+        }
+        let message: MessageBody = serde_json::from_slice(&body).context("bad webimap message")?;
+        let raw = message.body.as_bytes();
+        let mail = mailparse::parse_mail(raw).context("can't parse mail")?;
+        let rfc724_mid = crate::imap::prefetch_get_message_id(&mail.headers)
+            .unwrap_or_else(crate::imap::create_message_id);
+        receive_imf_inner(context, &rfc724_mid, raw, false).await?;
+        let (status, _body) = self
+            .req(
+                context,
+                "DELETE",
+                &format!("/webimap/message/{uid}"),
+                None,
+                REQUEST_TIMEOUT,
+            )
+            .await?;
+        if !(200..300).contains(&status) {
+            // Failing here makes the caller back off. The message was
+            // processed but stays on the server, so the next long-poll
+            // returns it again immediately; without the backoff that is
+            // a busy loop. receive_imf() dedups the reruns by Message-ID.
+            bail!("webimap delete of UID {uid} failed with status {status}");
+        }
+        Ok(())
+    }
+}
+
+/// Sends a message over the webimap HTTP API.
+///
+/// Reports like `crate::smtp::smtp_send()` does:
+/// updates `last_send_error` on `smtp` and returns the same
+/// [`SendResult`] retry/failure semantics.
+pub(crate) async fn smtp_send(
+    context: &Context,
+    lp: &ConfiguredLoginParam,
+    recipients: &[async_smtp::EmailAddress],
+    message: &str,
+    smtp: &mut Smtp,
+) -> SendResult {
+    let client = match WebimapClient::new(lp) {
+        Ok(client) => client,
+        Err(err) => {
+            smtp.last_send_error = Some(format!("{err:#}"));
+            return SendResult::Failure(err);
+        }
+    };
+    let to: Vec<String> = recipients.iter().map(|addr| addr.to_string()).collect();
+    let body = serde_json::json!({
+        "from": client.addr,
+        "to": to,
+        "body": message,
+    })
+    .to_string();
+    match client
+        .req(
+            context,
+            "POST",
+            "/webimap/send",
+            Some(body),
+            REQUEST_TIMEOUT,
+        )
+        .await
+    {
+        Err(err) => {
+            // Transport error, e.g. server unreachable: retry later.
+            warn!(context, "webimap send failed: {err:#}.");
+            smtp.last_send_error = Some(format!("{err:#}"));
+            SendResult::Retry
+        }
+        Ok((status, _response)) if (200..300).contains(&status) => {
+            smtp.last_send_error = None;
+            SendResult::Success
+        }
+        Ok((status, response)) => {
+            // ponytail: every non-2xx is treated as permanent so PGP-only
+            // rejections surface to the user; split out 5xx as Retry if
+            // madmail servers turn out to return transient errors.
+            let err = format_err!(
+                "webimap send failed with status {status}: {}",
+                String::from_utf8_lossy(&response)
+            );
+            smtp.last_send_error = Some(format!("{err:#}"));
+            SendResult::Failure(err)
+        }
+    }
+}
+
+/// A single receive iteration: long-poll for messages, process and delete them.
+///
+/// Returns whether the poll returned any messages. Empty polls are the
+/// steady state and signal no working/idle transition, so connectivity
+/// does not flap every [`LONG_POLL_WAIT_SECS`].
+async fn fetch_idle(ctx: &Context, client: &WebimapClient, connection: &Imap) -> Result<bool> {
+    let mut msgs = client.list_messages(ctx).await?;
+    if msgs.is_empty() {
+        return Ok(false);
+    }
+    connection.connectivity.set_working(ctx);
+
+    msgs.sort_by_key(|meta| meta.uid);
+    let mut failed = 0;
+    for meta in msgs {
+        // ponytail: a failed message is skipped and retried on the next
+        // round, it stays on the server until successfully processed.
+        if let Err(err) = client.fetch_message(ctx, meta.uid).await {
+            warn!(ctx, "webimap: failed to process UID {}: {err:#}.", meta.uid);
+            failed += 1;
+        }
+    }
+
+    // Erroring here makes the caller back off; without it a message that
+    // fails to process would turn the long-poll into a busy loop
+    // because it is returned again immediately.
+    if failed > 0 {
+        bail!("failed to process {failed} webimap message(s)");
+    }
+    Ok(true)
+}
+
+/// Receiving loop for a webimap transport,
+/// replaces `scheduler::inbox_loop()`.
+pub(crate) async fn webimap_loop(
+    ctx: Context,
+    started: oneshot::Sender<()>,
+    inbox_handlers: ImapConnectionHandlers,
+    lp: ConfiguredLoginParam,
+) {
+    use futures::future::FutureExt;
+
+    info!(ctx, "Starting webimap loop.");
+    let ImapConnectionHandlers {
+        connection,
+        stop_token,
+    } = inbox_handlers;
+
+    let transport_id = connection.transport_id();
+    let ctx1 = ctx.clone();
+    let fut = async move {
+        let ctx = ctx1;
+        if let Err(()) = started.send(()) {
+            warn!(ctx, "Webimap loop, missing started receiver.");
+            return;
+        };
+
+        let client = match WebimapClient::new(&lp) {
+            Ok(client) => client,
+            Err(err) => {
+                warn!(
+                    ctx,
+                    "Transport {transport_id}: invalid webimap configuration: {err:#}."
+                );
+                connection.connectivity.set_err(&ctx, format!("{err:#}"));
+                return;
+            }
+        };
+
+        connection.connectivity.set_connecting(&ctx);
+        // Whether connectivity is already signalled as Idle: transition
+        // only after messages, errors or connects, not on every empty poll.
+        let mut signalled_idle = false;
+        loop {
+            match fetch_idle(&ctx, &client, &connection).await {
+                Ok(had_messages) => {
+                    if had_messages || !signalled_idle {
+                        connection.connectivity.set_idle(&ctx);
+                        ctx.emit_event(EventType::ImapInboxIdle);
+                        signalled_idle = true;
+                    }
+                }
+                Err(err) => {
+                    signalled_idle = false;
+                    warn!(
+                        ctx,
+                        "Transport {transport_id}: webimap fetch failed: {err:#}."
+                    );
+                    connection.connectivity.set_err(&ctx, format!("{err:#}"));
+
+                    // Retry in 30 seconds or when interrupted,
+                    // e.g. because the network came back.
+                    tokio::time::timeout(Duration::from_secs(30), async {
+                        connection.idle_interrupt_receiver.recv().await.ok();
+                    })
+                    .await
+                    .ok();
+                }
+            }
+        }
+    };
+
+    stop_token
+        .cancelled()
+        .map(|_| {
+            info!(ctx, "Transport {transport_id}: Shutting down webimap loop.");
+        })
+        .race(fut)
+        .await;
+}
