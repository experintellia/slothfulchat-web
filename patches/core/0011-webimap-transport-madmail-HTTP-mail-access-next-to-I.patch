+/// Parses and validates the host of a `webimapaccount:` QR,
+/// returning it in canonical `host[:port]` form.
+///
+/// The payload is attacker-suppliable, so it must be a pure `host[:port]`:
+/// userinfo (`trusted.org@evil.com` would display trusted.org but connect
+/// to evil.com), path, query, fragment and whitespace are all rejected.
+fn decode_webimap_host(qr: &str) -> Result<String> {
+    let payload = qr
+        .get(WEBIMAPACCOUNT_SCHEME.len()..)
+        .context("Invalid webimapaccount payload")?
+        .trim();
+    let url = url::Url::parse(&format!("https://{payload}"))
+        .with_context(|| format!("Invalid webimapaccount host: {payload:?}"))?;
+    if !url.username().is_empty()
+        || url.password().is_some()
+        || url.path() != "/"
+        || url.query().is_some()
+        || url.fragment().is_some()
+    {
+        bail!("Invalid webimapaccount host: {payload:?}");
+    }
+    let host = url
+        .host_str()
+        .with_context(|| format!("Invalid webimapaccount host: {payload:?}"))?;
+    Ok(match url.port() {
+        Some(port) => format!("{host}:{port}"),
+        None => host.to_string(),
+    })
+}
