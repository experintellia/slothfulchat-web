+/// Performs a single HTTP request.
+///
+/// Unlike [`read_url_blob`], does not cache
+/// and returns the status code and the response body instead of failing
+/// on non-2xx responses.
+///
+/// Fails if no response arrived within `timeout` (covers connecting,
+/// sending and reading the response body).
+///
+/// hyper never follows redirects, so `_follow_redirects` has no effect here;
+/// it exists to keep the signature identical to the wasm (fetch) variant
+/// where the browser would follow redirects unless told not to.
+pub(crate) async fn request(
+    context: &Context,
+    method: &str,
+    url: &str,
+    headers: &[(&str, &str)],
+    body: Option<String>,
+    timeout: Duration,
+    _follow_redirects: bool,
+) -> Result<(u16, Response)> {
+    tokio::time::timeout(timeout, async {
+        let parsed_url = url
+            .parse::<hyper::Uri>()
+            .with_context(|| format!("Failed to parse URL {url:?}"))?;
+        let mut sender = get_http_sender(context, parsed_url.clone(), true).await?;
+        let authority = parsed_url
+            .authority()
+            .context("URL has no authority")?
+            .clone();
+
+        let mut req = hyper::Request::builder()
+            .method(hyper::Method::from_bytes(method.as_bytes())?)
+            .uri(parsed_url)
+            .header(hyper::header::HOST, authority.as_str());
+        for (name, value) in headers {
+            req = req.header(*name, *value);
+        }
+        let request = req.body(body.unwrap_or_default())?;
+
+        let response = sender.send_request(request).await?;
+        let status = response.status().as_u16();
+
+        let content_type = response
+            .headers()
+            .get("content-type")
+            .and_then(|value| value.to_str().ok())
+            .and_then(|value| value.parse::<Mime>().ok());
+        let mimetype = content_type
+            .as_ref()
+            .map(|mime| mime.essence_str().to_string());
+        let encoding = content_type.as_ref().and_then(|mime| {
+            mime.get_param(mime::CHARSET)
+                .map(|charset| charset.as_str().to_string())
+        });
+        let blob = response.collect().await?.to_bytes().to_vec();
+
+        Ok((
+            status,
+            Response {
+                blob,
+                mimetype,
+                encoding,
+            },
+        ))
+    })
+    .await
+    .map_err(|_| format_err!("HTTP {method} request to {url} timed out"))?
+}
+
