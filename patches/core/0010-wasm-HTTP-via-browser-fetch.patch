+pub async fn read_url_blob(_context: &Context, url: &str) -> Result<Response> {
+    let resp = fetch("GET", url, None, None).await?;
+    if !resp.ok {
+        bail!(
+            "The server returned a non-successful response code: {}",
+            resp.status
+        );
+    }
+    let content_type = resp.content_type.and_then(|v| v.parse::<Mime>().ok());
+    let mimetype = content_type.as_ref().map(|m| m.essence_str().to_string());
+    let encoding = content_type
+        .as_ref()
+        .and_then(|m| m.get_param(mime::CHARSET))
+        .map(|c| c.as_str().to_string());
+    Ok(Response {
+        blob: resp.body,
+        mimetype,
+        encoding,
+    })
 }
 
