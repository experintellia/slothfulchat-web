+/// The parts of a `fetch()` response we use; unlike JS handles, all Send.
+struct FetchResponse {
+    status: u16,
+    ok: bool,
+    content_type: Option<String>,
+    body: Vec<u8>,
+}
+
+fn js_str(v: JsValue) -> String {
+    format!("{v:?}")
+}
+
+/// Runs `fetch()` on the worker's JS event loop.
+///
+/// JS handles are `!Send` but our futures must be Send (yerpc), so the JS
+/// side runs in a `spawn_local` task and the result comes back over a
+/// oneshot channel — same pattern as `ws_tcp`.
+async fn fetch(
+    method: &'static str,
+    url: &str,
+    body: Option<String>,
+    content_type: Option<&'static str>,
+) -> Result<FetchResponse> {
+    let url = url.to_string();
+    let (tx, rx) = oneshot::channel();
+    wasm_bindgen_futures::spawn_local(async move {
+        let _ = tx.send(fetch_inner(method, &url, body, content_type).await);
+    });
+    rx.await
+        .map_err(|_| anyhow!("fetch task dropped"))?
+        .map_err(|e| anyhow!("fetch {method} {e}"))
+}
+
+async fn fetch_inner(
+    method: &str,
+    url: &str,
+    body: Option<String>,
+    content_type: Option<&str>,
+) -> std::result::Result<FetchResponse, String> {
+    let init = web_sys::RequestInit::new();
+    init.set_method(method);
+    if let Some(body) = &body {
+        init.set_body(&JsValue::from_str(body));
+    }
+    if let Some(ct) = content_type {
+        let headers = web_sys::Headers::new().map_err(js_str)?;
+        headers.append("content-type", ct).map_err(js_str)?;
+        init.set_headers(&headers);
+    }
+    // The core always runs in a Web Worker; there is no `window` global.
+    let scope: web_sys::WorkerGlobalScope = js_sys::global().unchecked_into();
+    let resp: web_sys::Response = JsFuture::from(scope.fetch_with_str_and_init(url, &init))
+        .await
+        .map_err(js_str)?
+        .unchecked_into();
+    let buf = JsFuture::from(resp.array_buffer().map_err(js_str)?)
+        .await
+        .map_err(js_str)?;
+    Ok(FetchResponse {
+        status: resp.status(),
+        ok: resp.ok(),
+        content_type: resp.headers().get("content-type").ok().flatten(),
+        body: js_sys::Uint8Array::new(&buf).to_vec(),
+    })
+}
+
+/// POST endpoints carry tokens; https only, as on native.
+fn ensure_https(url: &str) -> Result<()> {
+    if !url.starts_with("https://") {
+        bail!("POST requests to non-HTTPS URLs are not allowed");
+    }
+    Ok(())
+}
