+/// Rustls time provider backed by the JS clock:
+/// `SystemTime::now()` panics on wasm32-unknown-unknown.
+#[cfg(target_arch = "wasm32")]
+#[derive(Debug)]
+struct JsClockTimeProvider;
+
+#[cfg(target_arch = "wasm32")]
+impl rustls::time_provider::TimeProvider for JsClockTimeProvider {
+    fn current_time(&self) -> Option<rustls::pki_types::UnixTime> {
+        Some(rustls::pki_types::UnixTime::since_unix_epoch(
+            std::time::Duration::from_millis(js_sys::Date::now() as u64),
+        ))
+    }
+}
+
+/// `ClientConfig` builder with the right crypto provider
+/// and, on wasm, a non-panicking time provider.
+fn client_config_builder() -> Result<
+    rustls::ConfigBuilder<rustls::ClientConfig, rustls::client::WantsClientCert>,
+    rustls::Error,
+> {
+    #[cfg(not(target_arch = "wasm32"))]
+    let builder = rustls::ClientConfig::builder_with_provider(Arc::new(default_provider()));
+    #[cfg(target_arch = "wasm32")]
+    let builder = rustls::ClientConfig::builder_with_details(
+        Arc::new(default_provider()),
+        Arc::new(JsClockTimeProvider),
+    );
+    let root_cert_store =
+        rustls::RootCertStore::from_iter(webpki_roots::TLS_SERVER_ROOTS.iter().cloned());
+    Ok(builder
+        .with_safe_default_protocol_versions()?
+        .with_root_certificates(root_cert_store))
+}
