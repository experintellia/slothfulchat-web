+//! wasm32 stub for the HTTP module.
+//!
+//! The native implementation uses hyper over raw TCP. On wasm every request
+//! errors at runtime; routing HTTP through `fetch()` or the WebSocket proxy
+//! is the upgrade path (M3+).
+
+use anyhow::{Result, bail};
+use serde::Serialize;
+
+use crate::context::Context;
+
+/// HTTP(S) GET response.
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub struct Response {
+    /// Response body.
+    pub blob: Vec<u8>,
+
+    /// MIME type extracted from the `Content-Type` header, if any.
+    pub mimetype: Option<String>,
+
+    /// Encoding extracted from the `Content-Type` header, if any.
+    pub encoding: Option<String>,
+}
+
+/// Retrieves the text contents of URL using HTTP GET request.
+pub async fn read_url(_context: &Context, _url: &str) -> Result<String> {
+    bail!("HTTP requests are not available on wasm yet")
+}
+
+/// Retrieves the text contents of URL using HTTP GET request.
+pub(crate) async fn read_url_with_tls(
+    _context: &Context,
+    _url: &str,
+    _strict_tls: bool,
+) -> Result<String> {
+    bail!("HTTP requests are not available on wasm yet")
+}
+
+/// Removes expired cache entries.
+pub(crate) async fn http_cache_cleanup(_context: &Context) -> Result<()> {
+    Ok(())
+}
+
+/// Retrieves the binary contents of URL using HTTP GET request.
+pub async fn read_url_blob(_context: &Context, _url: &str) -> Result<Response> {
+    bail!("HTTP requests are not available on wasm yet")
+}
+
+/// Retrieves the binary contents of URL using HTTP GET request.
+pub(crate) async fn read_url_blob_with_tls(
+    _context: &Context,
+    _url: &str,
+    _strict_tls: bool,
+) -> Result<Response> {
+    bail!("HTTP requests are not available on wasm yet")
+}
+
+/// Sends an empty POST request to the URL.
+pub(crate) async fn post_empty(_context: &Context, _url: &str) -> Result<(String, bool)> {
+    bail!("HTTP requests are not available on wasm yet")
+}
+
+/// Sends a POST request with given string as body.
+pub(crate) async fn post_string(_context: &Context, _url: &str, _body: String) -> Result<bool> {
+    bail!("HTTP requests are not available on wasm yet")
+}
+
+/// Posts the given form to the URL.
+pub(crate) async fn post_form<T: Serialize + ?Sized>(
+    _context: &Context,
+    _url: &str,
+    _form: &T,
+) -> Result<bytes::Bytes> {
+    bail!("HTTP requests are not available on wasm yet")
+}
diff --git a/src/net/proxy_wasm.rs b/src/net/proxy_wasm.rs
new file mode 100644
index 000000000..152613428
--- /dev/null
+++ b/src/net/proxy_wasm.rs
@@ -0,0 +1,45 @@
+//! wasm32 stub for the proxy module.
+//!
+//! Proxies (SOCKS5/shadowsocks/HTTP) need raw TCP, which browsers don't have.
+//! `ProxyConfig` is an uninhabited enum: `load()` always yields `None`, so
+//! `&self` methods are unreachable.
+
+use anyhow::{Result, bail};
+
+use crate::context::Context;
+use crate::net::session::SessionStream;
+
+/// Default SOCKS5 port.
+pub const DEFAULT_SOCKS_PORT: u16 = 1080;
+
+/// Proxy configuration (never instantiable on wasm).
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum ProxyConfig {}
+
+impl ProxyConfig {
+    /// Creates a new proxy configuration by parsing given proxy URL.
+    pub fn from_url(_url: &str) -> Result<Self> {
+        bail!("proxies are not supported on wasm")
+    }
+
+    /// Serializes the proxy configuration into an URL.
+    pub fn to_url(&self) -> String {
+        match *self {}
+    }
+
+    /// Reads proxy configuration from the database.
+    pub async fn load(_context: &Context) -> Result<Option<Self>> {
+        Ok(None)
+    }
+
+    /// Connects to the target via the proxy.
+    pub(crate) async fn connect(
+        &self,
+        _context: &Context,
+        _target_host: &str,
+        _target_port: u16,
+        _load_dns_cache: bool,
+    ) -> Result<Box<dyn SessionStream>> {
+        match *self {}
+    }
+}
