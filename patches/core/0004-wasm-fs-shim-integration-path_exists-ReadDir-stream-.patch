+/// Returns whether the path exists.
+///
+/// `Path::exists()` uses sync std::fs, which always errors on
+/// wasm32-unknown-unknown; the wasm fs shim tracks files in memory instead.
+pub(crate) fn path_exists(path: impl AsRef<Path>) -> bool {
+    #[cfg(not(target_arch = "wasm32"))]
+    {
+        path.as_ref().exists()
+    }
+    #[cfg(target_arch = "wasm32")]
+    {
+        fs::sync_exists(path.as_ref())
+    }
+}
