From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: experintellia <280144245+experintellia@users.noreply.github.com>
Date: Mon, 6 Jul 2026 22:34:43 +0000
Subject: [PATCH 7/8] wasm: route blob sync fs ops through the memfs shim

blob.rs does blocking std::fs inside block_in_place; std::fs is
unsupported on wasm32, so use the shim's sync_* memfs API there.
---
 src/blob.rs            | 97 ++++++++++++++++++++++++++++++------------
 src/blob/blob_tests.rs |  6 +--
 2 files changed, 72 insertions(+), 31 deletions(-)

diff --git a/src/blob.rs b/src/blob.rs
index 20267a913..a0c4e15dd 100644
--- a/src/blob.rs
+++ b/src/blob.rs
@@ -25,6 +25,26 @@
 use crate::message::Viewtype;
 use crate::tools::sanitize_filename;
 
+/// Synchronous filesystem ops used from `block_in_place` contexts.
+/// `std::fs` is unsupported on wasm32-unknown-unknown,
+/// so the in-memory `tokio::fs` shim is used there instead.
+#[cfg(not(target_arch = "wasm32"))]
+mod sync_fs {
+    pub use std::fs::{copy, create_dir_all, read, rename, write};
+}
+#[cfg(target_arch = "wasm32")]
+mod sync_fs {
+    pub use tokio::fs::{
+        sync_copy as copy, sync_create_dir_all as create_dir_all, sync_read as read,
+        sync_rename as rename, sync_write as write,
+    };
+}
+
+/// Object-safe reader used by [`BlobObject::check_or_recode_to_size`]
+/// so the same code can read from a file (native) or the in-memory fs (wasm).
+trait BufReadSeek: std::io::BufRead + std::io::Seek {}
+impl<T: std::io::BufRead + std::io::Seek> BufReadSeek for T {}
+
 /// Represents a file in the blob directory.
 ///
 /// The object has a name, which will always be valid UTF-8.  Having a
@@ -80,10 +100,10 @@ pub fn create_and_deduplicate(
                     "Source file not in blobdir. Copying instead of moving in order to prevent moving a file that was still needed."
                 );
                 temp_path = blobdir.join(format!("tmp-{}", rand::random::<u64>()));
-                if std::fs::copy(src, &temp_path).is_err() {
+                if sync_fs::copy(src, &temp_path).is_err() {
                     // Maybe the blobdir didn't exist
-                    std::fs::create_dir_all(blobdir).log_err(context).ok();
-                    std::fs::copy(src, &temp_path).context("Copying new blobfile failed")?;
+                    sync_fs::create_dir_all(blobdir).log_err(context).ok();
+                    sync_fs::copy(src, &temp_path).context("Copying new blobfile failed")?;
                 };
                 src_in_blobdir = &temp_path;
             }
@@ -108,7 +128,7 @@ pub fn create_and_deduplicate(
 
             // This will also replace an already-existing file.
             // Renaming is atomic, so this will avoid race conditions.
-            std::fs::rename(src_in_blobdir, &new_path)?;
+            sync_fs::rename(src_in_blobdir, &new_path)?;
 
             context.emit_event(EventType::NewBlobFile(blob.as_name().to_string()));
             Ok(blob)
@@ -132,10 +152,10 @@ pub fn create_and_deduplicate_from_bytes(
         task::block_in_place(|| {
             let blobdir = context.get_blobdir();
             let temp_path = blobdir.join(format!("tmp-{}", rand::random::<u64>()));
-            if std::fs::write(&temp_path, data).is_err() {
+            if sync_fs::write(&temp_path, data).is_err() {
                 // Maybe the blobdir didn't exist
-                std::fs::create_dir_all(blobdir).log_err(context).ok();
-                std::fs::write(&temp_path, data).context("writing new blobfile failed")?;
+                sync_fs::create_dir_all(blobdir).log_err(context).ok();
+                sync_fs::write(&temp_path, data).context("writing new blobfile failed")?;
             };
 
             BlobObject::create_and_deduplicate(context, &temp_path, Path::new(original_name))
@@ -336,21 +356,33 @@ fn check_or_recode_to_size(
         let original_name = name.clone();
         let vt = &mut *viewtype;
         let res: Result<String> = tokio::task::block_in_place(move || {
-            let mut file = std::fs::File::open(self.to_abs_path())?;
-            let (nr_bytes, exif) = image_metadata(&file)?;
+            let abs_path = self.to_abs_path();
+            #[cfg(target_arch = "wasm32")]
+            let file_bytes = sync_fs::read(&abs_path)?;
+            // Returns file length and a fresh reader positioned at the start.
+            let open_reader = || -> Result<(u64, Box<dyn BufReadSeek>)> {
+                #[cfg(not(target_arch = "wasm32"))]
+                {
+                    let file = std::fs::File::open(&abs_path)?;
+                    let nr_bytes = file.metadata()?.len();
+                    Ok((nr_bytes, Box::new(std::io::BufReader::new(file))))
+                }
+                #[cfg(target_arch = "wasm32")]
+                {
+                    let nr_bytes = file_bytes.len() as u64;
+                    Ok((nr_bytes, Box::new(Cursor::new(file_bytes.clone()))))
+                }
+            };
+            let (nr_bytes, mut file) = open_reader()?;
+            let exif = image_metadata(&mut file)?;
             *no_exif_ref = exif.is_none();
-            // It's strange that BufReader modifies a file position while it takes a non-mut
-            // reference. Ok, just rewind it.
             file.rewind()?;
-            let imgreader = ImageReader::new(std::io::BufReader::new(&file)).with_guessed_format();
+            let imgreader = ImageReader::new(file).with_guessed_format();
             let imgreader = match imgreader {
                 Ok(ir) => ir,
                 _ => {
-                    file.rewind()?;
-                    ImageReader::with_format(
-                        std::io::BufReader::new(&file),
-                        ImageFormat::from_path(self.to_abs_path())?,
-                    )
+                    let (_, file) = open_reader()?;
+                    ImageReader::with_format(file, ImageFormat::from_path(&abs_path)?)
                 }
             };
             let fmt = imgreader.format().context("Unknown format")?;
@@ -548,25 +580,34 @@ fn file_hash(src: &Path) -> Result<blake3::Hash> {
         "Use `get_abs_path()` to get the absolute path of the blobfile"
     );
     let mut hasher = blake3::Hasher::new();
-    let mut src_file = std::fs::File::open(src)
-        .with_context(|| format!("Failed to open file {}", src.display()))?;
-    hasher
-        .update_reader(&mut src_file)
-        .context("update_reader")?;
+    #[cfg(not(target_arch = "wasm32"))]
+    {
+        let mut src_file = std::fs::File::open(src)
+            .with_context(|| format!("Failed to open file {}", src.display()))?;
+        hasher
+            .update_reader(&mut src_file)
+            .context("update_reader")?;
+    }
+    #[cfg(target_arch = "wasm32")]
+    {
+        let data = sync_fs::read(src)
+            .with_context(|| format!("Failed to open file {}", src.display()))?;
+        hasher.update(&data);
+    }
     let hash = hasher.finalize();
     Ok(hash)
 }
 
-/// Returns image file size and Exif.
-fn image_metadata(file: &std::fs::File) -> Result<(u64, Option<exif::Exif>)> {
