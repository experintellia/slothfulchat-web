	#	dns porkbun {
	#		api_key {env.PORKBUN_API_KEY}
	#		api_secret_key {env.PORKBUN_API_SECRET_KEY}
	#	}
	# }
	# tls {
	#	dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	# }
}

# next.slothful.chat — main-branch build, deployed by deploy-preview.sh into
# /srv/slothfulchat/next/dist. The routes file is taken from the deployed
# bundle itself, so each deploy's reload picks up that version's routes.
# Uncomment once next has been deployed at least once — otherwise caddy fails
# to load on this missing import file on a fresh server.
# import /srv/slothfulchat/next/dist/caddy/routes.caddy next.slothful.chat /srv/slothfulchat/next/dist

# PR previews — one site.caddy per pr-<n>, written server-side by
# deploy-preview.sh. The glob targets */site.caddy specifically, so a permanent
# comment-only previews/_keep/site.caddy (created at bring-up, see README.md)
# guarantees the glob always matches at least one file and can never break
# config load on an empty previews/ directory.
import /srv/slothfulchat/previews/*/site.caddy

