# Local webxdc dev harness. `pnpm dev:webxdc` runs this (via dev-caddy.mjs),
# which also starts serve.mjs on port 8643 for Caddy to proxy to.
# Plain HTTP: browsers resolve any *.localhost (multi-label too) to loopback and
# treat it as a secure context, so the app's SW registers without any certs.
# Plain `pnpm serve` still works standalone — you just don't get the webxdc
# subdomains without Caddy.

http://app.localhost:8642 {
	# Parity with routes.caddy: the shipped config under /caddy/ is never served.
	error /caddy/* 404
	reverse_proxy localhost:8643
}

http://*.webxdc.app.localhost:8642 {
	# Mirror routes.caddy's webxdc block: every path serves the test page. We
	# proxy to serve.mjs (rather than file_server) to reuse its MIME handling.
	rewrite * /webxdc-test.html
	reverse_proxy localhost:8643
}
