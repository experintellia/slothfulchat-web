{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    // src/events.mjs is plain JS (shared with instance-config.mjs at build
    // time) — let tsc type-check it via its JSDoc annotation
    "allowJs": true,
    // packages/calls/ui is React (docs/calls.md: the call UI is "our own React
    // tree mounted by the runtime", unrelated to upstream desktop's own React
    // build). No JSX in src/ yet (M0: runtime.ts still stubs the call hooks),
    // but the option must be here before M1 adds any.
    "jsx": "react-jsx",
    // core-wasm ships no .d.ts (esbuild build); packages/calls ships no dist
    // at all (private, source-consumed only) — resolve both from source.
    // esbuild honors these paths too, so the bundle also builds from source.
    "paths": {
      "@slothfulchat/core-wasm": ["../core-wasm/src/index.ts"],
      "@slothfulchat/calls/engine": ["../calls/engine/index.ts"],
      "@slothfulchat/calls/ui": ["../calls/ui/index.tsx"],
      "@slothfulchat/calls/bridge": ["../calls/bridge/index.ts"]
    }
  },
  "include": ["src"]
}
