{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    // core-wasm ships no .d.ts (esbuild build) — resolve types from its source.
    // esbuild honors these paths too, so the bundle also builds from source.
    "paths": {
      "@slothfulchat/core-wasm": ["../core-wasm/src/index.ts"]
    }
  },
  "include": ["src"]
}
